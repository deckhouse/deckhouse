# render imports for candi images
# . is dict with next params
#   Env - werf env
{{- define "candi_generic_imports" }}
{{- $context := . -}}

- image: dev/candi
  add: /deckhouse
  to: /deckhouse
  before: setup
- image: dev-prebuild
  add: /deckhouse
  to: /deckhouse
  includePaths:
  - modules/*/openapi/config-values.yaml
  - global-hooks/openapi/config-values.yaml
  after: setup
- image: version-map-artifact
  add: /version_map_{{ $context.Env }}.yml
  to: /deckhouse/candi/version_map.yml
  before: setup
{{- end }}

# render shell scripts for preparing candi image
# . is dict with keys:
#   CI_COMMIT_TAG - CI_COMMIT_TAG env
{{- define "candi_prepare_with_shell" }}
{{- $context := . -}}

shell:
  setup:
  - echo '{{- $context.CI_COMMIT_TAG }}' > /deckhouse/version
{{- end }}
