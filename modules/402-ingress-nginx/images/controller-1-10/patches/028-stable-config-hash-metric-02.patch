+// deepCopyConfigurationForHash returns a full deep copy of the configuration with variable
+// or per-pod data cleared (Backend.Endpoints, SSLCert.Certificate/CACertificate, L4Service.Endpoints)
+// so the copy is suitable for deterministic hashing.
+// All slices are canonically sorted so slice order cannot differ across pods.
+func deepCopyConfigurationForHash(cfg *ingress.Configuration) *ingress.Configuration {
+	if cfg == nil {
+		return nil
+	}
+	cfgCopy := &ingress.Configuration{
+		BackendConfigChecksum: cfg.BackendConfigChecksum,
+		ConfigurationChecksum: cfg.ConfigurationChecksum,
+	}
+	if len(cfg.Backends) > 0 {
+		cfgCopy.Backends = make([]*ingress.Backend, len(cfg.Backends))
+		for i, b := range cfg.Backends {
+			if b != nil {
+				bc := b.DeepCopy()
+				bc.Endpoints = nil
+				cfgCopy.Backends[i] = bc
+			}
+		}
+	}
+	if len(cfg.Servers) > 0 {
+		cfgCopy.Servers = make([]*ingress.Server, len(cfg.Servers))
+		for i, s := range cfg.Servers {
+			if s != nil {
+				cfgCopy.Servers[i] = deepCopyServerForHash(s)
+			}
+		}
+	}
+	if len(cfg.TCPEndpoints) > 0 {
+		cfgCopy.TCPEndpoints = make([]ingress.L4Service, len(cfg.TCPEndpoints))
+		for i := range cfg.TCPEndpoints {
+			cfgCopy.TCPEndpoints[i] = cfg.TCPEndpoints[i]
+			cfgCopy.TCPEndpoints[i].Endpoints = nil
+		}
+	}
+	if len(cfg.UDPEndpoints) > 0 {
+		cfgCopy.UDPEndpoints = make([]ingress.L4Service, len(cfg.UDPEndpoints))
+		for i := range cfg.UDPEndpoints {
+			cfgCopy.UDPEndpoints[i] = cfg.UDPEndpoints[i]
+			cfgCopy.UDPEndpoints[i].Endpoints = nil
+		}
+	}
+	if len(cfg.PassthroughBackends) > 0 {
+		cfgCopy.PassthroughBackends = make([]*ingress.SSLPassthroughBackend, len(cfg.PassthroughBackends))
+		for i, p := range cfg.PassthroughBackends {
+			if p != nil {
+				cfgCopy.PassthroughBackends[i] = &ingress.SSLPassthroughBackend{
+					Port:     p.Port,
+					Backend:  p.Backend,
+					Hostname: p.Hostname,
+				}
+			}
+		}
+	}
+	if cfg.DefaultSSLCertificate != nil {
+		cfgCopy.DefaultSSLCertificate = deepCopySSLCertForHash(cfg.DefaultSSLCertificate)
+	}
+	if len(cfg.StreamSnippets) > 0 {
+		cfgCopy.StreamSnippets = make([]string, len(cfg.StreamSnippets))
+		copy(cfgCopy.StreamSnippets, cfg.StreamSnippets)
+	}
+	sortConfigCopyForHash(cfgCopy)
+	return cfgCopy
+}
+
+// sortConfigCopyForHash sorts all slices in the config copy so hashing is order-independent.
+func sortConfigCopyForHash(cfg *ingress.Configuration) {
+	if cfg == nil {
+		return
+	}
+	sort.Slice(cfg.Backends, func(i, j int) bool {
+		if cfg.Backends[i] == nil {
+			return cfg.Backends[j] != nil
+		}
+		if cfg.Backends[j] == nil {
+			return false
+		}
+		return cfg.Backends[i].Name < cfg.Backends[j].Name
+	})
+	for _, b := range cfg.Backends {
+		if b == nil {
+			continue
+		}
+		if len(b.AlternativeBackends) > 1 {
+			sort.Strings(b.AlternativeBackends)
+		}
+		// Sort map values so serialization is deterministic (CookieSessionAffinity.Locations is map[string][]string).
+		if b.SessionAffinity.CookieSessionAffinity.Locations != nil {
+			for k, v := range b.SessionAffinity.CookieSessionAffinity.Locations {
+				if len(v) > 1 {
+					sort.Strings(v)
+					b.SessionAffinity.CookieSessionAffinity.Locations[k] = v
+				}
+			}
+		}
+	}
+	sort.Slice(cfg.Servers, func(i, j int) bool {
+		if cfg.Servers[i] == nil {
+			return cfg.Servers[j] != nil
+		}
+		if cfg.Servers[j] == nil {
+			return false
+		}
+		return cfg.Servers[i].Hostname < cfg.Servers[j].Hostname
+	})
+	for _, s := range cfg.Servers {
+		if s != nil && len(s.Locations) > 1 {
+			sort.Slice(s.Locations, func(i, j int) bool {
+				li, lj := s.Locations[i], s.Locations[j]
+				if li == nil {
+					return lj != nil
+				}
+				if lj == nil {
+					return false
+				}
+				if len(li.Path) != len(lj.Path) {
+					return len(li.Path) > len(lj.Path)
+				}
+				return li.Path > lj.Path
+			})
+		}
+		if s != nil && len(s.Aliases) > 1 {
+			sort.Strings(s.Aliases)
+		}
+	}
+	sort.Slice(cfg.TCPEndpoints, func(i, j int) bool {
+		return cfg.TCPEndpoints[i].Port < cfg.TCPEndpoints[j].Port
+	})
+	sort.Slice(cfg.UDPEndpoints, func(i, j int) bool {
+		return cfg.UDPEndpoints[i].Port < cfg.UDPEndpoints[j].Port
+	})
+	sort.Slice(cfg.PassthroughBackends, func(i, j int) bool {
+		if cfg.PassthroughBackends[i] == nil {
+			return cfg.PassthroughBackends[j] != nil
+		}
+		if cfg.PassthroughBackends[j] == nil {
+			return false
+		}
+		a, b := cfg.PassthroughBackends[i], cfg.PassthroughBackends[j]
+		if a.Hostname != b.Hostname {
+			return a.Hostname < b.Hostname
+		}
+		return a.Backend < b.Backend
+	})
+	if len(cfg.StreamSnippets) > 1 {
+		sort.Strings(cfg.StreamSnippets)
+	}
+}
+
+// deepCopyServerForHash returns a deep copy of the server with SSLCert certificate pointers
+// cleared. Locations are copied so the copy can be sorted; metadata is left in place.
+func deepCopyServerForHash(s *ingress.Server) *ingress.Server {
+	if s == nil {
+		return nil
+	}
+	out := &ingress.Server{
+		Hostname:               s.Hostname,
+		SSLPassthrough:         s.SSLPassthrough,
+		RedirectFromToWWW:      s.RedirectFromToWWW,
+		CertificateAuth:        s.CertificateAuth,
+		ProxySSL:               s.ProxySSL,
+		ServerSnippet:          s.ServerSnippet,
+		SSLCiphers:             s.SSLCiphers,
+		SSLPreferServerCiphers: s.SSLPreferServerCiphers,
+		AuthTLSError:           s.AuthTLSError,
+		Locations:              deepCopyLocationsForHash(s.Locations),
+		Aliases:                append([]string(nil), s.Aliases...),
+	}
+	if s.SSLCert != nil {
+		out.SSLCert = deepCopySSLCertForHash(s.SSLCert)
+	}
+	return out
+}
+
+// deepCopyLocationsForHash returns a copy of the location slice (shallow copy of each Location)
+// so the copy can be sorted without mutating the original. Metadata is left in place.
+func deepCopyLocationsForHash(locs []*ingress.Location) []*ingress.Location {
+	if len(locs) == 0 {
+		return nil
+	}
+	out := make([]*ingress.Location, len(locs))
+	for i, loc := range locs {
+		if loc == nil {
+			continue
+		}
+		locCopy := *loc
+		out[i] = &locCopy
+	}
+	return out
+}
+
+// deepCopySSLCertForHash returns a copy of the cert with Certificate and CACertificate cleared.
+// For the per-pod fake certificate (identified by FakeSSLCertificateUID), the volatile fields
+// (PemCertKey, PemSHA, ExpireTime) are zeroed so all pods produce the same hash.
+func deepCopySSLCertForHash(sc *ingress.SSLCert) *ingress.SSLCert {
+	if sc == nil {
+		return nil
+	}
+	cnCopy := append([]string(nil), sc.CN...)
+	if len(cnCopy) > 1 {
+		sort.Strings(cnCopy)
+	}
+	out := &ingress.SSLCert{
+		Name:        sc.Name,
+		Namespace:   sc.Namespace,
+		CAFileName:  sc.CAFileName,
+		CASHA:       sc.CASHA,
+		CRLFileName: sc.CRLFileName,
+		CRLSHA:      sc.CRLSHA,
+		PemFileName: sc.PemFileName,
+		PemSHA:      sc.PemSHA,
+		CN:          cnCopy,
+		ExpireTime:  sc.ExpireTime,
+		PemCertKey:  sc.PemCertKey,
+		UID:         sc.UID,
+	}
+	if sc.UID == ssl.FakeSSLCertificateUID {
+		out.PemCertKey = ""
+		out.PemSHA = ""
+		out.ExpireTime = time.Time{}
+	}
+	return out
+}
+
+// hashConfigurationDeterministic returns a deterministic hash of the configuration so that all
+// controller pods with the same config report the same config_hash metric. Uses a full deep copy
+// with variable data cleared and all slices/map values sorted, then JSON (Go sorts map keys) plus xxhash.
+func hashConfigurationDeterministic(cfg *ingress.Configuration) (uint64, error) {
+	cfgCopy := deepCopyConfigurationForHash(cfg)
+	data, err := json.Marshal(cfgCopy)
+	if err != nil {
+		klog.Errorf("config_hash: json.Marshal failed: %v", err)
+		return 0, err
+	}
+	return xxhash.Sum64(data), nil
+}
