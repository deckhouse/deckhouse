+
+package controller
+
+import (
+	"net"
+	"testing"
+
+	ngx_config "k8s.io/ingress-nginx/internal/ingress/controller/config"
+	"k8s.io/ingress-nginx/internal/ingress/defaults"
+	"k8s.io/ingress-nginx/internal/ingress/annotations/authtls"
+	"k8s.io/ingress-nginx/internal/ingress/annotations/proxyssl"
+	"k8s.io/ingress-nginx/internal/ingress/resolver"
+	"k8s.io/ingress-nginx/pkg/apis/ingress"
+)
+
+func TestCopyTemplateConfigForHashClearsChecksumAndPEMFields(t *testing.T) {
+	tc := &ngx_config.TemplateConfig{
+		BacklogSize:   4096,
+		IsIPV6Enabled: true,
+		Cfg: ngx_config.Configuration{
+			Backend: defaults.Backend{
+				Resolver: []net.IP{net.ParseIP("10.0.0.10")},
+			},
+			Checksum:             "12345",
+			MaxWorkerOpenFiles:   65536,
+			MaxWorkerConnections: 49152,
+			WorkerProcesses:      "8",
+			WorkerCPUAffinity:    "auto",
+			DisableIpv6DNS:       true,
+			DisableIpv6:          false,
+			DefaultSSLCertificate: &ingress.SSLCert{
+				PemSHA: "default-pem-sha",
+			},
+		},
+		Servers: []*ingress.Server{
+			{
+				CertificateAuth: authtls.Config{
+					AuthSSLCert: resolver.AuthSSLCert{
+						CASHA:  "ca-sha",
+						CRLSHA: "crl-sha",
+					},
+				},
+				ProxySSL: proxyssl.Config{
+					AuthSSLCert: resolver.AuthSSLCert{
+						CASHA: "proxy-ca-sha",
+					},
+				},
+				Locations: []*ingress.Location{
+					{
+						ProxySSL: proxyssl.Config{
+							AuthSSLCert: resolver.AuthSSLCert{
+								CASHA: "location-proxy-ca-sha",
+							},
+						},
+					},
+				},
+			},
+		},
+	}
+
+	hashTC := copyTemplateConfigForHash(tc)
+
+	if hashTC.Cfg.Checksum != "" {
+		t.Fatalf("expected empty checksum, got %q", hashTC.Cfg.Checksum)
+	}
+	if len(hashTC.Cfg.Resolver) != 0 {
+		t.Fatalf("expected empty resolver, got %v", hashTC.Cfg.Resolver)
+	}
+	if hashTC.Cfg.MaxWorkerOpenFiles != 0 || hashTC.Cfg.MaxWorkerConnections != 0 {
+		t.Fatalf("expected zero worker limits, got open=%d conn=%d", hashTC.Cfg.MaxWorkerOpenFiles, hashTC.Cfg.MaxWorkerConnections)
+	}
+	if hashTC.Cfg.WorkerProcesses != "" || hashTC.Cfg.WorkerCPUAffinity != "" {
+		t.Fatalf("expected empty worker process settings, got processes=%q affinity=%q", hashTC.Cfg.WorkerProcesses, hashTC.Cfg.WorkerCPUAffinity)
+	}
+	if hashTC.Cfg.DisableIpv6DNS || hashTC.Cfg.DisableIpv6 {
+		t.Fatalf("expected ipv6 dns/disable flags cleared for hash pass")
+	}
+	if hashTC.BacklogSize != 0 || hashTC.IsIPV6Enabled {
+		t.Fatalf("expected zero backlog and disabled ipv6 template flag")
+	}
+	if hashTC.Cfg.DefaultSSLCertificate == nil || hashTC.Cfg.DefaultSSLCertificate.PemSHA != "" {
+		t.Fatalf("expected cleared default SSL PemSHA")
+	}
+	if hashTC.Servers[0].CertificateAuth.CASHA != "" || hashTC.Servers[0].CertificateAuth.CRLSHA != "" {
+		t.Fatalf("expected cleared server certificate auth PEM sha fields")
+	}
+	if hashTC.Servers[0].ProxySSL.CASHA != "" {
+		t.Fatalf("expected cleared server proxy SSL PEM sha")
+	}
+	if hashTC.Servers[0].Locations[0].ProxySSL.CASHA != "" {
+		t.Fatalf("expected cleared location proxy SSL PEM sha")
+	}
+
+	if tc.Cfg.Checksum != "12345" {
+		t.Fatalf("copy should not mutate original checksum")
+	}
+	if len(tc.Cfg.Resolver) != 1 || tc.BacklogSize != 4096 || !tc.IsIPV6Enabled {
+		t.Fatalf("copy should not mutate original AUTO fields")
+	}
+	if tc.Cfg.DefaultSSLCertificate.PemSHA != "default-pem-sha" {
+		t.Fatalf("copy should not mutate original default SSL PemSHA")
+	}
+}
