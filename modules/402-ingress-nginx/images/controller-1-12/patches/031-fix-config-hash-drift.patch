+package controller
+
+import (
+	"fmt"
+
+	"github.com/cespare/xxhash/v2"
+
+	ngx_config "k8s.io/ingress-nginx/internal/ingress/controller/config"
+	"k8s.io/ingress-nginx/pkg/apis/ingress"
+)
+
+// hashTemplateConfig renders nginx.conf from a prepared template config with
+// checksum and PEM sha comment fields cleared, then hashes the result.
+func (n *NGINXController) hashTemplateConfig(tc *ngx_config.TemplateConfig) (uint64, error) {
+	hashTC := copyTemplateConfigForHash(tc)
+	content, err := n.t.Write(hashTC)
+	if err != nil {
+		return 0, err
+	}
+
+	return xxhash.Sum64(content), nil
+}
+
+// hashRenderedTemplateConfiguration renders nginx.conf with checksum, PEM sha
+// comments, and per-node AUTO values normalized, then hashes the result.
+func (n *NGINXController) hashRenderedTemplateConfiguration(ingressCfg ingress.Configuration) (uint64, error) {
+	cfg := n.store.GetBackendConfiguration()
+	cfg.Resolver = n.resolver
+
+	tc, err := n.buildTemplateConfig(cfg, ingressCfg)
+	if err != nil {
+		return 0, err
+	}
+
+	return n.hashTemplateConfig(tc)
+}
+
+// copyTemplateConfigForHash returns a copy of the template config suitable for
+// hashing: checksum and PEM sha comments cleared, and per-node/per-pod AUTO
+// values zeroed so pods sharing the same ingress config produce the same hash.
+func copyTemplateConfigForHash(tc *ngx_config.TemplateConfig) *ngx_config.TemplateConfig {
+	if tc == nil {
+		return nil
+	}
+
+	out := *tc
+	normalizeTemplateConfigForHash(&out)
+
+	if tc.Cfg.DefaultSSLCertificate != nil {
+		cert := *tc.Cfg.DefaultSSLCertificate
+		cert.PemSHA = ""
+		out.Cfg.DefaultSSLCertificate = &cert
+	}
+
+	out.Servers = copyServersForTemplateHash(tc.Servers)
+
+	return &out
+}
+
+// normalizeTemplateConfigForHash blanks values that are resolved per node or per
+// pod when left at AUTO/DEFAULT in the shared configmap or deployment.
+func normalizeTemplateConfigForHash(tc *ngx_config.TemplateConfig) {
+	tc.Cfg.Checksum = ""
+	tc.Cfg.Resolver = nil
+	tc.Cfg.MaxWorkerOpenFiles = 0
+	tc.Cfg.MaxWorkerConnections = 0
+	tc.Cfg.WorkerProcesses = ""
+	tc.Cfg.WorkerCPUAffinity = ""
+	tc.Cfg.DisableIpv6DNS = false
+	tc.Cfg.DisableIpv6 = false
+
+	tc.BacklogSize = 0
+	tc.IsIPV6Enabled = false
+}
+
+func copyServersForTemplateHash(servers []*ingress.Server) []*ingress.Server {
+	if len(servers) == 0 {
+		return nil
+	}
+
+	out := make([]*ingress.Server, len(servers))
+	for i, s := range servers {
+		if s == nil {
+			continue
+		}
+
+		srv := *s
+		srv.CertificateAuth.CASHA = ""
+		srv.CertificateAuth.CRLSHA = ""
+		srv.ProxySSL.CASHA = ""
+
+		if len(s.Locations) > 0 {
+			locs := make([]*ingress.Location, len(s.Locations))
+			for j, loc := range s.Locations {
+				if loc == nil {
+					continue
+				}
+				l := *loc
+				l.ProxySSL.CASHA = ""
+				locs[j] = &l
+			}
+			srv.Locations = locs
+		}
+
+		out[i] = &srv
+	}
+
+	return out
+}
+
+func checksumFromTemplateHash(hash uint64) string {
+	return fmt.Sprintf("%v", hash)
+}
