diff --git a/internal/ingress/status/status.go b/internal/ingress/status/status.go
index 150573dce..7bee5a233 100644
--- a/internal/ingress/status/status.go
+++ b/internal/ingress/status/status.go
@@ -64,6 +64,8 @@ type Config struct {
 
 	PublishStatusAddress string
 
+	StatusServiceLabel string
+
 	UpdateStatusOnShutdown bool
 
 	UseNodeInternalIP bool
@@ -191,6 +193,18 @@ func (s *statusSync) runningAddresses() ([]v1.IngressLoadBalancerIngress, error)
 		return addrs, nil
 	}
 
+	if s.StatusServiceLabel != "" {
+		addrs, err := getStatusAddressFromServiceByLabel(s.StatusServiceLabel, s.Client)
+		if err == nil && len(addrs) > 0 {
+			return addrs, nil
+		}
+		if err != nil {
+			klog.Warningf("error getting addresses from services with selector %q: %v", s.StatusServiceLabel, err)
+		} else {
+			klog.V(2).Infof("no Services found for selector %q, falling back", s.StatusServiceLabel)
+		}
+	}
+
 	if s.PublishService != "" {
 		return statusAddressFromService(s.PublishService, s.Client)
 	}
@@ -408,3 +422,38 @@ func stringInIngresses(s string, list []v1.IngressLoadBalancerIngress) bool {
 
 	return false
 }
+
+func getStatusAddressFromServiceByLabel(label string, kubeClient clientset.Interface) ([]v1.IngressLoadBalancerIngress, error) {
+	services, err := kubeClient.CoreV1().Services("").List(context.TODO(), metav1.ListOptions{
+		LabelSelector: label,
+	})
+	if err != nil {
+		return nil, err
+	}
+
+	addresses := make([]v1.IngressLoadBalancerIngress, 0)
+
+	for i := range services.Items {
+		svc := &services.Items[i]
+		svcAddrs, err := statusAddressFromService(k8s.MetaNamespaceKey(svc), kubeClient)
+		if err != nil {
+			klog.Warningf("error extracting addresses from service %s/%s: %v", svc.Namespace, svc.Name, err)
+			continue
+		}
+
+		for _, addr := range svcAddrs {
+			key := addr.IP
+			if key == "" {
+				key = addr.Hostname
+			}
+			if key == "" {
+				continue
+			}
+			if !stringInIngresses(key, addresses) {
+				addresses = append(addresses, addr)
+			}
+		}
+	}
+
+	return addresses, nil
+}
