+distributed under the License is distributed on an "AS IS" BASIS,
+WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.
+See the License for the specific language governing permissions and
+limitations under the License.
+*/
+
+package scope
+
+import metav1 "k8s.io/apimachinery/pkg/apis/meta/v1"
+
+type conditionsAware interface {
+	GetConditions() []metav1.Condition
+	SetConditions([]metav1.Condition)
+}
+
+func normalizeLegacyConditions(obj conditionsAware) {
+	conditions := obj.GetConditions()
+	if len(conditions) == 0 {
+		return
+	}
+
+	for i := range conditions {
+		if conditions[i].Reason == "" {
+			conditions[i].Reason = "MigratedFromBeta1"
+		}
+		if conditions[i].Message == "" {
+			conditions[i].Message = "Condition restored during migration to v1beta2"
+		}
+		if conditions[i].LastTransitionTime.IsZero() {
+			conditions[i].LastTransitionTime = metav1.Now()
+		}
+	}
+
+	obj.SetConditions(conditions)
+}
