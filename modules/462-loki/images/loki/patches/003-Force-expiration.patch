+	expiredChunksSizeBytes            prometheus.Counter
+	dirUsageThresholdBytes            *prometheus.GaugeVec
+	dirUsageBytes                     *prometheus.GaugeVec
+	dirUsageEvaluationDuration        *prometheus.HistogramVec
+}
