+package loki
+
+import (
+	"context"
+
+	"github.com/grafana/dskit/grpcutil"
+	"github.com/grafana/dskit/services"
+	"google.golang.org/grpc/health/grpc_health_v1"
+)
+
+// healthCheckAdapter wraps grpcutil.HealthCheck to satisfy the
+// grpc_health_v1.HealthServer interface which added a List method
+// in newer gRPC versions.
+type healthCheckAdapter struct {
+	grpc_health_v1.UnimplementedHealthServer
+	hc *grpcutil.HealthCheck
+}
+
+func newHealthCheck(sm *services.Manager) *healthCheckAdapter {
+	return &healthCheckAdapter{hc: grpcutil.NewHealthCheck(sm)}
+}
+
+func (a *healthCheckAdapter) Check(ctx context.Context, req *grpc_health_v1.HealthCheckRequest) (*grpc_health_v1.HealthCheckResponse, error) {
+	return a.hc.Check(ctx, req)
+}
+
+func (a *healthCheckAdapter) Watch(req *grpc_health_v1.HealthCheckRequest, srv grpc_health_v1.Health_WatchServer) error {
+	return a.hc.Watch(req, srv)
+}
+
+func (a *healthCheckAdapter) List(ctx context.Context, req *grpc_health_v1.HealthListRequest) (*grpc_health_v1.HealthListResponse, error) {
+	resp, err := a.hc.Check(ctx, &grpc_health_v1.HealthCheckRequest{})
+	if err != nil {
+		return nil, err
+	}
+	return &grpc_health_v1.HealthListResponse{
+		Statuses: map[string]*grpc_health_v1.HealthCheckResponse{
+			"": resp,
+		},
+	}, nil
+}
