diff --git a/go-mod-tidy-all.sh b/go-mod-tidy-all.sh
new file mode 100644
index 0000000..ac19a79
--- /dev/null
+++ b/go-mod-tidy-all.sh
@@ -0,0 +1,11 @@
+#!/bin/bash
+
+find . -name "go.mod" | while read -r modfile; do
+    dir=$(dirname "$modfile")
+    
+    echo "Processing: $dir"
+    
+    (cd "$dir" && go mod tidy)
+done
+
+echo "Done!"
