diff --git a/server/lockout_test.go b/server/lockout_test.go
new file mode 100644
index 00000000..37a42aeb
--- /dev/null
+++ b/server/lockout_test.go
@@ -0,0 +1,264 @@
+package server
+
+import (
+	"context"
+	"log/slog"
+	"testing"
+	"time"
+
+	"github.com/dexidp/dex/connector"
+	"github.com/dexidp/dex/storage"
+	"github.com/dexidp/dex/storage/memory"
+)
+
+// newLockoutTestServer wires up the minimum *Server needed by
+// recordOfflineSessionFailedAttempt (storage + passwordPolicy).
+func newLockoutTestServer(t *testing.T, maxAttempts uint64, lockDuration time.Duration, applyTo ...string) (*Server, storage.Storage) {
+	t.Helper()
+	pp, err := NewPasswordPolicy("test")
+	if err != nil {
+		t.Fatalf("NewPasswordPolicy: %v", err)
+	}
+	if err := WithLockoutSettings(maxAttempts, lockDuration)(pp); err != nil {
+		t.Fatalf("WithLockoutSettings: %v", err)
+	}
+	if len(applyTo) > 0 {
+		if err := WithLockoutApplyToConnectors(applyTo)(pp); err != nil {
+			t.Fatalf("WithLockoutApplyToConnectors: %v", err)
+		}
+	}
+	stor := memory.New(slog.New(slog.DiscardHandler))
+	return &Server{
+		storage:        stor,
+		passwordPolicy: pp,
+		logger:         slog.New(slog.DiscardHandler),
+	}, stor
+}
+
+func TestAppliesToConnectorType(t *testing.T) {
+	t.Run("nil lockout", func(t *testing.T) {
+		pp, err := NewPasswordPolicy("test")
+		if err != nil {
+			t.Fatal(err)
+		}
+		if pp.AppliesToConnectorType("local") {
+			t.Fatal("expected false for nil lockout")
+		}
+	})
+
+	t.Run("empty applyTo defaults to local", func(t *testing.T) {
+		pp, err := NewPasswordPolicy("test", WithLockoutSettings(5, time.Minute))
+		if err != nil {
+			t.Fatal(err)
+		}
+		if !pp.AppliesToConnectorType("local") {
+			t.Fatal("expected local to be covered by default")
+		}
+		if !pp.AppliesToConnectorType("LOCAL") {
+			t.Fatal("expected case-insensitive match")
+		}
+		if pp.AppliesToConnectorType("ldap") {
+			t.Fatal("expected ldap to be excluded by default")
+		}
+	})
+
+	t.Run("explicit list", func(t *testing.T) {
+		pp, err := NewPasswordPolicy("test",
+			WithLockoutSettings(5, time.Minute),
+			WithLockoutApplyToConnectors([]string{"LDAP", "atlassian-crowd"}),
+		)
+		if err != nil {
+			t.Fatal(err)
+		}
+		if !pp.AppliesToConnectorType("ldap") {
+			t.Fatal("ldap must match")
+		}
+		if !pp.AppliesToConnectorType("Atlassian-Crowd") {
+			t.Fatal("crowd must match case-insensitively")
+		}
+		if pp.AppliesToConnectorType("local") {
+			t.Fatal("local must NOT match when not in explicit list")
+		}
+	})
+
+	t.Run("apply requires lockout configured first", func(t *testing.T) {
+		pp, err := NewPasswordPolicy("test", WithLockoutApplyToConnectors([]string{"ldap"}))
+		if err == nil {
+			t.Fatalf("expected error, got pp=%+v", pp)
+		}
+	})
+}
+
+func TestIsOfflineSessionLocked(t *testing.T) {
+	pp, _ := NewPasswordPolicy("test", WithLockoutSettings(5, time.Minute))
+	future := time.Now().Add(time.Minute)
+	past := time.Now().Add(-time.Minute)
+
+	if !pp.IsOfflineSessionLocked(storage.OfflineSessions{LockedUntil: &future}) {
+		t.Fatal("expected locked when LockedUntil is in the future")
+	}
+	if pp.IsOfflineSessionLocked(storage.OfflineSessions{LockedUntil: &past}) {
+		t.Fatal("expected unlocked when LockedUntil is in the past")
+	}
+	if pp.IsOfflineSessionLocked(storage.OfflineSessions{}) {
+		t.Fatal("expected unlocked when LockedUntil is nil")
+	}
+}
+
+func TestRecordOfflineSessionFailedAttempt_FirstFailureCreatesStub(t *testing.T) {
+	s, stor := newLockoutTestServer(t, 5, time.Minute, "ldap")
+	ctx := context.Background()
+	ident := connector.Identity{UserID: "user1", Email: "user1@example.org"}
+
+	locked, err := s.recordOfflineSessionFailedAttempt(ctx, ident, "ldap")
+	if err != nil {
+		t.Fatalf("unexpected error: %v", err)
+	}
+	if locked {
+		t.Fatal("threshold not reached, expected lockedNow=false")
+	}
+
+	got, err := stor.GetOfflineSessions(ctx, "user1", "ldap")
+	if err != nil {
+		t.Fatalf("GetOfflineSessions: %v", err)
+	}
+	if got.IncorrectPasswordLoginAttempts != 1 {
+		t.Fatalf("got attempts=%d, want 1", got.IncorrectPasswordLoginAttempts)
+	}
+	if got.Email != "user1@example.org" {
+		t.Fatalf("got email=%q, want user1@example.org", got.Email)
+	}
+	if got.LockedUntil != nil {
+		t.Fatalf("expected LockedUntil=nil, got %v", got.LockedUntil)
+	}
+}
+
+func TestRecordOfflineSessionFailedAttempt_IncrementsExisting(t *testing.T) {
+	s, stor := newLockoutTestServer(t, 5, time.Minute, "ldap")
+	ctx := context.Background()
+
+	if err := stor.CreateOfflineSessions(ctx, storage.OfflineSessions{
+		UserID:                         "user2",
+		ConnID:                         "ldap",
+		Email:                          "user2@example.org",
+		Refresh:                        map[string]*storage.RefreshTokenRef{},
+		IncorrectPasswordLoginAttempts: 2,
+	}); err != nil {
+		t.Fatalf("CreateOfflineSessions: %v", err)
+	}
+
+	locked, err := s.recordOfflineSessionFailedAttempt(ctx, connector.Identity{UserID: "user2", Email: "user2@example.org"}, "ldap")
+	if err != nil {
+		t.Fatal(err)
+	}
+	if locked {
+		t.Fatal("expected lockedNow=false (3 < 5)")
+	}
+
+	got, _ := stor.GetOfflineSessions(ctx, "user2", "ldap")
+	if got.IncorrectPasswordLoginAttempts != 3 {
+		t.Fatalf("got attempts=%d, want 3", got.IncorrectPasswordLoginAttempts)
+	}
+}
+
+func TestRecordOfflineSessionFailedAttempt_LocksAtThreshold(t *testing.T) {
+	s, stor := newLockoutTestServer(t, 3, 5*time.Minute, "ldap")
+	ctx := context.Background()
+
+	if err := stor.CreateOfflineSessions(ctx, storage.OfflineSessions{
+		UserID:                         "user3",
+		ConnID:                         "ldap",
+		Refresh:                        map[string]*storage.RefreshTokenRef{},
+		IncorrectPasswordLoginAttempts: 2,
+	}); err != nil {
+		t.Fatalf("CreateOfflineSessions: %v", err)
+	}
+
+	before := time.Now()
+	locked, err := s.recordOfflineSessionFailedAttempt(ctx, connector.Identity{UserID: "user3", Email: "user3@example.org"}, "ldap")
+	if err != nil {
+		t.Fatal(err)
+	}
+	if !locked {
+		t.Fatal("expected lockedNow=true at threshold (3 >= 3)")
+	}
+
+	got, _ := stor.GetOfflineSessions(ctx, "user3", "ldap")
+	if got.IncorrectPasswordLoginAttempts != 0 {
+		t.Fatalf("expected counter reset, got %d", got.IncorrectPasswordLoginAttempts)
+	}
+	if got.LockedUntil == nil {
+		t.Fatal("expected LockedUntil to be set")
+	}
+	if got.LockedUntil.Before(before.Add(4 * time.Minute)) {
+		t.Fatalf("LockedUntil too small: %v (before=%v)", got.LockedUntil, before)
+	}
+	if got.LockedUntil.After(before.Add(6 * time.Minute)) {
+		t.Fatalf("LockedUntil too big: %v", got.LockedUntil)
+	}
+	if got.Email != "user3@example.org" {
+		t.Fatalf("expected email backfill, got %q", got.Email)
+	}
+}
+
+func TestRecordOfflineSessionFailedAttempt_LocksImmediatelyWhenMaxIs1(t *testing.T) {
+	s, stor := newLockoutTestServer(t, 1, time.Minute, "ldap")
+	ctx := context.Background()
+
+	locked, err := s.recordOfflineSessionFailedAttempt(ctx, connector.Identity{UserID: "user4", Email: "u4@x"}, "ldap")
+	if err != nil {
+		t.Fatal(err)
+	}
+	if !locked {
+		t.Fatal("expected immediate lock when threshold=1")
+	}
+	got, _ := stor.GetOfflineSessions(ctx, "user4", "ldap")
+	if got.LockedUntil == nil {
+		t.Fatal("expected LockedUntil set")
+	}
+	if got.IncorrectPasswordLoginAttempts != 0 {
+		t.Fatalf("expected attempts reset, got %d", got.IncorrectPasswordLoginAttempts)
+	}
+}
+
+func TestRecordOfflineSessionFailedAttempt_NoPolicyIsNoOp(t *testing.T) {
+	stor := memory.New(slog.New(slog.DiscardHandler))
+	s := &Server{
+		storage:        stor,
+		passwordPolicy: nil,
+		logger:         slog.New(slog.DiscardHandler),
+	}
+	locked, err := s.recordOfflineSessionFailedAttempt(context.Background(), connector.Identity{UserID: "x"}, "ldap")
+	if err != nil {
+		t.Fatal(err)
+	}
+	if locked {
+		t.Fatal("expected lockedNow=false when policy is nil")
+	}
+	if _, err := stor.GetOfflineSessions(context.Background(), "x", "ldap"); err != storage.ErrNotFound {
+		t.Fatalf("expected ErrNotFound, got %v", err)
+	}
+}
+
+func TestRecordOfflineSessionFailedAttempt_PreservesEmailIfAlreadySet(t *testing.T) {
+	s, stor := newLockoutTestServer(t, 5, time.Minute, "ldap")
+	ctx := context.Background()
+
+	if err := stor.CreateOfflineSessions(ctx, storage.OfflineSessions{
+		UserID:  "user5",
+		ConnID:  "ldap",
+		Email:   "original@example.org",
+		Refresh: map[string]*storage.RefreshTokenRef{},
+	}); err != nil {
+		t.Fatal(err)
+	}
+
+	if _, err := s.recordOfflineSessionFailedAttempt(ctx, connector.Identity{UserID: "user5", Email: "different@example.org"}, "ldap"); err != nil {
+		t.Fatal(err)
+	}
+
+	got, _ := stor.GetOfflineSessions(ctx, "user5", "ldap")
+	if got.Email != "original@example.org" {
+		t.Fatalf("Email got overwritten: %q", got.Email)
+	}
+}
