diff --git a/server/ratelimit.go b/server/ratelimit.go
new file mode 100644
index 00000000..8747adf0
--- /dev/null
+++ b/server/ratelimit.go
@@ -0,0 +1,288 @@
+package server
+
+import (
+	"net/http"
+	"strconv"
+	"strings"
+	"sync"
+	"time"
+)
+
+// IPRateLimiter is an in-memory token-bucket rate limiter keyed by client IP.
+//
+// It is intended for protecting brute-force-prone endpoints (password login
+// form, token endpoint). The Middleware applies the limit only to failed
+// authentication responses (HTTP 4xx/5xx): tokens reserved before invoking
+// the wrapped handler are released back to the bucket on success (2xx/3xx),
+// so legitimate traffic does not consume the per-IP budget. Buckets are
+// evicted after a TTL of inactivity to keep memory bounded in the face of
+// botnet-scale unique IPs.
+//
+// In HA setups (multiple Dex replicas) each instance maintains its own
+// counters. The effective per-IP rate is therefore N times higher, where
+// N is the replica count. This is acceptable for a brute-force backstop
+// when paired with account-level lockout; for stricter guarantees use an
+// edge rate limiter (ingress) or a shared store (out of scope here).
+type IPRateLimiter struct {
+	ratePerSec float64
+	burst      float64
+	ttl        time.Duration
+
+	mu       sync.Mutex
+	limiters map[string]*ipBucket
+
+	stopOnce sync.Once
+	stopCh   chan struct{}
+}
+
+// ipBucket holds a per-IP token-bucket state. tokens is a fractional balance
+// in [0, burst]; lastRefill is the wall-clock instant the bucket was last
+// updated. Access must be guarded by IPRateLimiter.mu.
+type ipBucket struct {
+	tokens     float64
+	lastRefill time.Time
+	lastSeen   time.Time
+}
+
+// NewIPRateLimiter constructs a per-IP rate limiter.
+//
+// requestsPerMinute is the sustainable rate of failed authentication
+// responses tolerated per IP. burst is the bucket capacity (allowed burst
+// of failures before throttling). ttl is how long to retain an inactive
+// bucket before evicting it. Non-positive values are replaced with safe
+// defaults.
+func NewIPRateLimiter(requestsPerMinute, burst int, ttl time.Duration) *IPRateLimiter {
+	if requestsPerMinute <= 0 {
+		requestsPerMinute = 10
+	}
+	if burst <= 0 {
+		burst = 10
+	}
+	if ttl <= 0 {
+		ttl = 10 * time.Minute
+	}
+	rl := &IPRateLimiter{
+		ratePerSec: float64(requestsPerMinute) / 60.0,
+		burst:      float64(burst),
+		ttl:        ttl,
+		limiters:   make(map[string]*ipBucket),
+		stopCh:     make(chan struct{}),
+	}
+	go rl.janitor()
+	return rl
+}
+
+// Stop terminates the eviction janitor. Safe to call multiple times.
+func (rl *IPRateLimiter) Stop() {
+	rl.stopOnce.Do(func() { close(rl.stopCh) })
+}
+
+// refillLocked brings the bucket's token balance up to the given instant.
+// rl.mu must be held by the caller.
+func (rl *IPRateLimiter) refillLocked(b *ipBucket, now time.Time) {
+	if elapsed := now.Sub(b.lastRefill).Seconds(); elapsed > 0 {
+		b.tokens += elapsed * rl.ratePerSec
+		if b.tokens > rl.burst {
+			b.tokens = rl.burst
+		}
+		b.lastRefill = now
+	}
+}
+
+// getOrCreateLocked returns the bucket for ip, creating a freshly filled one
+// on first contact. rl.mu must be held by the caller.
+func (rl *IPRateLimiter) getOrCreateLocked(ip string, now time.Time) *ipBucket {
+	b, ok := rl.limiters[ip]
+	if !ok {
+		b = &ipBucket{tokens: rl.burst, lastRefill: now}
+		rl.limiters[ip] = b
+	}
+	b.lastSeen = now
+	return b
+}
+
+// Allow consumes a single token from the IP's bucket and reports whether
+// one was available. It is exposed primarily for tests and diagnostics; the
+// HTTP middleware uses reserve()/releaseReservation() to enforce a
+// failure-only policy.
+func (rl *IPRateLimiter) Allow(ip string) bool {
+	if ip == "" {
+		ip = "unknown"
+	}
+	rl.mu.Lock()
+	defer rl.mu.Unlock()
+
+	now := time.Now()
+	b := rl.getOrCreateLocked(ip, now)
+	rl.refillLocked(b, now)
+
+	if b.tokens >= 1.0 {
+		b.tokens -= 1.0
+		return true
+	}
+	return false
+}
+
+// reserve attempts to take a token from the bucket of the given IP.
+//
+// On success ok is true and the caller may later return the token to the
+// bucket via releaseReservation(ip) (used to refund successful HTTP
+// responses). On rejection ok is false and retry is the time until enough
+// tokens accumulate for one more request.
+//
+// An empty IP is mapped to a single shared bucket - this is safer than
+// letting unkeyed traffic bypass the limiter.
+func (rl *IPRateLimiter) reserve(ip string) (retry time.Duration, ok bool) {
+	if ip == "" {
+		ip = "unknown"
+	}
+	rl.mu.Lock()
+	defer rl.mu.Unlock()
+
+	now := time.Now()
+	b := rl.getOrCreateLocked(ip, now)
+	rl.refillLocked(b, now)
+
+	if b.tokens >= 1.0 {
+		b.tokens -= 1.0
+		return 0, true
+	}
+	if rl.ratePerSec <= 0 {
+		return time.Hour, false
+	}
+	deficit := 1.0 - b.tokens
+	wait := time.Duration(deficit / rl.ratePerSec * float64(time.Second))
+	return wait, false
+}
+
+// releaseReservation returns one token to the IP's bucket. It is the
+// counterpart to a successful reserve() call. It is safe to call when the
+// bucket has since been evicted - the operation is then a no-op.
+func (rl *IPRateLimiter) releaseReservation(ip string) {
+	if ip == "" {
+		ip = "unknown"
+	}
+	rl.mu.Lock()
+	defer rl.mu.Unlock()
+
+	b, ok := rl.limiters[ip]
+	if !ok {
+		return
+	}
+	now := time.Now()
+	rl.refillLocked(b, now)
+	b.tokens += 1.0
+	if b.tokens > rl.burst {
+		b.tokens = rl.burst
+	}
+	b.lastSeen = now
+}
+
+// statusRecorder captures the HTTP status code written by a downstream
+// handler so the rate-limit middleware can decide whether to charge or
+// release a previously reserved token.
+type statusRecorder struct {
+	http.ResponseWriter
+	status int
+}
+
+// WriteHeader records the response status before delegating to the wrapped
+// ResponseWriter. The first call wins; subsequent calls are forwarded as-is.
+func (sr *statusRecorder) WriteHeader(code int) {
+	if sr.status == 0 {
+		sr.status = code
+	}
+	sr.ResponseWriter.WriteHeader(code)
+}
+
+// Write ensures we record a default 200 status if the handler writes the
+// body without an explicit WriteHeader call (matching net/http semantics).
+func (sr *statusRecorder) Write(b []byte) (int, error) {
+	if sr.status == 0 {
+		sr.status = http.StatusOK
+	}
+	return sr.ResponseWriter.Write(b)
+}
+
+// Middleware enforces a per-IP rate limit on failed authentication responses
+// produced by the wrapped handler. Tokens are reserved before invoking the
+// handler and released back to the bucket if the response status is < 400,
+// so successful logins, successful token issuance and other 2xx/3xx flows
+// never consume the per-IP budget.
+//
+// Over-limit requests receive HTTP 429 and a Retry-After header without
+// reaching the wrapped handler.
+func (rl *IPRateLimiter) Middleware(next http.Handler) http.Handler {
+	return http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
+		ip := remoteIPFromRequest(r)
+
+		retry, allowed := rl.reserve(ip)
+		if !allowed {
+			if retry < time.Second {
+				retry = time.Second
+			}
+			w.Header().Set("Retry-After", strconv.Itoa(int(retry.Seconds())))
+			http.Error(w, "Too many requests", http.StatusTooManyRequests)
+			return
+		}
+
+		sr := &statusRecorder{ResponseWriter: w}
+		next.ServeHTTP(sr, r)
+
+		// 2xx/3xx - successful or in-flight auth flow (e.g. redirect to
+		// approval page); refund the reserved token so legitimate users
+		// do not exhaust their IP budget over time.
+		if sr.status == 0 || sr.status < 400 {
+			rl.releaseReservation(ip)
+		}
+	})
+}
+
+// remoteIPFromRequest prefers the IP that the request-context carries (set
+// by handlerWithHeaders from the configured RealIPHeader and trusted
+// proxies). It falls back to r.RemoteAddr with the port stripped.
+func remoteIPFromRequest(r *http.Request) string {
+	if v := r.Context().Value(RequestKeyRemoteIP); v != nil {
+		if s, ok := v.(string); ok && s != "" {
+			return s
+		}
+	}
+	addr := r.RemoteAddr
+	if addr == "" {
+		return ""
+	}
+	if i := strings.LastIndex(addr, ":"); i >= 0 {
+		host := addr[:i]
+		host = strings.TrimPrefix(host, "[")
+		host = strings.TrimSuffix(host, "]")
+		return host
+	}
+	return addr
+}
+
+func (rl *IPRateLimiter) janitor() {
+	interval := rl.ttl / 2
+	if interval <= 0 {
+		interval = time.Minute
+	}
+	ticker := time.NewTicker(interval)
+	defer ticker.Stop()
+	for {
+		select {
+		case <-rl.stopCh:
+			return
+		case <-ticker.C:
+			rl.evictStale(time.Now())
+		}
+	}
+}
+
+func (rl *IPRateLimiter) evictStale(now time.Time) {
+	rl.mu.Lock()
+	defer rl.mu.Unlock()
+	for ip, b := range rl.limiters {
+		if now.Sub(b.lastSeen) > rl.ttl {
+			delete(rl.limiters, ip)
+		}
+	}
+}
diff --git a/server/ratelimit_test.go b/server/ratelimit_test.go
new file mode 100644
index 00000000..d4470887
--- /dev/null
+++ b/server/ratelimit_test.go
@@ -0,0 +1,285 @@
+package server
+
+import (
+	"net/http"
+	"net/http/httptest"
+	"strconv"
+	"sync"
+	"sync/atomic"
+	"testing"
+	"time"
+)
+
+func TestIPRateLimiter_BurstThenDeny(t *testing.T) {
+	rl := NewIPRateLimiter(60, 3, time.Minute)
+	defer rl.Stop()
+
+	// Burst of 3 must succeed, the 4th must be denied.
+	for i := 0; i < 3; i++ {
+		if !rl.Allow("1.2.3.4") {
+			t.Fatalf("call %d: expected Allow=true", i)
+		}
+	}
+	if rl.Allow("1.2.3.4") {
+		t.Fatal("expected 4th call to be denied")
+	}
+}
+
+func TestIPRateLimiter_PerIPIsolation(t *testing.T) {
+	rl := NewIPRateLimiter(60, 1, time.Minute)
+	defer rl.Stop()
+
+	if !rl.Allow("1.1.1.1") {
+		t.Fatal("first call from 1.1.1.1 should be allowed")
+	}
+	if !rl.Allow("2.2.2.2") {
+		t.Fatal("first call from 2.2.2.2 should be allowed independently")
+	}
+	if rl.Allow("1.1.1.1") {
+		t.Fatal("second call from 1.1.1.1 should be denied")
+	}
+}
+
+func TestIPRateLimiter_Refill(t *testing.T) {
+	// 600 rpm = 10 rps -> ~100ms per token.
+	rl := NewIPRateLimiter(600, 1, time.Minute)
+	defer rl.Stop()
+
+	if !rl.Allow("9.9.9.9") {
+		t.Fatal("first call should be allowed")
+	}
+	if rl.Allow("9.9.9.9") {
+		t.Fatal("immediate second call should be denied")
+	}
+	time.Sleep(150 * time.Millisecond)
+	if !rl.Allow("9.9.9.9") {
+		t.Fatal("call after refill window should be allowed")
+	}
+}
+
+func TestIPRateLimiter_Eviction(t *testing.T) {
+	rl := NewIPRateLimiter(60, 5, 50*time.Millisecond)
+	defer rl.Stop()
+
+	rl.Allow("evict-me")
+
+	rl.mu.Lock()
+	_, present := rl.limiters["evict-me"]
+	rl.mu.Unlock()
+	if !present {
+		t.Fatal("expected bucket to be present right after Allow")
+	}
+
+	// Wait long enough for the janitor (interval = ttl/2) to run at least once
+	// and for the bucket's lastSeen to exceed ttl.
+	time.Sleep(200 * time.Millisecond)
+
+	rl.mu.Lock()
+	_, present = rl.limiters["evict-me"]
+	rl.mu.Unlock()
+	if present {
+		t.Fatal("expected stale bucket to be evicted")
+	}
+}
+
+func TestIPRateLimiter_StopIsIdempotent(t *testing.T) {
+	rl := NewIPRateLimiter(60, 1, time.Minute)
+	rl.Stop()
+	rl.Stop()
+}
+
+// TestIPRateLimiter_MiddlewareSuccessNeverExhausts ensures that 2xx/3xx
+// responses do NOT consume tokens - even an unbounded number of successful
+// requests must keep flowing through the middleware unhindered.
+func TestIPRateLimiter_MiddlewareSuccessNeverExhausts(t *testing.T) {
+	rl := NewIPRateLimiter(60, 2, time.Minute)
+	defer rl.Stop()
+
+	var served int32
+	h := rl.Middleware(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
+		atomic.AddInt32(&served, 1)
+		w.WriteHeader(http.StatusOK)
+	}))
+
+	for i := 0; i < 50; i++ {
+		r := httptest.NewRequest(http.MethodPost, "/token", nil)
+		r.RemoteAddr = "10.0.0.1:55555"
+		w := httptest.NewRecorder()
+		h.ServeHTTP(w, r)
+		if w.Code != http.StatusOK {
+			t.Fatalf("successful call %d: got %d, want 200 (success must not exhaust the bucket)", i, w.Code)
+		}
+	}
+	if got := atomic.LoadInt32(&served); got != 50 {
+		t.Fatalf("downstream handler hit %d times, want 50", got)
+	}
+}
+
+// TestIPRateLimiter_MiddlewareFailureBudgetReturns429 ensures that only
+// failure responses (>= 400) charge tokens, and once the burst is exhausted
+// the next failure is rejected before reaching the handler with HTTP 429
+// and Retry-After set.
+func TestIPRateLimiter_MiddlewareFailureBudgetReturns429(t *testing.T) {
+	rl := NewIPRateLimiter(60, 2, time.Minute)
+	defer rl.Stop()
+
+	var served int32
+	h := rl.Middleware(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
+		atomic.AddInt32(&served, 1)
+		w.WriteHeader(http.StatusUnauthorized)
+	}))
+
+	doCall := func() *httptest.ResponseRecorder {
+		r := httptest.NewRequest(http.MethodPost, "/auth/local/login", nil)
+		r.RemoteAddr = "10.0.0.2:55555"
+		w := httptest.NewRecorder()
+		h.ServeHTTP(w, r)
+		return w
+	}
+
+	// burst=2: first two failures pass through and consume tokens.
+	for i := 0; i < 2; i++ {
+		if got := doCall().Code; got != http.StatusUnauthorized {
+			t.Fatalf("failure call %d: got %d, want 401", i, got)
+		}
+	}
+
+	// Third failure is rejected by the middleware before reaching the handler.
+	w := doCall()
+	if w.Code != http.StatusTooManyRequests {
+		t.Fatalf("3rd call: got %d, want 429", w.Code)
+	}
+	if w.Header().Get("Retry-After") == "" {
+		t.Fatal("expected Retry-After header on 429")
+	}
+	if n, err := strconv.Atoi(w.Header().Get("Retry-After")); err != nil || n < 1 {
+		t.Fatalf("Retry-After = %q, want integer >= 1", w.Header().Get("Retry-After"))
+	}
+	if got := atomic.LoadInt32(&served); got != 2 {
+		t.Fatalf("downstream handler hit %d times, want 2 (third call must be short-circuited)", got)
+	}
+}
+
+// TestIPRateLimiter_MiddlewareSuccessRefundsToken proves that a successful
+// response in between failures returns its reserved token to the bucket: a
+// success interleaved with failures lets the IP perform more total failures
+// than the static burst size allows.
+//
+// Note: the middleware short-circuits with 429 *before* the handler runs
+// when the bucket is empty, so a 200 cannot rescue an already-depleted
+// bucket. The interleaving below tests refund while the bucket still has
+// capacity, which is the realistic case.
+func TestIPRateLimiter_MiddlewareSuccessRefundsToken(t *testing.T) {
+	rl := NewIPRateLimiter(60, 2, time.Minute)
+	defer rl.Stop()
+
+	var status atomic.Int32
+
+	h := rl.Middleware(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
+		w.WriteHeader(int(status.Load()))
+	}))
+
+	doCall := func() int {
+		r := httptest.NewRequest(http.MethodPost, "/auth/local/login", nil)
+		r.RemoteAddr = "10.0.0.3:55555"
+		w := httptest.NewRecorder()
+		h.ServeHTTP(w, r)
+		return w.Code
+	}
+
+	// burst=2 -> bucket starts at 2 tokens. We issue 5 successes first:
+	// without refund those alone would exhaust the bucket (only 2 tokens
+	// available), but with refund the bucket stays full. We then prove
+	// it stayed full by running 2 failures (consuming the full burst)
+	// followed by a third failure that must hit 429.
+	status.Store(http.StatusOK)
+	for i := 0; i < 5; i++ {
+		if got := doCall(); got != http.StatusOK {
+			t.Fatalf("success %d: got %d, want 200 (success must not consume the bucket)", i, got)
+		}
+	}
+
+	status.Store(http.StatusUnauthorized)
+	for i := 0; i < 2; i++ {
+		if got := doCall(); got != http.StatusUnauthorized {
+			t.Fatalf("failure %d after refunded successes: got %d, want 401", i, got)
+		}
+	}
+	if got := doCall(); got != http.StatusTooManyRequests {
+		t.Fatalf("post-exhaustion: got %d, want 429", got)
+	}
+}
+
+func TestIPRateLimiter_MiddlewareUsesContextIP(t *testing.T) {
+	rl := NewIPRateLimiter(60, 1, time.Minute)
+	defer rl.Stop()
+
+	// Use a failing handler so the rate-limit budget is actually consumed -
+	// the middleware refunds tokens for 2xx/3xx responses.
+	h := rl.Middleware(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
+		w.WriteHeader(http.StatusUnauthorized)
+	}))
+
+	// Two requests from different RemoteAddr but the same context IP must
+	// share a bucket - this is the X-Real-IP path.
+	makeReq := func(remote, ctxIP string) *http.Request {
+		r := httptest.NewRequest(http.MethodPost, "/token", nil)
+		r.RemoteAddr = remote
+		r = r.WithContext(WithRemoteIP(r.Context(), ctxIP))
+		return r
+	}
+
+	w1 := httptest.NewRecorder()
+	h.ServeHTTP(w1, makeReq("1.1.1.1:1", "203.0.113.7"))
+	if w1.Code != http.StatusUnauthorized {
+		t.Fatalf("first call: got %d, want 401", w1.Code)
+	}
+
+	w2 := httptest.NewRecorder()
+	h.ServeHTTP(w2, makeReq("2.2.2.2:2", "203.0.113.7"))
+	if w2.Code != http.StatusTooManyRequests {
+		t.Fatalf("second call from same context IP: got %d, want 429", w2.Code)
+	}
+}
+
+func TestIPRateLimiter_NilMiddlewareDisabledInServer(t *testing.T) {
+	// When Server.rateLimiter is nil the wrapper in newServer returns the
+	// handler unchanged. Reproduce that contract here so we don't accidentally
+	// break it.
+	var called bool
+	var s *Server
+	wrap := func(h http.HandlerFunc) http.HandlerFunc {
+		if s == nil || s.rateLimiter == nil {
+			return h
+		}
+		return s.rateLimiter.Middleware(h).ServeHTTP
+	}
+	wrapped := wrap(func(w http.ResponseWriter, r *http.Request) { called = true })
+	w := httptest.NewRecorder()
+	wrapped(w, httptest.NewRequest(http.MethodGet, "/", nil))
+	if !called {
+		t.Fatal("expected handler to run when rate limiter is nil")
+	}
+}
+
+func TestIPRateLimiter_Concurrent(t *testing.T) {
+	rl := NewIPRateLimiter(6000, 50, time.Minute)
+	defer rl.Stop()
+
+	var wg sync.WaitGroup
+	var allowed int64
+	for i := 0; i < 100; i++ {
+		wg.Add(1)
+		go func() {
+			defer wg.Done()
+			if rl.Allow("burst") {
+				atomic.AddInt64(&allowed, 1)
+			}
+		}()
+	}
+	wg.Wait()
+
+	if got := atomic.LoadInt64(&allowed); got < 50 || got > 100 {
+		t.Fatalf("allowed=%d, want between 50 (burst) and 100 (total)", got)
+	}
+}
