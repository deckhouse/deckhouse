+// recordOfflineSessionFailedAttempt increments the failed-attempt counter on
+// the OfflineSessions object for (identity.UserID, connID) and applies a
+// lockout when the configured threshold is reached.
+//
+// It returns lockedNow=true when this attempt caused the account to enter the
+// locked state, so the caller can render an HTTP 429 immediately.
+//
+// When no OfflineSessions object exists yet (the user has never logged in
+// successfully) a stub is created with the counter set to 1. This keeps the
+// counter monotonic across the very first failed attempt for fresh users.
+func (s *Server) recordOfflineSessionFailedAttempt(ctx context.Context, identity connector.Identity, connID string) (lockedNow bool, err error) {
+	if s.passwordPolicy == nil {
+		return false, nil
+	}
+	lockDuration := s.passwordPolicy.LockDuration()
+
+	current, getErr := s.storage.GetOfflineSessions(ctx, identity.UserID, connID)
+	if errors.Is(getErr, storage.ErrNotFound) {
+		stub := storage.OfflineSessions{
+			UserID:                         identity.UserID,
+			ConnID:                         connID,
+			Email:                          identity.Email,
+			Refresh:                        make(map[string]*storage.RefreshTokenRef),
+			IncorrectPasswordLoginAttempts: 1,
+		}
+		// First failed attempt for a never-logged-in user; lock immediately
+		// only if the threshold is 1 (treat the threshold as inclusive).
+		if s.passwordPolicy.IsMaxLoginAttemptsExeeded(1) {
+			until := time.Now().Add(lockDuration)
+			stub.LockedUntil = &until
+			stub.IncorrectPasswordLoginAttempts = 0
+			lockedNow = true
+		}
+		if cErr := s.storage.CreateOfflineSessions(ctx, stub); cErr != nil {
+			return false, cErr
+		}
+		return lockedNow, nil
+	}
+	if getErr != nil {
+		return false, getErr
+	}
+
+	nextAttempts := current.IncorrectPasswordLoginAttempts + 1
+	willLock := s.passwordPolicy.IsMaxLoginAttemptsExeeded(nextAttempts)
+
+	updater := func(o storage.OfflineSessions) (storage.OfflineSessions, error) {
+		if o.Email == "" && identity.Email != "" {
+			o.Email = identity.Email
+		}
+		if willLock {
+			until := time.Now().Add(lockDuration)
+			o.LockedUntil = &until
+			o.IncorrectPasswordLoginAttempts = 0
+		} else {
+			o.IncorrectPasswordLoginAttempts = nextAttempts
+		}
+		return o, nil
+	}
+	if uErr := s.storage.UpdateOfflineSessions(ctx, identity.UserID, connID, updater); uErr != nil {
+		return false, uErr
+	}
+	return willLock, nil
+}
