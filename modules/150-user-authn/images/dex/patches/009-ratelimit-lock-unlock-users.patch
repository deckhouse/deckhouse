+// RateLimit configures the per-IP rate limiter that protects brute-force-prone
+// endpoints (POST /auth/{connector}/login and /token).
+//
+// Limits are enforced in-memory per Dex replica. In HA setups the effective
+// per-IP rate is multiplied by the replica count; this is acceptable as a
+// brute-force backstop when paired with account-level lockout.
+type RateLimit struct {
+	// Enabled toggles enforcement. When false the limiter is not constructed
+	// and the routing surface matches upstream Dex.
+	Enabled bool `json:"enabled"`
+
+	// PerIP is the per-source-IP token-bucket configuration. The IP is taken
+	// from the configured web.clientRemoteIP header (when set and the
+	// request comes from a trusted proxy) and otherwise from RemoteAddr.
+	PerIP RateLimitPerIP `json:"perIP"`
+}
+
+// RateLimitPerIP configures the per-IP token bucket.
+type RateLimitPerIP struct {
+	// RequestsPerMinute is the sustainable steady-state rate per IP.
+	// A non-positive value falls back to a safe default in the server.
+	RequestsPerMinute int `json:"requestsPerMinute"`
+
+	// Burst is the maximum bucket size, i.e. how many requests an IP may
+	// make in a short burst before being throttled. A non-positive value
+	// falls back to a safe default in the server.
+	Burst int `json:"burst"`
+}
