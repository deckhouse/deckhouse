+// levelString maps a Level to the string used in the JSON "level" field for
+// the standard log stream. Auth and request streams use their own constant
+// labels ("auth" / "request").
+func levelString(lvl Level) string {
+	if lvl == ERROR {
+		return "error"
+	}
+	return "info"
+}
+
+// writeJSON marshals v as a single JSON line (trailing newline) to w. The
+// caller must hold l.mu. A marshal failure never drops the line silently —
+// we emit a minimal object describing the failure instead.
+func (l *Logger) writeJSON(w io.Writer, v interface{}) {
+	b, err := json.Marshal(v)
+	if err != nil {
+		b = []byte(fmt.Sprintf(`{"level":"error","msg":"log marshal failed: %v"}`, err))
+	}
+	b = append(b, '\n')
+	if _, err := w.Write(b); err != nil {
+		panic(err)
+	}
+}
