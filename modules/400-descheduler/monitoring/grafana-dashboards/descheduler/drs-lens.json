        "y": 9
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$ds_prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "bottomk(10, descheduler:workload_happiness_score{namespace=~\"$namespace\"})",
          "instant": true,
          "legendFormat": "{{namespace}}/{{workload_kind}}/{{workload_name}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
          "unit": "short",
          "min": 0,
