        "y": 5
      },
      "datasource": {
        "type": "prometheus",
        "uid": "$ds_prometheus"
      },
      "targets": [
        {
          "refId": "A",
          "expr": "rate(descheduler_loop_duration_seconds_sum{job=\"descheduler\"}[$__rate_interval]) / rate(descheduler_loop_duration_seconds_count{job=\"descheduler\"}[$__rate_interval])",
          "instant": true
        }
      ],
      "fieldConfig": {
        "defaults": {
