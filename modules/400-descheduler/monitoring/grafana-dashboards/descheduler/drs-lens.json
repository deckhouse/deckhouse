        },
        {
          "refId": "B",
          "expr": "descheduler:cluster_imbalance_stddev{resource=\"memory\"}",
          "legendFormat": "{{resource}}"
        },
        {
          "refId": "C",
          "expr": "descheduler:cluster_imbalance_stddev{resource=\"pods\"}",
          "legendFormat": "{{resource}}"
        }
      ],
      "fieldConfig": {
        "defaults": {
