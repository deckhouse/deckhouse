              "Value #B": "cpu req",
              "Value #C": "mem use",
              "Value #D": "mem req",
              "Value #E": "pods",
              "Value #F": "unhappy wl",
              "Value #G": "evictions",
              "Value #H": "failed",
              "Value #I": "pressure conds"
