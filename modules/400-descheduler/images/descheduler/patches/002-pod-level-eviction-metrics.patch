+
+package evictions
+
+import (
+	v1 "k8s.io/api/core/v1"
+	apierrors "k8s.io/apimachinery/pkg/api/errors"
+	metav1 "k8s.io/apimachinery/pkg/apis/meta/v1"
+	appsv1listers "k8s.io/client-go/listers/apps/v1"
+
+	"sigs.k8s.io/descheduler/metrics"
+)
+
+// workloadNone is the workload kind/name reported for pods that have no
+// controlling owner (bare pods). A constant placeholder is used instead of the
+// pod name to keep the metric label cardinality bounded.
+const workloadNone = "<none>"
+
+// resolveWorkload returns the stable owning workload (kind, name) for a pod.
+//
+// The pod's controller ownerRef is used directly for workloads that own pods
+// themselves (StatefulSet, DaemonSet, Job, custom controllers). For a pod owned
+// by a ReplicaSet the chain is followed one more hop (ReplicaSet to Deployment)
+// using the cached ReplicaSet lister, because a ReplicaSet name changes on every
+// rollout and is therefore not a stable identity. If the ReplicaSet cannot be
+// resolved (cache miss or orphan ReplicaSet) the ReplicaSet itself is reported.
+// Bare pods (no controller) resolve to workloadNone to avoid unbounded
+// cardinality from per-pod names.
+func resolveWorkload(pod *v1.Pod, rsLister appsv1listers.ReplicaSetLister) (string, string) {
+	ref := metav1.GetControllerOf(pod)
+	if ref == nil {
+		return workloadNone, workloadNone
+	}
+
+	if ref.Kind == "ReplicaSet" && rsLister != nil {
+		rs, err := rsLister.ReplicaSets(pod.Namespace).Get(ref.Name)
+		if err == nil {
+			if owner := metav1.GetControllerOf(rs); owner != nil {
+				return owner.Kind, owner.Name
+			}
+		}
+	}
+
+	return ref.Kind, ref.Name
+}
+
+// observePodEviction records a single pod-level eviction attempt against the
+// workload-scoped descheduler_pod_evictions_total metric.
+func observePodEviction(pod *v1.Pod, opts EvictOptions, workloadKind, workloadName, result, reason string) {
+	metrics.PodEvictionsTotal.With(map[string]string{
+		"namespace":     pod.Namespace,
+		"workload_kind": workloadKind,
+		"workload_name": workloadName,
+		"node":          pod.Spec.NodeName,
+		"strategy":      opts.StrategyName,
+		"profile":       opts.ProfileName,
+		"result":        result,
+		"reason":        reason,
+	}).Inc()
+}
+
+// evictionErrorReason maps an eviction error to a bounded reason label value so
+// that the metric never carries arbitrary error text.
+func evictionErrorReason(err error) string {
+	switch {
+	case apierrors.IsTooManyRequests(err):
+		return "too_many_requests"
+	case apierrors.IsNotFound(err):
+		return "not_found"
+	default:
+		return "api_error"
+	}
+}
