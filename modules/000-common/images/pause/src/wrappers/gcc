#!/bin/sh

# Current wrapper
SELF="$(readlink -f "$0")"

# Name of compiler
NAME=$(basename "$0")

# Are looking for the real compiler name, skipping ourselves
REAL=""
for p in $(echo "$PATH" | tr ':' ' '); do
    CAND="$p/${NAME}"
    if [ -x "$CAND" ]; then
        CAND_REAL="$(readlink -f "$CAND")"
        if [ "$CAND_REAL" != "$SELF" ]; then
            REAL="$CAND_REAL"
            break
        fi
    fi
done

if [ -z "$REAL" ]; then
    echo "${NAME} wrapper: real ${NAME} not found" >&2
    exit 1
fi

# Log tag: C vs C++ toolchain (same script for gcc and g++ via symlink)
case "$NAME" in
    g++|c++|*-g++)
        LOG_TAG="[CXX]"
        ;;
    *)
        LOG_TAG="[CC]"
        ;;
esac

# Environment that affects compilation (Make/autotools/pkg-config consumers)
for _var in CC CXX CFLAGS CXXFLAGS CPPFLAGS LDFLAGS; do
    eval "_set=\${${_var}+x}"
    if [ -n "$_set" ]; then
        eval "_val=\$$_var"
        echo "${LOG_TAG} ${_var}=${_val}" >&2
    fi
done

# Command line after env (flags may also appear only here)
echo "${LOG_TAG} ${NAME} $*" >&2

# Transfer control
exec "$REAL" "$@"
