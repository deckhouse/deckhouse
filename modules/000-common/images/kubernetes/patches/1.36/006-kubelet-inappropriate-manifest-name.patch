+// manifestAllowedExtensions lists filename extensions that are allowed as pod manifests.
+// Only files with these extensions are processed (e.g. kube-apiserver.backup is ignored).
+var manifestAllowedExtensions = []string{".yaml", ".yml"}
+
+// shouldIgnoreManifestFile returns true if the manifest file should be ignored
+// (hidden files or files without an allowed extension).
+func shouldIgnoreManifestFile(baseName string) bool {
+	if strings.HasPrefix(baseName, ".") {
+		return true
+	}
+	for _, ext := range manifestAllowedExtensions {
+		if strings.HasSuffix(strings.ToLower(baseName), ext) {
+			return false
+		}
+	}
+	return true
+}
