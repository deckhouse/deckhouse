+func TestDynamicTransformersRegisterSensitiveResource(t *testing.T) {
+	secretsGR := schema.GroupResource{Group: "", Resource: "secrets"}
+	crdGR := schema.GroupResource{Group: "example.com", Resource: "databases"}
+
+	secretsTransformer := value.PrefixTransformer{Prefix: []byte("k8s:enc:test:"), Transformer: &identityTransformer{}}
+	overrides := map[schema.GroupResource]value.Transformer{
+		secretsGR: value.NewPrefixTransformers(nil, secretsTransformer),
+	}
+
+	dt := NewDynamicTransformers(overrides, nil, func() {}, 0)
+
+	t.Run("unregistered sensitive resource falls through to identity", func(t *testing.T) {
+		transformer := dt.TransformerForResource(crdGR)
+		out, err := transformer.TransformToStorage(context.Background(), []byte("data"), value.DefaultContext(nil))
+		if err != nil {
+			t.Fatal(err)
+		}
+		if !bytes.Equal(out, []byte("data")) {
+			t.Errorf("expected identity (no-op) transformer, got output %q", string(out))
+		}
+	})
+
+	t.Run("registered sensitive resource uses secrets transformer", func(t *testing.T) {
+		dt.RegisterSensitiveResource(crdGR)
+
+		transformer := dt.TransformerForResource(crdGR)
+		out, err := transformer.TransformToStorage(context.Background(), []byte("data"), value.DefaultContext(nil))
+		if err != nil {
+			t.Fatal(err)
+		}
+		if !bytes.HasPrefix(out, []byte("k8s:enc:test:")) {
+			t.Errorf("expected secrets transformer prefix, got output %q", string(out))
+		}
+	})
+
+	t.Run("unregistered sensitive resource reverts to identity", func(t *testing.T) {
+		dt.UnregisterSensitiveResource(crdGR)
+
+		transformer := dt.TransformerForResource(crdGR)
+		out, err := transformer.TransformToStorage(context.Background(), []byte("data"), value.DefaultContext(nil))
+		if err != nil {
+			t.Fatal(err)
+		}
+		if !bytes.Equal(out, []byte("data")) {
+			t.Errorf("expected identity transformer after unregister, got output %q", string(out))
+		}
+	})
+}
