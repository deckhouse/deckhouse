+package sensitive
+
+import (
+	"reflect"
+	"testing"
+
+	structuralschema "k8s.io/apiextensions-apiserver/pkg/apiserver/schema"
+)
+
+func TestHasSensitiveFields(t *testing.T) {
+	tests := []struct {
+		name     string
+		schema   *structuralschema.Structural
+		expected bool
+	}{
+		{
+			name:     "nil schema",
+			schema:   nil,
+			expected: false,
+		},
+		{
+			name:     "empty schema",
+			schema:   &structuralschema.Structural{},
+			expected: false,
+		},
+		{
+			name: "root marked sensitive",
+			schema: &structuralschema.Structural{
+				Extensions: structuralschema.Extensions{XSensitiveData: true},
+			},
+			expected: true,
+		},
+		{
+			name: "sensitive property",
+			schema: &structuralschema.Structural{
+				Properties: map[string]structuralschema.Structural{
+					"password": {Extensions: structuralschema.Extensions{XSensitiveData: true}},
+					"name":     {Generic: structuralschema.Generic{Type: "string"}},
+				},
+			},
+			expected: true,
+		},
+		{
+			name: "no sensitive properties",
+			schema: &structuralschema.Structural{
+				Properties: map[string]structuralschema.Structural{
+					"name": {Generic: structuralschema.Generic{Type: "string"}},
+				},
+			},
+			expected: false,
+		},
+		{
+			name: "sensitive in items",
+			schema: &structuralschema.Structural{
+				Items: &structuralschema.Structural{
+					Extensions: structuralschema.Extensions{XSensitiveData: true},
+				},
+			},
+			expected: true,
+		},
+		{
+			name: "sensitive in additionalProperties",
+			schema: &structuralschema.Structural{
+				AdditionalProperties: &structuralschema.StructuralOrBool{
+					Structural: &structuralschema.Structural{
+						Extensions: structuralschema.Extensions{XSensitiveData: true},
+					},
+				},
+			},
+			expected: true,
+		},
+		{
+			name: "sensitive deeply nested",
+			schema: &structuralschema.Structural{
+				Properties: map[string]structuralschema.Structural{
+					"spec": {
+						Properties: map[string]structuralschema.Structural{
+							"tls": {
+								Properties: map[string]structuralschema.Structural{
+									"key": {Extensions: structuralschema.Extensions{XSensitiveData: true}},
+								},
+							},
+						},
+					},
+				},
+			},
+			expected: true,
+		},
+		{
+			name: "sensitive in nested items properties",
+			schema: &structuralschema.Structural{
+				Properties: map[string]structuralschema.Structural{
+					"list": {
+						Items: &structuralschema.Structural{
+							Properties: map[string]structuralschema.Structural{
+								"token": {Extensions: structuralschema.Extensions{XSensitiveData: true}},
+							},
+						},
+					},
+				},
+			},
+			expected: true,
+		},
+	}
+
+	for _, tt := range tests {
+		t.Run(tt.name, func(t *testing.T) {
+			if got := HasSensitiveFields(tt.schema); got != tt.expected {
+				t.Errorf("HasSensitiveFields() = %v, want %v", got, tt.expected)
+			}
+		})
+	}
+}
+
+func TestCollectSensitivePaths(t *testing.T) {
+	tests := []struct {
+		name     string
+		schema   *structuralschema.Structural
+		expected []string
+	}{
+		{
+			name:     "nil schema",
+			schema:   nil,
+			expected: nil,
+		},
+		{
+			name:     "no sensitive fields",
+			schema:   &structuralschema.Structural{},
+			expected: nil,
+		},
+		{
+			name: "root marked sensitive",
+			schema: &structuralschema.Structural{
+				Extensions: structuralschema.Extensions{XSensitiveData: true},
+			},
+			expected: []string{"."},
+		},
+		{
+			name: "flat properties",
+			schema: &structuralschema.Structural{
+				Properties: map[string]structuralschema.Structural{
+					"password": {Extensions: structuralschema.Extensions{XSensitiveData: true}},
+					"name":     {Generic: structuralschema.Generic{Type: "string"}},
+					"token":    {Extensions: structuralschema.Extensions{XSensitiveData: true}},
+				},
+			},
+			expected: []string{".password", ".token"},
+		},
+		{
+			name: "nested properties",
+			schema: &structuralschema.Structural{
+				Properties: map[string]structuralschema.Structural{
+					"spec": {
+						Properties: map[string]structuralschema.Structural{
+							"password": {Extensions: structuralschema.Extensions{XSensitiveData: true}},
+							"tls": {
+								Properties: map[string]structuralschema.Structural{
+									"key": {Extensions: structuralschema.Extensions{XSensitiveData: true}},
+								},
+							},
+						},
+					},
+				},
+			},
+			expected: []string{".spec.password", ".spec.tls.key"},
+		},
+		{
+			name: "sensitive array items",
+			schema: &structuralschema.Structural{
+				Properties: map[string]structuralschema.Structural{
+					"secrets": {
+						Items: &structuralschema.Structural{
+							Properties: map[string]structuralschema.Structural{
+								"value": {Extensions: structuralschema.Extensions{XSensitiveData: true}},
+							},
+						},
+					},
+				},
+			},
+			expected: []string{".secrets[].value"},
+		},
+		{
+			name: "sensitive additionalProperties",
+			schema: &structuralschema.Structural{
+				Properties: map[string]structuralschema.Structural{
+					"data": {
+						AdditionalProperties: &structuralschema.StructuralOrBool{
+							Structural: &structuralschema.Structural{
+								Extensions: structuralschema.Extensions{XSensitiveData: true},
+							},
+						},
+					},
+				},
+			},
+			expected: []string{".data[*]"},
+		},
+	}
+
+	for _, tt := range tests {
+		t.Run(tt.name, func(t *testing.T) {
+			got := CollectSensitivePaths(tt.schema)
+			if !reflect.DeepEqual(got, tt.expected) {
+				t.Errorf("CollectSensitivePaths() = %v, want %v", got, tt.expected)
+			}
+		})
+	}
+}
+
+func TestStripSensitiveFields(t *testing.T) {
+	tests := []struct {
+		name           string
+		obj            interface{}
+		schema         *structuralschema.Structural
+		isResourceRoot bool
+		expected       interface{}
+	}{
+		{
+			name:     "nil object",
+			obj:      nil,
+			schema:   &structuralschema.Structural{},
+			expected: nil,
+		},
+		{
+			name:     "nil schema",
+			obj:      map[string]interface{}{"a": "b"},
+			schema:   nil,
+			expected: map[string]interface{}{"a": "b"},
+		},
+		{
+			name: "strip flat property",
+			obj: map[string]interface{}{
+				"password": "secret",
+				"name":     "public",
+			},
+			schema: &structuralschema.Structural{
+				Properties: map[string]structuralschema.Structural{
+					"password": {Extensions: structuralschema.Extensions{XSensitiveData: true}},
+					"name":     {Generic: structuralschema.Generic{Type: "string"}},
+				},
+			},
+			expected: map[string]interface{}{
+				"name": "public",
+			},
+		},
+		{
+			name: "strip nested property",
+			obj: map[string]interface{}{
+				"spec": map[string]interface{}{
+					"token":  "abc-def",
+					"normal": "value",
+				},
+			},
+			schema: &structuralschema.Structural{
+				Properties: map[string]structuralschema.Structural{
+					"spec": {
+						Properties: map[string]structuralschema.Structural{
+							"token":  {Extensions: structuralschema.Extensions{XSensitiveData: true}},
+							"normal": {Generic: structuralschema.Generic{Type: "string"}},
+						},
+					},
+				},
+			},
+			expected: map[string]interface{}{
+				"spec": map[string]interface{}{
+					"normal": "value",
+				},
+			},
+		},
+		{
+			name: "preserves meta fields at resource root",
+			obj: map[string]interface{}{
+				"apiVersion": "v1",
+				"kind":       "Foo",
+				"metadata":   map[string]interface{}{"name": "test"},
+				"password":   "secret",
+			},
+			schema: &structuralschema.Structural{
+				Properties: map[string]structuralschema.Structural{
+					"password": {Extensions: structuralschema.Extensions{XSensitiveData: true}},
+				},
+			},
+			isResourceRoot: true,
+			expected: map[string]interface{}{
+				"apiVersion": "v1",
+				"kind":       "Foo",
+				"metadata":   map[string]interface{}{"name": "test"},
+			},
+		},
+		{
+			name: "preserves meta fields in embedded resource",
+			obj: map[string]interface{}{
+				"embedded": map[string]interface{}{
+					"apiVersion": "v1",
+					"kind":       "Bar",
+					"metadata":   map[string]interface{}{"name": "inner"},
+					"secret":     "hidden",
+				},
+			},
+			schema: &structuralschema.Structural{
+				Properties: map[string]structuralschema.Structural{
+					"embedded": {
+						Extensions: structuralschema.Extensions{XEmbeddedResource: true},
+						Properties: map[string]structuralschema.Structural{
+							"secret": {Extensions: structuralschema.Extensions{XSensitiveData: true}},
+						},
+					},
+				},
+			},
+			expected: map[string]interface{}{
+				"embedded": map[string]interface{}{
+					"apiVersion": "v1",
+					"kind":       "Bar",
+					"metadata":   map[string]interface{}{"name": "inner"},
+				},
+			},
+		},
+		{
+			name: "strip additionalProperties values",
+			obj: map[string]interface{}{
+				"data": map[string]interface{}{
+					"key1": "secret1",
+					"key2": "secret2",
+				},
+			},
+			schema: &structuralschema.Structural{
+				Properties: map[string]structuralschema.Structural{
+					"data": {
+						AdditionalProperties: &structuralschema.StructuralOrBool{
+							Structural: &structuralschema.Structural{
+								Extensions: structuralschema.Extensions{XSensitiveData: true},
+							},
+						},
+					},
+				},
+			},
