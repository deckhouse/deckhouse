+func TestTransformerFromOverridesWithSensitiveResources(t *testing.T) {
+	secretsGR := schema.GroupResource{Group: "", Resource: "secrets"}
+	crdGR := schema.GroupResource{Group: "example.com", Resource: "databases"}
+	explicitGR := schema.GroupResource{Group: "example.com", Resource: "configs"}
+
+	secretsTransformer := value.PrefixTransformer{Prefix: []byte("k8s:enc:secrets:"), Transformer: &identityTransformer{}}
+	explicitTransformer := value.PrefixTransformer{Prefix: []byte("k8s:enc:explicit:"), Transformer: &identityTransformer{}}
+
+	overrides := map[schema.GroupResource]value.Transformer{
+		secretsGR:  value.NewPrefixTransformers(nil, secretsTransformer),
+		explicitGR: value.NewPrefixTransformers(nil, explicitTransformer),
+	}
+
+	sensitiveResources := &sync.Map{}
+	sensitiveResources.Store(crdGR, struct{}{})
+	sensitiveResources.Store(explicitGR, struct{}{})
+
+	t.Run("sensitive resource with no explicit override gets secrets transformer", func(t *testing.T) {
+		transformer := transformerFromOverrides(overrides, crdGR, sensitiveResources)
+		out, err := transformer.TransformToStorage(context.Background(), []byte("data"), value.DefaultContext(nil))
+		if err != nil {
+			t.Fatal(err)
+		}
+		if !bytes.HasPrefix(out, []byte("k8s:enc:secrets:")) {
+			t.Errorf("expected secrets transformer, got %q", string(out))
+		}
+	})
+
+	t.Run("explicit override takes precedence over sensitive registration", func(t *testing.T) {
+		transformer := transformerFromOverrides(overrides, explicitGR, sensitiveResources)
+		out, err := transformer.TransformToStorage(context.Background(), []byte("data"), value.DefaultContext(nil))
+		if err != nil {
+			t.Fatal(err)
+		}
+		if !bytes.HasPrefix(out, []byte("k8s:enc:explicit:")) {
+			t.Errorf("expected explicit transformer, got %q", string(out))
+		}
+	})
+
+	t.Run("non-sensitive resource without override gets identity", func(t *testing.T) {
+		otherGR := schema.GroupResource{Group: "other.io", Resource: "things"}
+		transformer := transformerFromOverrides(overrides, otherGR, sensitiveResources)
+		out, err := transformer.TransformToStorage(context.Background(), []byte("data"), value.DefaultContext(nil))
+		if err != nil {
+			t.Fatal(err)
+		}
