+func TestNewSensitiveMaskingTransformer_SingleObject(t *testing.T) {
+	schema := testSchemaWithSensitive()
+	transformer := newSensitiveMaskingTransformer(schema)
+
+	obj := &unstructured.Unstructured{
+		Object: map[string]interface{}{
+			"apiVersion": "example.com/v1",
+			"kind":       "MyCustomResource",
+			"spec": map[string]interface{}{
+				"password": "mysecret",
+				"name":     "myname",
+			},
+		},
+	}
+
+	result := transformer(obj)
+	u := result.(*unstructured.Unstructured)
+	spec := u.Object["spec"].(map[string]interface{})
+
+	if spec["password"] != sensitive.MaskedValue {
+		t.Errorf("expected password to be masked, got %v", spec["password"])
+	}
+	if spec["name"] != "myname" {
+		t.Errorf("expected name to remain unchanged, got %v", spec["name"])
+	}
