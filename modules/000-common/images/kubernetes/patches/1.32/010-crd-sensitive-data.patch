+func TestMaskSensitiveFields(t *testing.T) {
+	tests := []struct {
+		name           string
+		obj            interface{}
+		schema         *structuralschema.Structural
+		isResourceRoot bool
+		expected       interface{}
+	}{
+		{
+			name:     "nil object",
+			obj:      nil,
+			schema:   &structuralschema.Structural{},
+			expected: nil,
+		},
+		{
+			name:     "nil schema",
+			obj:      map[string]interface{}{"a": "b"},
+			schema:   nil,
+			expected: map[string]interface{}{"a": "b"},
+		},
+		{
+			name: "mask flat property",
+			obj: map[string]interface{}{
+				"password": "secret",
+				"name":     "public",
+			},
+			schema: &structuralschema.Structural{
+				Properties: map[string]structuralschema.Structural{
+					"password": {Extensions: structuralschema.Extensions{XSensitiveData: true}},
+					"name":     {Generic: structuralschema.Generic{Type: "string"}},
+				},
+			},
+			expected: map[string]interface{}{
+				"password": MaskedValue,
+				"name":     "public",
+			},
+		},
+		{
+			name: "mask nested property",
+			obj: map[string]interface{}{
+				"spec": map[string]interface{}{
+					"token":  "abc-def",
+					"normal": "value",
+				},
+			},
+			schema: &structuralschema.Structural{
+				Properties: map[string]structuralschema.Structural{
+					"spec": {
+						Properties: map[string]structuralschema.Structural{
+							"token":  {Extensions: structuralschema.Extensions{XSensitiveData: true}},
+							"normal": {Generic: structuralschema.Generic{Type: "string"}},
+						},
+					},
+				},
+			},
+			expected: map[string]interface{}{
+				"spec": map[string]interface{}{
+					"token":  MaskedValue,
+					"normal": "value",
+				},
+			},
+		},
+		{
+			name: "preserves meta fields at resource root",
+			obj: map[string]interface{}{
+				"apiVersion": "v1",
+				"kind":       "Foo",
+				"metadata":   map[string]interface{}{"name": "test"},
+				"password":   "secret",
+			},
+			schema: &structuralschema.Structural{
+				Properties: map[string]structuralschema.Structural{
+					"password": {Extensions: structuralschema.Extensions{XSensitiveData: true}},
+				},
+			},
+			isResourceRoot: true,
+			expected: map[string]interface{}{
+				"apiVersion": "v1",
+				"kind":       "Foo",
+				"metadata":   map[string]interface{}{"name": "test"},
+				"password":   MaskedValue,
+			},
+		},
+		{
+			name: "preserves meta fields in embedded resource",
+			obj: map[string]interface{}{
+				"embedded": map[string]interface{}{
+					"apiVersion": "v1",
+					"kind":       "Bar",
+					"metadata":   map[string]interface{}{"name": "inner"},
+					"secret":     "hidden",
+				},
+			},
+			schema: &structuralschema.Structural{
+				Properties: map[string]structuralschema.Structural{
+					"embedded": {
+						Extensions: structuralschema.Extensions{XEmbeddedResource: true},
+						Properties: map[string]structuralschema.Structural{
+							"secret": {Extensions: structuralschema.Extensions{XSensitiveData: true}},
+						},
+					},
+				},
+			},
+			expected: map[string]interface{}{
+				"embedded": map[string]interface{}{
+					"apiVersion": "v1",
+					"kind":       "Bar",
+					"metadata":   map[string]interface{}{"name": "inner"},
+					"secret":     MaskedValue,
+				},
+			},
+		},
+		{
+			name: "mask additionalProperties values",
+			obj: map[string]interface{}{
+				"data": map[string]interface{}{
+					"key1": "secret1",
+					"key2": "secret2",
+				},
+			},
+			schema: &structuralschema.Structural{
+				Properties: map[string]structuralschema.Structural{
+					"data": {
+						AdditionalProperties: &structuralschema.StructuralOrBool{
+							Structural: &structuralschema.Structural{
+								Extensions: structuralschema.Extensions{XSensitiveData: true},
+							},
+						},
+					},
+				},
+			},
+			expected: map[string]interface{}{
+				"data": map[string]interface{}{
+					"key1": MaskedValue,
+					"key2": MaskedValue,
+				},
+			},
+		},
+		{
+			name: "mask sensitive array items",
+			obj: map[string]interface{}{
+				"tokens": []interface{}{"token1", "token2"},
+			},
+			schema: &structuralschema.Structural{
+				Properties: map[string]structuralschema.Structural{
+					"tokens": {
+						Items: &structuralschema.Structural{
+							Extensions: structuralschema.Extensions{XSensitiveData: true},
+						},
+					},
+				},
+			},
+			expected: map[string]interface{}{
+				"tokens": []interface{}{MaskedValue, MaskedValue},
+			},
+		},
+		{
+			name: "mask sensitive fields inside array objects",
+			obj: map[string]interface{}{
+				"items": []interface{}{
+					map[string]interface{}{"name": "a", "secret": "s1"},
+					map[string]interface{}{"name": "b", "secret": "s2"},
+				},
+			},
+			schema: &structuralschema.Structural{
+				Properties: map[string]structuralschema.Structural{
+					"items": {
+						Items: &structuralschema.Structural{
+							Properties: map[string]structuralschema.Structural{
+								"name":   {Generic: structuralschema.Generic{Type: "string"}},
+								"secret": {Extensions: structuralschema.Extensions{XSensitiveData: true}},
+							},
+						},
+					},
+				},
+			},
+			expected: map[string]interface{}{
+				"items": []interface{}{
+					map[string]interface{}{"name": "a", "secret": MaskedValue},
+					map[string]interface{}{"name": "b", "secret": MaskedValue},
+				},
+			},
+		},
+		{
+			name: "deeply nested three levels",
+			obj: map[string]interface{}{
+				"level1": map[string]interface{}{
+					"level2": map[string]interface{}{
+						"level3": map[string]interface{}{
+							"secret": "deep-value",
+							"public": "visible",
+						},
+					},
+				},
+			},
+			schema: &structuralschema.Structural{
+				Properties: map[string]structuralschema.Structural{
+					"level1": {
+						Properties: map[string]structuralschema.Structural{
+							"level2": {
+								Properties: map[string]structuralschema.Structural{
+									"level3": {
+										Properties: map[string]structuralschema.Structural{
+											"secret": {Extensions: structuralschema.Extensions{XSensitiveData: true}},
+											"public": {Generic: structuralschema.Generic{Type: "string"}},
+										},
+									},
+								},
+							},
+						},
+					},
+				},
+			},
+			expected: map[string]interface{}{
+				"level1": map[string]interface{}{
+					"level2": map[string]interface{}{
+						"level3": map[string]interface{}{
+							"secret": MaskedValue,
+							"public": "visible",
+						},
+					},
+				},
+			},
+		},
+		{
+			name: "fields not in schema are left untouched",
+			obj: map[string]interface{}{
+				"password": "secret",
+				"unknown":  "value",
+			},
+			schema: &structuralschema.Structural{
+				Properties: map[string]structuralschema.Structural{
+					"password": {Extensions: structuralschema.Extensions{XSensitiveData: true}},
+				},
+			},
+			expected: map[string]interface{}{
+				"password": MaskedValue,
+				"unknown":  "value",
+			},
+		},
+		{
+			name:     "empty map with nil schema",
+			obj:      map[string]interface{}{},
+			schema:   nil,
+			expected: map[string]interface{}{},
+		},
+	}
+
+	for _, tt := range tests {
+		t.Run(tt.name, func(t *testing.T) {
+			MaskSensitiveFields(tt.obj, tt.schema, tt.isResourceRoot)
+			if !reflect.DeepEqual(tt.obj, tt.expected) {
+				t.Errorf("MaskSensitiveFields() result = %v, want %v", tt.obj, tt.expected)
+			}
+		})
+	}
+}
