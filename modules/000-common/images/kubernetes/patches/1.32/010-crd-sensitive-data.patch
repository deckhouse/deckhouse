+	})
+
+	t.Run("sensitive resource without secrets config gets identity", func(t *testing.T) {
+		emptyOverrides := map[schema.GroupResource]value.Transformer{}
+		transformer := transformerFromOverrides(emptyOverrides, crdGR, sensitiveResources)
