+		isResourceRoot bool
+		expected       interface{}
+	}{
+		{
+			name:     "nil object",
+			obj:      nil,
+			schema:   &structuralschema.Structural{},
+			expected: nil,
+		},
+		{
+			name:     "nil schema",
+			obj:      map[string]interface{}{"a": "b"},
+			schema:   nil,
+			expected: map[string]interface{}{"a": "b"},
+		},
+		{
+			name: "mask flat property",
+			obj: map[string]interface{}{
+				"password": "secret",
+				"name":     "public",
+			},
+			schema: &structuralschema.Structural{
+				Properties: map[string]structuralschema.Structural{
