+	metav1 "k8s.io/apimachinery/pkg/apis/meta/v1"
+	"k8s.io/apimachinery/pkg/runtime"
+	"k8s.io/apimachinery/pkg/watch"
+	"k8s.io/apiserver/pkg/storage"
+)
+
+// StoreAccessor is the subset of *genericregistry.Store (package
+// k8s.io/apiserver/pkg/registry/generic/registry) this package needs. It is
+// declared as a local interface -- rather than importing that package
+// directly -- specifically so that package can import THIS one (to add the
+// ScopeFilter hook to Store.List/Get/Watch) without creating an import
+// cycle. *genericregistry.Store satisfies this interface with its existing,
+// unmodified methods; no adapter is needed at call sites.
+//
+// PredicateFunc is deliberately excluded: on the real Store it is a struct
+// FIELD of function type, not a method, so it cannot appear in a Go
+// interface. Callers pass its value separately (see Decorator.BuildPredicate
+// and WatchConfig's predicate-building needs) -- construction sites already
+// have it in hand as `store.PredicateFunc`.
+type StoreAccessor interface {
+	Get(ctx context.Context, name string, options *metav1.GetOptions) (runtime.Object, error)
+	ListPredicate(ctx context.Context, p storage.SelectionPredicate, options *metainternalversion.ListOptions) (runtime.Object, error)
+	WatchPredicate(ctx context.Context, p storage.SelectionPredicate, resourceVersion string, sendInitialEvents *bool) (watch.Interface, error)
+	New() runtime.Object
+}
