+
+package scopefilter
+
+import (
+	"context"
+	"errors"
+	"time"
+
+	apierrors "k8s.io/apimachinery/pkg/api/errors"
+	metainternalversion "k8s.io/apimachinery/pkg/apis/meta/internalversion"
+	metav1 "k8s.io/apimachinery/pkg/apis/meta/v1"
+	"k8s.io/apimachinery/pkg/fields"
+	"k8s.io/apimachinery/pkg/labels"
+	"k8s.io/apimachinery/pkg/runtime"
+	"k8s.io/apimachinery/pkg/runtime/schema"
+	"k8s.io/apimachinery/pkg/watch"
+	"k8s.io/apiserver/pkg/authentication/user"
+	genericapirequest "k8s.io/apiserver/pkg/endpoints/request"
+	"k8s.io/apiserver/pkg/storage"
+	storageerr "k8s.io/apiserver/pkg/storage/errors"
+	"k8s.io/klog/v2"
+)
+
+// DefaultRefreshInterval is the polling cadence the watch path uses when a
+// Decorator's RefreshInterval is unset. One second balances responsiveness
+// to permission changes against load on the upstream permission service.
+const DefaultRefreshInterval = time.Second
+
+var (
+	errCannotList  = errors.New("cannot list resource")
+	errCannotGet   = errors.New("cannot get resource")
+	errCannotWatch = errors.New("cannot watch resource")
+	errNoUser      = errors.New("no user info in context")
+	errNoNamespace = errors.New("no namespace in context")
+)
+
+// Decorator wraps a *genericregistry.Store and adds scope filtering to its
+// List/Get/Watch methods, transparently falling back to the plain store
+// whenever filtering is not active for a given request -- a fully
+// privileged, non-triggering caller pays no extra fetcher/resolver round
+// trips at all.
+//
+// Two usage patterns:
+//
+//   - Unconditional (namespaces' own storage): Trigger always returns true,
+//     Mode is IdentityByName, Classify/RBACFloor are nil, and Accessible
+//     alone supplies the allowed set on every call. This reproduces the
+//     original, narrower namespace-only patch: there is no separate
+//     resource+verb to narrow the floor against, because Namespace listing
+//     Namespace already IS that resource+verb.
+//
+//   - Generic (any other namespaced resource, built-in or CRD): Trigger
+//     checks scopefilter.RequestFrom(ctx), Mode is IdentityByNamespace, and
+//     the RBAC floor is intersected in whenever scopefilter.IsBypass(ctx) is
+//     also true.
+type Decorator struct {
+	// Store performs the actual List/Get/Watch calls once filtering has
+	// decided what to allow. See StoreAccessor's doc for why this is a
+	// local interface rather than *genericregistry.Store directly.
+	Store StoreAccessor
+
+	// BuildPredicate is the resource's registered predicate-construction
+	// function -- on the real Store this is the `PredicateFunc` struct
+	// field, passed by value (`store.PredicateFunc`) since a struct field
+	// cannot be required by StoreAccessor. Ensures the resulting
+	// SelectionPredicate's GetAttrs matches what the resource's own
+	// storage strategy expects.
+	BuildPredicate func(label labels.Selector, field fields.Selector) storage.SelectionPredicate
+
+	// Resource identifies the resource being served, used both for
+	// building apierrors and as the (group, version, resource) narrowed
+	// against by RBACFloorResolver.
+	Resource schema.GroupVersionResource
+
+	Mode IdentityMode
+
+	// Trigger reports whether ctx should be routed through the filtering
+	// path at all.
+	Trigger func(ctx context.Context) bool
+
+	// Classify resolves the classification-selector set for the scope
+	// request tagged on ctx. Nil if this Decorator never needs
+	// classification (the unconditional-namespaces usage pattern).
+	Classify ClassificationResolver
+
+	// RBACFloor computes the RBAC safety floor. Consulted only when
+	// scopefilter.IsBypass(ctx) is true. Nil for the unconditional
+	// namespaces usage pattern (see type doc).
+	RBACFloor RBACFloorResolver
+
+	// Accessible answers the "accessible" scope kind, and is the sole
+	// source of truth for the unconditional-namespaces usage pattern.
+	// Required whenever Classify or RBACFloor is set, since both build on
+	// it (directly, or via RBACFloor's own dependency on it).
+	Accessible AccessibleNamespaceFetcher
+
+	// RefreshInterval overrides DefaultRefreshInterval for the watch-path
+	// poller.
+	RefreshInterval time.Duration
+}
+
+func (d *Decorator) identityField() string {
+	if d.Mode == IdentityByName {
+		return NameField
+	}
+	return NamespaceField
+}
+
+func userFromContext(ctx context.Context) (user.Info, error) {
+	u, ok := genericapirequest.UserFrom(ctx)
+	if !ok {
+		return nil, errNoUser
+	}
+	return u, nil
+}
+
+// resolve computes the classification set (if any) and the RBAC floor (if
+// bypass is active) for the given verb. hasClassified/hasFloor distinguish
+// "not applicable" from "applicable, empty set" -- an empty-but-present set
+// still means deny-everything, whereas "not applicable" means don't
+// restrict on this axis at all.
+func (d *Decorator) resolve(ctx context.Context, u user.Info, verb string) (classified map[string]struct{}, hasClassified bool, floor map[string]struct{}, hasFloor bool, err error) {
+	if d.Mode == IdentityByName {
+		// Unconditional namespaces usage: the accessible set IS the
+		// floor. There is no separate classification concept and no
+		// separate resource+verb to narrow against -- namespaces IS
+		// the resource being asked about.
+		names, ferr := d.Accessible.FetchAccessibleNamespaces(ctx, u)
+		if ferr != nil {
+			return nil, false, nil, false, ferr
+		}
+		return nil, false, NamesToSet(names), true, nil
+	}
+
+	req, _ := RequestFrom(ctx)
+	if req.Kind != KindAccessible {
+		set, cerr := d.Classify.Resolve(ctx, req.Kind, req.Project)
+		if cerr != nil {
+			return nil, false, nil, false, cerr
+		}
+		classified, hasClassified = set, true
+	}
+	if IsBypass(ctx) {
+		set, ferr := d.RBACFloor.Resolve(ctx, u, d.Resource, verb)
+		if ferr != nil {
+			return nil, false, nil, false, ferr
+		}
+		floor, hasFloor = set, true
+	}
+	return classified, hasClassified, floor, hasFloor, nil
+}
+
+// combinedSet intersects whichever of classified/floor apply, per the
+// invariant finalSet = classification(scope) ∩ (rbacFloor, if bypass fired).
+// ok is false when neither axis applies -- i.e. no restriction at all, which
+// callers must handle by skipping filtering entirely rather than passing a
+// set through (NameSetSelector's nil-set sentinel means deny-everything, the
+// opposite of "no restriction").
+func combinedSet(classified map[string]struct{}, hasClassified bool, floor map[string]struct{}, hasFloor bool) (set map[string]struct{}, ok bool) {
+	switch {
+	case hasClassified && hasFloor:
+		return IntersectSets(classified, floor), true
+	case hasClassified:
+		return classified, true
+	case hasFloor:
+		return floor, true
+	default:
+		return nil, false
+	}
+}
+
+func callerSelectors(options *metainternalversion.ListOptions) (labels.Selector, fields.Selector) {
+	label := labels.Everything()
+	field := fields.Everything()
+	if options != nil {
+		if options.LabelSelector != nil {
+			label = options.LabelSelector
+		}
+		if options.FieldSelector != nil {
+			field = options.FieldSelector
+		}
+	}
+	return label, field
+}
+
+// List implements the filtering List path. Callers must only invoke this
+// when filtering is actually triggered for ctx (see Store.List's guard on
+// Trigger); List itself does not re-check.
+func (d *Decorator) List(ctx context.Context, options *metainternalversion.ListOptions) (runtime.Object, error) {
+	u, err := userFromContext(ctx)
+	if err != nil {
+		klog.V(4).InfoS("scopefilter: missing user info on List", "resource", d.Resource, "err", err)
+		return nil, apierrors.NewForbidden(d.Resource.GroupResource(), "", errCannotList)
+	}
+
+	classified, hasClassified, floor, hasFloor, err := d.resolve(ctx, u, "list")
+	if err != nil {
+		klog.Warningf("scopefilter: failed to resolve allowed set for user %q on List (%s): %v", u.GetName(), d.Resource, err)
+		return nil, apierrors.NewForbidden(d.Resource.GroupResource(), "", errCannotList)
+	}
+
+	set, restrict := combinedSet(classified, hasClassified, floor, hasFloor)
+	label, field := callerSelectors(options)
+	if restrict {
+		field = fields.AndSelectors(field, NewNameSetSelector(d.identityField(), set))
+	}
+
+	out, err := d.Store.ListPredicate(ctx, d.BuildPredicate(label, field), options)
+	if err != nil {
+		return nil, storageerr.InterpretListError(err, d.Resource.GroupResource())
+	}
+	return out, nil
+}
+
+// Get implements the filtering Get path. Callers must only invoke this when
+// filtering is actually triggered for ctx. rawGet performs the actual,
+// unfiltered storage read once Get has decided the identity is allowed --
+// passed in by the caller (Store.Get) rather than reached via d.Store.Get,
+// because d.Store.Get on the real Store IS the hooked entrypoint that
+// dispatches back here; calling it again would recurse forever.
+//
+// A denied namespace/identity surfaces as NotFound rather than Forbidden,
+// matching how the apiserver itself already translates a denied namespace
+// lookup, and deliberately making an inaccessible-project lookup
+// indistinguishable from a nonexistent-project one (non-disclosure of
+// existence).
+func (d *Decorator) Get(ctx context.Context, name string, options *metav1.GetOptions, rawGet func(context.Context, string, *metav1.GetOptions) (runtime.Object, error)) (runtime.Object, error) {
+	u, err := userFromContext(ctx)
+	if err != nil {
+		klog.V(4).InfoS("scopefilter: missing user info on Get", "resource", d.Resource, "name", name, "err", err)
+		return nil, apierrors.NewForbidden(d.Resource.GroupResource(), name, errCannotGet)
+	}
+
+	identity := name
+	if d.Mode == IdentityByNamespace {
+		ns, ok := genericapirequest.NamespaceFrom(ctx)
+		if !ok || ns == "" {
+			klog.V(4).InfoS("scopefilter: missing namespace in context on Get", "resource", d.Resource, "name", name)
+			return nil, apierrors.NewForbidden(d.Resource.GroupResource(), name, errNoNamespace)
+		}
+		identity = ns
+	}
+
+	classified, hasClassified, floor, hasFloor, err := d.resolve(ctx, u, "get")
+	if err != nil {
+		klog.Warningf("scopefilter: failed to resolve allowed set for user %q on Get (%s): %v", u.GetName(), d.Resource, err)
+		return nil, apierrors.NewForbidden(d.Resource.GroupResource(), name, errCannotGet)
+	}
+
+	if hasClassified {
+		if _, ok := classified[identity]; !ok {
+			return nil, apierrors.NewNotFound(d.Resource.GroupResource(), name)
+		}
+	}
+	if hasFloor {
+		if _, ok := floor[identity]; !ok {
+			return nil, apierrors.NewNotFound(d.Resource.GroupResource(), name)
+		}
+	}
+
+	return rawGet(ctx, name, options)
+}
+
+// Watch implements the filtering Watch path. Callers must only invoke this
+// when filtering is actually triggered for ctx. When neither classification
+// nor an RBAC floor applies (a fully privileged caller explicitly passing
+// --scope=accessible, which for them is a no-op since they can see
+// everything anyway), the inner watch is returned directly -- there is
+// nothing to poll and wrapping it would add pure overhead.
+func (d *Decorator) Watch(ctx context.Context, options *metainternalversion.ListOptions) (watch.Interface, error) {
+	u, err := userFromContext(ctx)
+	if err != nil {
+		klog.V(4).InfoS("scopefilter: missing user info on Watch", "resource", d.Resource, "err", err)
+		return nil, apierrors.NewForbidden(d.Resource.GroupResource(), "", errCannotWatch)
+	}
+
+	classified, hasClassified, floor, hasFloor, err := d.resolve(ctx, u, "watch")
+	if err != nil {
+		klog.Warningf("scopefilter: failed to resolve allowed set for user %q on Watch (%s): %v", u.GetName(), d.Resource, err)
+		return nil, apierrors.NewForbidden(d.Resource.GroupResource(), "", errCannotWatch)
+	}
+
+	initial, restrict := combinedSet(classified, hasClassified, floor, hasFloor)
+	label, field := callerSelectors(options)
+
+	var selector *NameSetSelector
+	finalField := field
+	if restrict {
+		selector = NewNameSetSelector(d.identityField(), initial)
+		finalField = fields.AndSelectors(field, selector)
+	}
+
+	predicate := d.BuildPredicate(label, finalField)
+	resourceVersion := ""
+	var sendInitialEvents *bool
+	if options != nil {
+		resourceVersion = options.ResourceVersion
+		predicate.AllowWatchBookmarks = options.AllowWatchBookmarks
+		sendInitialEvents = options.SendInitialEvents
+	}
+
+	inner, err := d.Store.WatchPredicate(ctx, predicate, resourceVersion, sendInitialEvents)
+	if err != nil {
+		return nil, err
+	}
+
+	if !restrict {
+		return inner, nil
+	}
+
+	refresh := d.RefreshInterval
+	if refresh <= 0 {
+		refresh = DefaultRefreshInterval
+	}
+
+	return NewFilteredWatch(ctx, WatchConfig{
+		Inner:          inner,
+		Selector:       selector,
+		Mode:           d.Mode,
+		Store:          d.Store,
+		BuildPredicate: d.BuildPredicate,
+		CallerLabel:    label,
+		CallerField:    field,
+		Poll: func(pctx context.Context) (map[string]struct{}, error) {
+			c, hasC, f, hasF, perr := d.resolve(pctx, u, "watch")
+			if perr != nil {
+				return nil, perr
+			}
+			next, ok := combinedSet(c, hasC, f, hasF)
+			if !ok {
+				// Cannot happen in practice: restrict was true
+				// at watch-open and neither axis can newly
+				// become "not applicable" mid-watch (the scope
+				// request and bypass status are fixed for the
+				// life of the connection). Fail closed rather
+				// than silently widening to unrestricted.
+				return map[string]struct{}{}, nil
+			}
+			return next, nil
+		},
+		Initial:         initial,
+		RefreshInterval: refresh,
+		UserName:        u.GetName(),
+	}), nil
+}
