+func newScopeTestRequest(t *testing.T, method, path, scopeHeader string) *http.Request {
+	t.Helper()
+	req, err := http.NewRequest(method, path, nil)
+	if err != nil {
+		t.Fatalf("NewRequest: %v", err)
+	}
+	if scopeHeader != "" {
+		req.Header.Set(scopefilter.HeaderScope, scopeHeader)
+	}
+
+	info, err := newTestRequestInfoResolver().NewRequestInfo(req)
+	if err != nil {
+		t.Fatalf("NewRequestInfo(%s %s): %v", method, path, err)
+	}
