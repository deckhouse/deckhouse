+
+// scopeTestHandler records whether the wrapped handler ran (bypass fired)
+// and what scopefilter tags its context carried, without touching the
+// storage layer at all.
+type scopeTestHandler struct {
+	called     bool
+	gotRequest scopefilter.Request
+	gotPresent bool
+	gotBypass  bool
+}
+
+func (h *scopeTestHandler) ServeHTTP(w http.ResponseWriter, req *http.Request) {
+	h.called = true
+	h.gotRequest, h.gotPresent = scopefilter.RequestFrom(req.Context())
+	h.gotBypass = scopefilter.IsBypass(req.Context())
+	w.WriteHeader(http.StatusOK)
+}
