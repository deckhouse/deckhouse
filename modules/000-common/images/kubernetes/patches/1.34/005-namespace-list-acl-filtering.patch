+package storage
+
+import (
+	"sync/atomic"
+
+	"k8s.io/apimachinery/pkg/fields"
+)
+
+// accessibleNamesSelector is a fields.Selector implementation that matches an
+// object iff its metadata.name is contained in a dynamically-updated set of
+// accessible namespace names.
+//
+// It is intended to be combined with the user-supplied field selector via
+// fields.AndSelectors and passed inside a storage.SelectionPredicate to
+// genericregistry.Store's ListPredicate / WatchPredicate. Because the
+// underlying Kubernetes storage layer always populates "metadata.name" in
+// storeElement.Fields, this lets us reuse the existing predicate machinery
+// for filtering and for streaming watches without any custom plumbing.
+//
+// The set of names is held behind an atomic.Pointer so that a single watch
+// can have its accessible set updated by a background goroutine without any
+// locking on the hot Matches() path.
+type accessibleNamesSelector struct {
+	// names points to the current (immutable) set of accessible names.
+	// nil means "deny everything" — used as a safe default before the first
+	// fetch and after a permanent error.
+	names atomic.Pointer[map[string]struct{}]
+}
+
+// newAccessibleNamesSelector creates a selector that matches the given initial
+// set of names. Pass nil to start in deny-everything mode.
+func newAccessibleNamesSelector(initial map[string]struct{}) *accessibleNamesSelector {
+	s := &accessibleNamesSelector{}
+	if initial != nil {
+		s.names.Store(&initial)
+	}
+	return s
+}
+
+// update atomically replaces the accessible-name set. Pass nil to switch
+// the selector into deny-everything mode (e.g. on a fetch error you wish
+// to fail closed).
+func (s *accessibleNamesSelector) update(set map[string]struct{}) {
+	if set == nil {
+		s.names.Store(nil)
+		return
+	}
+	s.names.Store(&set)
+}
+
+// snapshot returns the currently-loaded set, or nil if the selector is in
+// deny-everything mode. The returned map MUST NOT be mutated by callers; it
+// is shared with concurrent Matches calls.
+func (s *accessibleNamesSelector) snapshot() map[string]struct{} {
+	p := s.names.Load()
+	if p == nil {
+		return nil
+	}
+	return *p
+}
+
+// Matches implements fields.Selector. It returns true iff the object's
+// metadata.name is contained in the current accessible set.
+func (s *accessibleNamesSelector) Matches(f fields.Fields) bool {
+	set := s.names.Load()
+	if set == nil {
+		return false
+	}
+	_, ok := (*set)[f.Get("metadata.name")]
+	return ok
+}
+
+// Empty implements fields.Selector. The selector always restricts the
+// selection space, so this returns false unconditionally; otherwise an
+// AndSelector containing it would silently degrade to "everything".
+func (s *accessibleNamesSelector) Empty() bool { return false }
+
+// RequiresExactMatch implements fields.Selector. The selector represents a
+// set membership test rather than a single-value equality, so we never claim
+// to require an exact match. This preserves the storage layer's
+// MatchesSingle / MatchesSingleNamespace optimizations for any user-provided
+// equality terms ANDed alongside this selector.
+func (s *accessibleNamesSelector) RequiresExactMatch(string) (string, bool) {
+	return "", false
+}
+
+// Transform implements fields.Selector. The selector is opaque to selector
+// transformations; return self.
+func (s *accessibleNamesSelector) Transform(fields.TransformFunc) (fields.Selector, error) {
+	return s, nil
+}
+
+// Requirements implements fields.Selector. Returning nil keeps the dynamic
+// set out of the requirement-based introspection used by indexing; we rely
+// on the Matches path instead.
+func (s *accessibleNamesSelector) Requirements() fields.Requirements { return nil }
+
+// String implements fields.Selector. Returning empty avoids surfacing the
+// (potentially large, user-specific) set in error messages and audit logs.
+func (s *accessibleNamesSelector) String() string { return "" }
+
+// DeepCopySelector implements fields.Selector. The selector intentionally
+// shares its atomic state across copies so that a refresher goroutine can
+// update all watchers that observe the same instance simultaneously.
+func (s *accessibleNamesSelector) DeepCopySelector() fields.Selector { return s }
+
+// namesToSet is a small helper to convert a slice of names into a set with a
+// pre-sized backing map.
+func namesToSet(names []string) map[string]struct{} {
+	set := make(map[string]struct{}, len(names))
+	for _, n := range names {
+		set[n] = struct{}{}
+	}
+	return set
+}
