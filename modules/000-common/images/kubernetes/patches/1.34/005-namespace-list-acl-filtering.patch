+package scopefilter_test
+
+import (
+	"context"
+	"encoding/json"
+	"net/http"
+	"net/http/httptest"
+	"testing"
+
+	corev1 "k8s.io/api/core/v1"
+	metav1 "k8s.io/apimachinery/pkg/apis/meta/v1"
+	"k8s.io/apiserver/pkg/registry/generic/scopefilter"
+	restclient "k8s.io/client-go/rest"
+)
+
+// TestLoopbackClassificationResolver_LabelSelectorPerKind is the direct,
+// wire-level test of the exact labelSelector query string each scope Kind
+// sends: integration_test.go proves the END BEHAVIOR is correct against a
+// fake server that itself re-parses the selector with labels.Parse, which
+// would forgive some malformed-but-equivalent strings. This test instead
+// asserts on the literal query parameter the real HTTP client sends, so a
+// change to e.g. "!"+ProjectLabel accidentally becoming " !"+ProjectLabel
+// (a leading space, still often tolerated by labels.Parse) would be caught
+// here even if it happened to still work end to end.
+func TestLoopbackClassificationResolver_LabelSelectorPerKind(t *testing.T) {
+	tests := []struct {
+		name              string
+		kind              scopefilter.Kind
+		project           string
+		wantLabelSelector string
+	}{
+		{
+			name:              "system is the negated-existence selector",
+			kind:              scopefilter.KindSystem,
+			wantLabelSelector: "!" + scopefilter.ProjectLabel,
+		},
+		{
+			name:              "user is the bare-existence selector",
+			kind:              scopefilter.KindUser,
+			wantLabelSelector: scopefilter.ProjectLabel,
+		},
+		{
+			name:              "project is an equality selector on the given name",
+			kind:              scopefilter.KindProject,
+			project:           "team-a",
+			wantLabelSelector: scopefilter.ProjectLabel + "=team-a",
+		},
+	}
+
+	for _, tt := range tests {
+		t.Run(tt.name, func(t *testing.T) {
+			var gotSelector string
+			var gotPath string
+			srv := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
+				gotPath = r.URL.Path
+				gotSelector = r.URL.Query().Get("labelSelector")
+				w.Header().Set("Content-Type", "application/json")
+				_ = json.NewEncoder(w).Encode(corev1.NamespaceList{
+					TypeMeta: metav1.TypeMeta{APIVersion: "v1", Kind: "NamespaceList"},
+				})
+			}))
+			defer srv.Close()
+
+			resolver, err := scopefilter.NewLoopbackClassificationResolver(&restclient.Config{Host: srv.URL})
+			if err != nil {
+				t.Fatalf("NewLoopbackClassificationResolver: %v", err)
+			}
+
+			if _, err := resolver.Resolve(context.Background(), tt.kind, tt.project); err != nil {
+				t.Fatalf("Resolve: %v", err)
+			}
+
+			if gotPath != "/api/v1/namespaces" {
+				t.Fatalf("request path = %q, want /api/v1/namespaces", gotPath)
+			}
+			if gotSelector != tt.wantLabelSelector {
+				t.Fatalf("labelSelector = %q, want %q", gotSelector, tt.wantLabelSelector)
+			}
+		})
+	}
+}
+
+// TestLoopbackClassificationResolver_ProjectWithoutNameIsRejectedLocally
+// verifies KindProject with an empty project name fails BEFORE making any
+// HTTP call at all -- a request for "every namespace with any value of the
+// project label" is never the right fallback for a missing project name.
+func TestLoopbackClassificationResolver_ProjectWithoutNameIsRejectedLocally(t *testing.T) {
+	called := false
+	srv := httptest.NewServer(http.HandlerFunc(func(w http.ResponseWriter, r *http.Request) {
+		called = true
+		w.WriteHeader(http.StatusOK)
+	}))
+	defer srv.Close()
+
+	resolver, err := scopefilter.NewLoopbackClassificationResolver(&restclient.Config{Host: srv.URL})
+	if err != nil {
+		t.Fatalf("NewLoopbackClassificationResolver: %v", err)
+	}
+
+	if _, err := resolver.Resolve(context.Background(), scopefilter.KindProject, ""); err == nil {
+		t.Fatal("expected an error for KindProject with an empty project name")
+	}
+	if called {
+		t.Fatal("must fail before making any HTTP request when the project name is empty")
+	}
+}
