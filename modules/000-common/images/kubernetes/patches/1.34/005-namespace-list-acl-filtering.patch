+WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.
+See the License for the specific language governing permissions and
+limitations under the License.
+*/
+
+package storage
+
+import (
+	"context"
+	"errors"
+	"fmt"
+	"net/http"
+	"sync"
+	"time"
+
+	apierrors "k8s.io/apimachinery/pkg/api/errors"
+	metav1 "k8s.io/apimachinery/pkg/apis/meta/v1"
+	"k8s.io/apimachinery/pkg/runtime"
+	utilruntime "k8s.io/apimachinery/pkg/util/runtime"
+	"k8s.io/apimachinery/pkg/watch"
+	genericapirequest "k8s.io/apiserver/pkg/endpoints/request"
+	"k8s.io/klog/v2"
+	api "k8s.io/kubernetes/pkg/apis/core"
+)
+
+// filteredWatchBufferSize controls the per-watch buffered channel that merges
+// events coming from the underlying storage watch with events synthesized by
+// the ACL poller. Sized large enough to absorb a full namespace re-list during
+// a steady-state ACL rotation; on overflow the watch errors out and the client
+// is expected to reconnect with a fresh LIST.
+//
+// Mirrors openshift/openshift-apiserver pkg/project/auth/watch.go (1000).
+const filteredWatchBufferSize = 1000
+
+// errChannelOverflow is returned to the client (as a watch.Error event) when
+// the internal merge buffer overflows. The client is expected to reconnect.
+var errChannelOverflow = errors.New("namespace ACL filtered watch: outgoing channel overflow; reconnect")
+
+// nameSetGetter is the minimal subset of the storage REST surface used by the
+// filtered watch when synthesizing ADDED events for namespaces that just
+// became accessible. The signature matches genericregistry.Store.Get exactly,
+// but is kept as a small interface so tests can plug in a fake without
+// spinning up etcd.
+type nameSetGetter interface {
+	Get(ctx context.Context, name string, options *metav1.GetOptions) (runtime.Object, error)
+}
+
+// filteredWatch wraps a storage-layer watch.Interface for namespaces and
+// merges in synthetic events derived from changes to a user's accessible-
+// namespace set (the ACL).
+//
+// Architecture (mirrors OpenShift's userProjectWatcher):
+//
+//   - The underlying storage watch is started with a SelectionPredicate that
+//     contains a live accessibleNamesSelector. The selector's atomic state is
+//     updated on every ACL poll tick, so storage-layer events for namespaces
+//     the user no longer has access to are silently dropped at the predicate
+//     layer (no extra round-trips, no work in the cacher).
+//
+//   - In parallel, this wrapper polls the AccessibleNamespaceFetcher every
+//     refreshInterval (default 1s, configurable). On each tick it computes
+//     the diff against the names it has previously surfaced to the client
+//     (knownNames) and synthesizes ADDED / DELETED events accordingly.
+//     ADDED events fetch the actual Namespace via the supplied getter
+//     (a server-side Get against the storage layer).
+//
+//   - All events — both pass-through from storage and synthetic from the
+//     poller — are funneled through a single buffered channel and emitted to
+//     the client in arrival order, so the client sees a consistent stream.
+//
+//   - On any unrecoverable failure (channel overflow, fetcher panic) the
+//     watch emits a watch.Error and stops itself; the client's reflector
+//     will handle the reconnect/relist.
+type filteredWatch struct {
+	inner    watch.Interface
+	selector *accessibleNamesSelector
+	getter   nameSetGetter
+	fetcher  AccessibleNamespaceFetcher
+
+	username string
+	groups   []string
+	extra    map[string][]string
+
+	refreshInterval time.Duration
+
+	// outgoing is the channel returned to the client via ResultChan().
+	// Buffered so that a slow storage layer or a slow poller cannot block
+	// each other; on overflow we emit a watch.Error and stop.
+	outgoing chan watch.Event
+
+	// knownNames is the set of namespace names this watch has surfaced to
+	// the client and not yet retracted (i.e. for which the client believes
+	// it has live state). It is the SOURCE OF TRUTH for ADDED-vs-MODIFIED
+	// decisions and DELETED synthesis. Guarded by mu.
+	mu         sync.Mutex
+	knownNames map[string]struct{}
+
+	stopOnce sync.Once
+	stopCh   chan struct{}
+	cancel   context.CancelFunc
+}
+
+// newFilteredWatch wires together a storage watch with an ACL poller.
+//
+// The caller is responsible for starting the underlying inner watch and for
+// constructing the selector (the same selector instance must be used in the
+// inner watch's predicate so that storage-layer filtering and ACL-poller
+// updates are consistent).
+//
+// initial is the snapshot of accessible names at the moment the watch was
+// opened; it seeds knownNames so the very first poll tick does not synthesize
+// ADDED events for namespaces the client will already see via the inner
+// watch's SendInitialEvents.
+func newFilteredWatch(
+	parentCtx context.Context,
+	inner watch.Interface,
+	selector *accessibleNamesSelector,
+	getter nameSetGetter,
+	fetcher AccessibleNamespaceFetcher,
+	username string,
+	groups []string,
+	extra map[string][]string,
+	initial map[string]struct{},
+	refreshInterval time.Duration,
+) *filteredWatch {
+	ctx, cancel := context.WithCancel(parentCtx)
+
+	known := make(map[string]struct{}, len(initial))
+	for n := range initial {
+		known[n] = struct{}{}
+	}
+
+	w := &filteredWatch{
+		inner:           inner,
+		selector:        selector,
+		getter:          getter,
+		fetcher:         fetcher,
+		username:        username,
+		groups:          groups,
+		extra:           extra,
+		refreshInterval: refreshInterval,
+		outgoing:        make(chan watch.Event, filteredWatchBufferSize),
+		knownNames:      known,
+		stopCh:          make(chan struct{}),
+		cancel:          cancel,
+	}
+
+	go w.runStoragePump(ctx)
+	go w.runACLPoller(ctx)
+
+	return w
+}
+
+// ResultChan implements watch.Interface.
+func (w *filteredWatch) ResultChan() <-chan watch.Event {
+	return w.outgoing
+}
+
+// Stop implements watch.Interface. Idempotent.
+func (w *filteredWatch) Stop() {
+	w.stopOnce.Do(func() {
+		// Cancel the context first so background goroutines unblock from
+		// their selects before we tear down the inner watch.
+		w.cancel()
+		w.inner.Stop()
+		close(w.stopCh)
+	})
+}
+
+// runStoragePump forwards events from the underlying storage watch into the
+// outgoing channel, maintaining knownNames so that subsequent ACL diffs make
+// correct ADDED/DELETED decisions.
+func (w *filteredWatch) runStoragePump(ctx context.Context) {
+	defer utilruntime.HandleCrash()
+	defer w.Stop()
+
+	in := w.inner.ResultChan()
+	for {
+		select {
+		case <-ctx.Done():
+			return
+		case ev, ok := <-in:
+			if !ok {
+				// Inner watch closed (etcd disconnect, server shutdown,
+				// etc.). Propagate by stopping ourselves; client will
+				// reconnect with a fresh LIST.
+				return
+			}
+			ev = w.observeStorageEvent(ev)
+			if !w.emit(ev) {
+				return
+			}
+		}
+	}
+}
+
+// observeStorageEvent updates knownNames for an event the predicate just let
+// through and returns a (possibly mutated) event for emission. The event type
+// is demoted from ADDED to MODIFIED if the name was already in knownNames —
+// this happens, very rarely, when the ACL poller synthesized an ADDED for a
+// namespace at almost the same instant a real etcd CREATE event for it
+// crossed the predicate. Mirroring OpenShift's userProjectWatcher, we never
+// emit two ADDEDs for the same name without an intervening DELETED.
+func (w *filteredWatch) observeStorageEvent(ev watch.Event) watch.Event {
+	name, ok := nameOfNamespaceEvent(ev)
+	if !ok {
+		return ev
+	}
+
+	w.mu.Lock()
+	defer w.mu.Unlock()
+	switch ev.Type {
+	case watch.Added:
+		if _, already := w.knownNames[name]; already {
+			ev.Type = watch.Modified
+		}
+		w.knownNames[name] = struct{}{}
+	case watch.Modified:
+		w.knownNames[name] = struct{}{}
+	case watch.Deleted:
+		delete(w.knownNames, name)
+	}
+	return ev
+}
+
+// runACLPoller periodically refetches the user's accessible namespaces and
+// synthesizes ADDED/DELETED events for the diff. On the first iteration it
+// already has initial state in knownNames (seeded by the constructor), so it
+// only acts on subsequent changes — no double-emission of initial events.
+func (w *filteredWatch) runACLPoller(ctx context.Context) {
+	defer utilruntime.HandleCrash()
+	defer w.Stop()
+
+	if w.refreshInterval <= 0 {
+		// Misconfigured: poller would spin. Fall back to no-op (storage
+		// pump still works); ACL changes won't be reflected until the
+		// client reconnects.
+		<-ctx.Done()
+		return
+	}
+
+	ticker := time.NewTicker(w.refreshInterval)
+	defer ticker.Stop()
+
+	for {
+		select {
+		case <-ctx.Done():
+			return
+		case <-ticker.C:
+			if !w.tickACL(ctx) {
+				return
+			}
+		}
+	}
+}
+
+// tickACL performs one ACL poll iteration: fetch the latest accessible set,
+// update the live selector, and synthesize events for the diff. Returns
+// false if the watch must be torn down (e.g. emit overflow).
+func (w *filteredWatch) tickACL(ctx context.Context) bool {
+	names, err := w.fetcher.FetchAccessibleNamespaces(ctx, w.username, w.groups, w.extra)
+	if err != nil {
+		// Transient errors should not tear the watch down — the next tick
+		// will retry. A persistently failing fetcher will simply leave the
+		// client with the last-known view; that is strictly safer than
+		// flipping to deny-everything which would synthesize spurious
+		// DELETEDs across the whole accessible set.
+		klog.V(4).InfoS("namespace ACL: failed to refresh accessible set; keeping previous state",
+			"user", w.username, "err", err)
+		return true
+	}
+
+	newACL := namesToSet(names)
+	w.selector.update(newACL)
+
+	w.mu.Lock()
+	gained := make([]string, 0)
+	lost := make([]string, 0)
+	for n := range newACL {
+		if _, ok := w.knownNames[n]; !ok {
+			gained = append(gained, n)
+		}
+	}
+	for n := range w.knownNames {
+		if _, ok := newACL[n]; !ok {
+			lost = append(lost, n)
+		}
+	}
+	w.mu.Unlock()
+
+	for _, n := range lost {
+		ev := watch.Event{
+			Type: watch.Deleted,
+			// We do not have the original object in hand (and recovering it
+			// from etcd is racy). Emit a stub with just the name; this
+			// matches OpenShift's userProjectWatcher behavior and is enough
+			// for client-go reflectors to evict their cache entry.
+			Object: &api.Namespace{ObjectMeta: metav1.ObjectMeta{Name: n}},
+		}
+		w.mu.Lock()
+		delete(w.knownNames, n)
+		w.mu.Unlock()
+		if !w.emit(ev) {
+			return false
+		}
+	}
+
+	for _, n := range gained {
+		obj, err := w.getter.Get(ctx, n, &metav1.GetOptions{})
+		if err != nil {
+			if apierrors.IsNotFound(err) {
+				// Namespace exists in the user's ACL view but not in
+				// storage (likely a race with deletion). Skip — the
+				// client never saw it as ADDED and never will.
+				continue
+			}
+			klog.V(4).InfoS("namespace ACL: failed to fetch namespace for synthesized ADDED",
+				"namespace", n, "err", err)
+			continue
+		}
+
+		// Re-check under lock just before emitting: between gathering
+		// `gained` above and arriving here we released the lock, and the
+		// storage pump may have raced through and announced an ADDED for
+		// this same name (real etcd CREATE event passing the now-updated
+		// predicate). If so, the pump already updated knownNames; skip to
+		// avoid a duplicate ADDED. Best-effort; a tighter window would
+		// require holding the lock across the Get, which can be slow.
+		w.mu.Lock()
+		if _, already := w.knownNames[n]; already {
+			w.mu.Unlock()
+			continue
+		}
+		w.knownNames[n] = struct{}{}
+		w.mu.Unlock()
+
+		if !w.emit(watch.Event{Type: watch.Added, Object: obj}) {
+			return false
+		}
+	}
+
+	return true
+}
+
+// emit pushes an event to the outgoing channel without blocking. On overflow
+// it tries to deliver a watch.Error and returns false so callers tear the
+// watch down.
+func (w *filteredWatch) emit(ev watch.Event) bool {
+	select {
+	case <-w.stopCh:
+		return false
+	case w.outgoing <- ev:
+		return true
+	default:
+		// Outgoing buffer is full. Try one last delivery of an Error event
+		// (also non-blocking — if the client is gone there is nothing we
+		// can do) and stop.
+		errEvt := watch.Event{
+			Type: watch.Error,
+			Object: &metav1.Status{
+				Status:  metav1.StatusFailure,
+				Message: errChannelOverflow.Error(),
+				Reason:  metav1.StatusReasonInternalError,
+				Code:    http.StatusInternalServerError,
+			},
+		}
+		select {
+		case w.outgoing <- errEvt:
+		default:
+		}
+		klog.Warningf("namespace ACL filtered watch: outgoing channel full for user %q; closing watch", w.username)
+		return false
+	}
+}
+
+// nameOfNamespaceEvent extracts the namespace name from a watch event. It
+// returns ("", false) for unexpected payloads (defensive — the storage layer
+// always emits *api.Namespace, but a corrupt object should not panic the
+// pump goroutine).
+func nameOfNamespaceEvent(ev watch.Event) (string, bool) {
+	if ev.Object == nil {
+		return "", false
+	}
+	ns, ok := ev.Object.(*api.Namespace)
+	if !ok {
+		return "", false
+	}
+	return ns.Name, true
+}
+
+// userIdentityFromContext extracts the (username, groups, extra) triple used
+// to impersonate the user when calling the AccessibleNamespaceFetcher. It is
+// shared between the List, Get and Watch code paths in storage.go.
+func userIdentityFromContext(ctx context.Context) (username string, groups []string, extra map[string][]string, err error) {
+	u, ok := genericapirequest.UserFrom(ctx)
+	if !ok {
+		return "", nil, nil, fmt.Errorf("no user info in context")
+	}
+	return u.GetName(), u.GetGroups(), u.GetExtra(), nil
+}
