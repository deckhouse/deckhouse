+distributed under the License is distributed on an "AS IS" BASIS,
+WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.
+See the License for the specific language governing permissions and
+limitations under the License.
+*/
+
+// Package scopefilter_test's integration_test.go is the "Layer 3" of the
+// design's test plan: a full-pipeline test against a REAL etcd-backed
+// *genericregistry.Store and REAL scopefilter.Loopback* resolvers making
+// REAL HTTP calls (JSON encode/decode included) to an httptest.Server
+// standing in for kube-apiserver's own loopback endpoint (core v1 Namespace
+// LIST) and permission-browser-apiserver (AccessibleNamespaces,
+// BulkSubjectAccessReview).
+//
+// This deliberately duplicates none of decorator_test.go's fakes: that file
+// (Layer 1) proves Decorator's own combination logic is correct given
+// whatever resolvers hand it; this file proves the resolvers THEMSELVES
+// correctly speak the wire protocol end to end -- wrong JSON field names,
+// wrong HTTP verbs/paths, wrong label-selector construction would all pass
+// Layer 1 (which never touches HTTP or JSON) and fail here.
+package scopefilter_test
+
+import (
+	"context"
+	"encoding/json"
+	"fmt"
+	"net/http"
+	"net/http/httptest"
+	"testing"
+
+	corev1 "k8s.io/api/core/v1"
+	"k8s.io/apimachinery/pkg/api/apitesting"
+	metav1 "k8s.io/apimachinery/pkg/apis/meta/v1"
+	"k8s.io/apimachinery/pkg/fields"
+	"k8s.io/apimachinery/pkg/labels"
+	"k8s.io/apimachinery/pkg/runtime"
+	"k8s.io/apimachinery/pkg/runtime/schema"
+	"k8s.io/apimachinery/pkg/runtime/serializer"
+	utilruntime "k8s.io/apimachinery/pkg/util/runtime"
+	"k8s.io/apiserver/pkg/apis/example"
+	examplev1 "k8s.io/apiserver/pkg/apis/example/v1"
+	"k8s.io/apiserver/pkg/authentication/user"
+	genericapirequest "k8s.io/apiserver/pkg/endpoints/request"
+	"k8s.io/apiserver/pkg/registry/generic"
+	genericregistry "k8s.io/apiserver/pkg/registry/generic/registry"
+	"k8s.io/apiserver/pkg/registry/generic/scopefilter"
+	"k8s.io/apiserver/pkg/storage"
+	etcd3testing "k8s.io/apiserver/pkg/storage/etcd3/testing"
+	"k8s.io/apiserver/pkg/storage/storagebackend/factory"
+	restclient "k8s.io/client-go/rest"
+)
+
+var itScheme = runtime.NewScheme()
+var itCodecs = serializer.NewCodecFactory(itScheme)
+
+func init() {
+	utilruntime.Must(example.AddToScheme(itScheme))
+	utilruntime.Must(examplev1.AddToScheme(itScheme))
+}
+
+// ----- real etcd-backed Store for the example.Pod type ---------------------
+
+// newIntegrationStore builds a real *genericregistry.Store against a real
+// (embedded) etcd instance, exactly like genericregistry's own
+// NewTestGenericStoreRegistry -- deliberately reusing k8s.io/apiserver's own
+// "example" API group (k8s.io/apiserver/pkg/apis/example) rather than a
+// hand-rolled fake type, since it already ships full codec/scheme support
+// for exactly this purpose.
+func newIntegrationStore(t *testing.T) (*genericregistry.Store, func()) {
+	t.Helper()
+	const podPrefix = "/pods"
+
+	server, sc := etcd3testing.NewUnsecuredEtcd3TestClientServer(t)
+	sc.Codec = apitesting.TestStorageCodec(itCodecs, examplev1.SchemeGroupVersion)
+
+	s, destroyStorage, err := factory.Create(
+		*sc.ForResource(schema.GroupResource{Resource: "pods"}),
+		func() runtime.Object { return &example.Pod{} },
+		func() runtime.Object { return &example.PodList{} },
+		podPrefix,
+	)
+	if err != nil {
+		t.Fatalf("factory.Create: %v", err)
+	}
+
+	store := &genericregistry.Store{
+		NewFunc:                   func() runtime.Object { return &example.Pod{} },
+		NewListFunc:               func() runtime.Object { return &example.PodList{} },
+		DefaultQualifiedResource:  example.Resource("pods"),
+		SingularQualifiedResource: example.Resource("pod"),
+		KeyRootFunc: func(ctx context.Context) string {
+			return podPrefix
+		},
+		KeyFunc: func(ctx context.Context, name string) (string, error) {
+			ns, ok := genericapirequest.NamespaceFrom(ctx)
+			if !ok || ns == "" {
+				return "", fmt.Errorf("namespace is required")
+			}
+			return podPrefix + "/" + ns + "/" + name, nil
+		},
+		ObjectNameFunc: func(obj runtime.Object) (string, error) { return obj.(*example.Pod).Name, nil },
+		PredicateFunc: func(label labels.Selector, field fields.Selector) storage.SelectionPredicate {
+			return storage.SelectionPredicate{
+				Label: label,
+				Field: field,
+				GetAttrs: func(obj runtime.Object) (labels.Set, fields.Set, error) {
+					pod, ok := obj.(*example.Pod)
+					if !ok {
+						return nil, nil, fmt.Errorf("not a pod: %T", obj)
+					}
+					return labels.Set(pod.ObjectMeta.Labels), generic.ObjectMetaFieldsSet(&pod.ObjectMeta, true), nil
+				},
+			}
+		},
+		Storage: genericregistry.DryRunnableStorage{Storage: s},
+	}
+
+	destroy := func() {
+		destroyStorage()
+		server.Terminate(t)
+	}
+
+	// Seed directly through the raw storage.Interface -- bypassing
+	// Store.Create entirely, since this test never needs a REST create
+	// strategy (Store.CreateStrategy is deliberately left nil; only
+	// List/ListPredicate are under test here).
+	seed := func(namespace, name string) {
+		ctx := genericapirequest.WithNamespace(genericapirequest.NewContext(), namespace)
+		key, err := store.KeyFunc(ctx, name)
+		if err != nil {
+			t.Fatalf("KeyFunc(%s/%s): %v", namespace, name, err)
+		}
+		pod := &example.Pod{ObjectMeta: metav1.ObjectMeta{Namespace: namespace, Name: name}}
+		if err := s.Create(ctx, key, pod, nil, 0); err != nil {
+			t.Fatalf("seed %s/%s: %v", namespace, name, err)
+		}
+	}
+	seed("ns-a", "pod-1")
+	seed("ns-b", "pod-2")
+
+	return store, destroy
+}
+
+// ----- fake loopback server: core v1 Namespace LIST + permission-browser --
+
+// bulkSARRule is one canned (namespace, group, version, resource, verb) ->
+// allowed answer for the fake BulkSubjectAccessReview endpoint.
+type bulkSARRule struct {
+	namespace, resource, verb string
+	allowed                   bool
+}
+
+// newFakeLoopbackServer serves just enough of two APIs, on one server, to
+// exercise the real Loopback* resolvers exactly as they're used in
+// production against kube-apiserver's own loopback endpoint:
+//
+//   - GET /api/v1/namespaces (core v1, consumed by
+//     LoopbackClassificationResolver via a real client-go clientset) --
+//     filtered by labelSelector, matching real Kubernetes selector semantics
+//     via labels.Parse/labels.Set, not a hand-rolled string match.
+//   - GET /apis/authorization.deckhouse.io/v1alpha1/accessiblenamespaces
+//     (consumed by LoopbackAccessibleNamespaceFetcher).
+//   - POST /apis/authorization.deckhouse.io/v1alpha1/bulksubjectaccessreviews
+//     (consumed by LoopbackRBACFloorResolver), answered from rules.
+func newFakeLoopbackServer(t *testing.T, namespaces []corev1.Namespace, accessible []string, rules []bulkSARRule) *httptest.Server {
+	t.Helper()
+
+	mux := http.NewServeMux()
+
+	mux.HandleFunc("/api/v1/namespaces", func(w http.ResponseWriter, r *http.Request) {
+		selector := labels.Everything()
+		if raw := r.URL.Query().Get("labelSelector"); raw != "" {
+			sel, err := labels.Parse(raw)
+			if err != nil {
+				http.Error(w, err.Error(), http.StatusBadRequest)
+				return
+			}
+			selector = sel
+		}
+
+		list := corev1.NamespaceList{TypeMeta: metav1.TypeMeta{APIVersion: "v1", Kind: "NamespaceList"}}
+		for _, ns := range namespaces {
+			if selector.Matches(labels.Set(ns.Labels)) {
+				list.Items = append(list.Items, ns)
+			}
+		}
+		w.Header().Set("Content-Type", "application/json")
+		if err := json.NewEncoder(w).Encode(list); err != nil {
+			t.Errorf("encode NamespaceList: %v", err)
+		}
+	})
+
+	mux.HandleFunc("/apis/authorization.deckhouse.io/v1alpha1/accessiblenamespaces", func(w http.ResponseWriter, r *http.Request) {
+		if r.Method != http.MethodGet {
+			http.Error(w, "unsupported method", http.StatusMethodNotAllowed)
+			return
+		}
+		type item struct {
+			Metadata struct {
+				Name string `json:"name"`
+			} `json:"metadata"`
+		}
+		type list struct {
+			Items []item `json:"items"`
+		}
+		var out list
+		for _, n := range accessible {
+			out.Items = append(out.Items, item{Metadata: struct {
+				Name string `json:"name"`
+			}{Name: n}})
+		}
+		w.Header().Set("Content-Type", "application/json")
+		if err := json.NewEncoder(w).Encode(out); err != nil {
+			t.Errorf("encode accessiblenamespaces: %v", err)
+		}
+	})
+
+	mux.HandleFunc("/apis/authorization.deckhouse.io/v1alpha1/bulksubjectaccessreviews", func(w http.ResponseWriter, r *http.Request) {
+		if r.Method != http.MethodPost {
+			http.Error(w, "unsupported method", http.StatusMethodNotAllowed)
+			return
+		}
+		type resourceAttrs struct {
+			Namespace string `json:"namespace,omitempty"`
+			Verb      string `json:"verb,omitempty"`
+			Group     string `json:"group,omitempty"`
+			Version   string `json:"version,omitempty"`
+			Resource  string `json:"resource,omitempty"`
+		}
+		type reqItem struct {
+			ResourceAttributes resourceAttrs `json:"resourceAttributes"`
+		}
+		type reqBody struct {
+			Spec struct {
+				Requests []reqItem `json:"requests"`
+			} `json:"spec"`
+		}
+		var in reqBody
+		if err := json.NewDecoder(r.Body).Decode(&in); err != nil {
+			http.Error(w, err.Error(), http.StatusBadRequest)
+			return
+		}
+
+		type result struct {
+			Allowed bool `json:"allowed"`
+		}
+		type status struct {
+			Results []result `json:"results"`
+		}
+		type respBody struct {
+			Status status `json:"status"`
+		}
+		var out respBody
+		for _, req := range in.Spec.Requests {
+			allowed := false
+			for _, rule := range rules {
+				if rule.namespace == req.ResourceAttributes.Namespace &&
+					rule.resource == req.ResourceAttributes.Resource &&
+					rule.verb == req.ResourceAttributes.Verb {
+					allowed = rule.allowed
+					break
+				}
+			}
+			out.Status.Results = append(out.Status.Results, result{Allowed: allowed})
+		}
+		w.Header().Set("Content-Type", "application/json")
+		if err := json.NewEncoder(w).Encode(out); err != nil {
+			t.Errorf("encode bulksubjectaccessreviews response: %v", err)
+		}
+	})
+
+	srv := httptest.NewServer(mux)
+	t.Cleanup(srv.Close)
+	return srv
+}
+
+func namespaceWithProjectLabel(name, project string) corev1.Namespace {
+	labelsMap := map[string]string{}
+	if project != "" {
+		labelsMap[scopefilter.ProjectLabel] = project
+	}
+	return corev1.Namespace{ObjectMeta: metav1.ObjectMeta{Name: name, Labels: labelsMap}}
+}
+
+func podNames(t *testing.T, obj runtime.Object) []string {
+	t.Helper()
+	list, ok := obj.(*example.PodList)
+	if !ok {
+		t.Fatalf("List returned %T, want *example.PodList", obj)
+	}
+	names := make([]string, len(list.Items))
+	for i, p := range list.Items {
+		names[i] = p.Name
+	}
+	return names
+}
+
+// ----- the tests -------------------------------------------------------------
+
+// TestIntegration_AttackScenario_NarrowRBACMustNotLeakSystemNamespacePods is
+// the mandatory "attack" test from the design doc, run through the REAL
+// network path this time: a caller with RBAC for `get secrets` (not pods) in
+// ns-a -- which the fake Namespace LIST classifies as "system" (no project
+// label) -- must see nothing when requesting `pods --scope=system`, even
+// though ns-a is also present in AccessibleNamespaces (some access, just not
+// to pods).
+func TestIntegration_AttackScenario_NarrowRBACMustNotLeakSystemNamespacePods(t *testing.T) {
+	store, destroy := newIntegrationStore(t)
+	defer destroy()
+
+	srv := newFakeLoopbackServer(t,
+		[]corev1.Namespace{
+			namespaceWithProjectLabel("ns-a", ""), // system: no project label
+			namespaceWithProjectLabel("ns-b", "team-a"),
+		},
+		[]string{"ns-a"}, // AccessibleNamespaces: caller has SOME access to ns-a
+		[]bulkSARRule{
+			// Caller can list secrets in ns-a, but NOT pods.
+			{namespace: "ns-a", resource: "secrets", verb: "list", allowed: true},
+		},
+	)
+
+	decorator := buildDecorator(t, store, srv)
+	ctx := scopeCtx(t, decorator, scopefilter.Request{Kind: scopefilter.KindSystem}, true)
+
+	out, err := decorator.List(ctx, nil)
+	if err != nil {
+		t.Fatalf("List: %v", err)
+	}
+	if got := podNames(t, out); len(got) != 0 {
+		t.Fatalf("attack scenario leaked pods: got %v, want none (floor for pods/list in ns-a was never granted)", got)
+	}
+}
+
+// TestIntegration_ProjectScope_NoPodsListRightAlsoEmpty is the same caller as
+// the attack scenario, but requesting --scope=project:<ns-a's project> --
+// ns-a has no project label at all, so it can never match a project scope,
+// and even if it did the same missing pods/list right would still zero it
+// out.
+func TestIntegration_ProjectScope_NoPodsListRightAlsoEmpty(t *testing.T) {
+	store, destroy := newIntegrationStore(t)
+	defer destroy()
+
+	srv := newFakeLoopbackServer(t,
+		[]corev1.Namespace{
+			namespaceWithProjectLabel("ns-a", "team-a"),
+		},
+		[]string{"ns-a"},
+		[]bulkSARRule{
+			{namespace: "ns-a", resource: "secrets", verb: "list", allowed: true},
+		},
+	)
+
+	decorator := buildDecorator(t, store, srv)
+	ctx := scopeCtx(t, decorator, scopefilter.Request{Kind: scopefilter.KindProject, Project: "team-a"}, true)
+
+	out, err := decorator.List(ctx, nil)
+	if err != nil {
+		t.Fatalf("List: %v", err)
+	}
+	if got := podNames(t, out); len(got) != 0 {
+		t.Fatalf("got %v, want none (caller has no pods/list right in ns-a)", got)
+	}
+}
+
+// TestIntegration_ProjectScope_NonDisclosure is the non-disclosure
+// requirement: a nonexistent project and an existing project the caller
+// cannot see into (no matching namespaces reachable via their RBAC floor)
+// must produce bitwise-identical responses -- same empty list, same nil
+// error, same "not found by explicit resource" absence. If existence of a
+// real project leaked (e.g. a different error, a non-empty-but-wrong list),
+// this test would catch it.
+func TestIntegration_ProjectScope_NonDisclosure(t *testing.T) {
+	namespaces := []corev1.Namespace{
+		namespaceWithProjectLabel("ns-a", "real-project"),
+	}
+	accessible := []string{"ns-a"}
+	rules := []bulkSARRule{
+		{namespace: "ns-a", resource: "secrets", verb: "list", allowed: true},
+	}
+
+	run := func(t *testing.T, project string) (names []string, err error) {
+		store, destroy := newIntegrationStore(t)
+		defer destroy()
+		srv := newFakeLoopbackServer(t, namespaces, accessible, rules)
+		decorator := buildDecorator(t, store, srv)
+		ctx := scopeCtx(t, decorator, scopefilter.Request{Kind: scopefilter.KindProject, Project: project}, true)
+
+		out, err := decorator.List(ctx, nil)
+		if err != nil {
+			return nil, err
+		}
+		return podNames(t, out), nil
+	}
+
+	gotReal, errReal := run(t, "real-project")
+	gotFake, errFake := run(t, "nonexistent-project")
+
+	if errReal != nil || errFake != nil {
+		t.Fatalf("expected no errors, got real=%v fake=%v", errReal, errFake)
+	}
+	if len(gotReal) != 0 || len(gotFake) != 0 {
+		t.Fatalf("expected both empty, got real=%v fake=%v", gotReal, gotFake)
+	}
+}
+
+// TestIntegration_ControlScenario_GrantedPodsListRightSurfacesPods is the
+// positive control for the attack scenario: same setup, but the caller DOES
+// hold pods/list in ns-a -- their system-scoped pods must come back.
+func TestIntegration_ControlScenario_GrantedPodsListRightSurfacesPods(t *testing.T) {
+	store, destroy := newIntegrationStore(t)
+	defer destroy()
+
+	srv := newFakeLoopbackServer(t,
+		[]corev1.Namespace{
+			namespaceWithProjectLabel("ns-a", ""),
+			namespaceWithProjectLabel("ns-b", "team-a"),
+		},
+		[]string{"ns-a"},
+		[]bulkSARRule{
+			{namespace: "ns-a", resource: "pods", verb: "list", allowed: true},
+		},
+	)
+
+	decorator := buildDecorator(t, store, srv)
+	ctx := scopeCtx(t, decorator, scopefilter.Request{Kind: scopefilter.KindSystem}, true)
+
+	out, err := decorator.List(ctx, nil)
+	if err != nil {
+		t.Fatalf("List: %v", err)
+	}
+	if got := podNames(t, out); len(got) != 1 || got[0] != "pod-1" {
+		t.Fatalf("got %v, want [pod-1]", got)
+	}
+}
+
+// ----- shared wiring helpers -------------------------------------------------
+
+func buildDecorator(t *testing.T, store *genericregistry.Store, srv *httptest.Server) *scopefilter.Decorator {
+	t.Helper()
+	cfg := &restclient.Config{Host: srv.URL}
+
+	accessible, err := scopefilter.NewLoopbackAccessibleNamespaceFetcher(cfg)
+	if err != nil {
+		t.Fatalf("NewLoopbackAccessibleNamespaceFetcher: %v", err)
+	}
+	classify, err := scopefilter.NewLoopbackClassificationResolver(cfg)
+	if err != nil {
+		t.Fatalf("NewLoopbackClassificationResolver: %v", err)
+	}
+	floor, err := scopefilter.NewLoopbackRBACFloorResolver(cfg, accessible)
+	if err != nil {
+		t.Fatalf("NewLoopbackRBACFloorResolver: %v", err)
+	}
+
+	return &scopefilter.Decorator{
+		Store:          store,
+		BuildPredicate: store.PredicateFunc,
+		Resource:       schema.GroupVersionResource{Group: "", Version: "v1", Resource: "pods"},
+		Mode:           scopefilter.IdentityByNamespace,
+		Classify:       classify,
+		RBACFloor:      floor,
+		Accessible:     accessible,
+	}
+}
+
+// scopeCtx builds a request context tagged exactly as authorization.go's
+// generic bypass branch would tag it for a denied-then-bypassed request
+// (WithRequest + WithBypass together) -- the HTTP-level authorization
+// filter itself is Layer 2's concern, not this layer's; this test starts
+// from "the filter already decided to bypass" and verifies everything
+// downstream of that decision.
+func scopeCtx(t *testing.T, _ *scopefilter.Decorator, req scopefilter.Request, bypass bool) context.Context {
+	t.Helper()
+	ctx := genericapirequest.WithUser(genericapirequest.NewContext(), &user.DefaultInfo{Name: "alice"})
+	ctx = scopefilter.WithRequest(ctx, req)
+	if bypass {
+		ctx = scopefilter.WithBypass(ctx)
+	}
+	return ctx
+}
