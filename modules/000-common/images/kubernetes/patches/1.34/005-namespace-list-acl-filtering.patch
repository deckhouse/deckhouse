+
+package scopefilter
+
+import (
+	"context"
+	"fmt"
+
+	metav1 "k8s.io/apimachinery/pkg/apis/meta/v1"
+	"k8s.io/client-go/kubernetes"
+	restclient "k8s.io/client-go/rest"
+)
+
+// ProjectLabel is the label Deckhouse's multitenancy-manager stamps on every
+// namespace belonging to a Project (deckhouse.io/v1alpha2 Project CRD).
+// Namespaces without this label are "system" namespaces for
+// scope-classification purposes; namespaces carrying it belong to the
+// project named by its value.
+const ProjectLabel = "projects.deckhouse.io/project"
+
+// ClassificationResolver resolves the "system" / "user" / "project:<name>"
+// scope kinds to a set of namespace names. It answers a question that is
+// identity-independent (which namespaces exist and how are they labeled),
+// not "can this particular user see them" -- that narrowing is applied
+// separately by RBACFloorResolver, and only when the caller was actually
+// denied by RBAC.
+type ClassificationResolver interface {
+	// Resolve returns the set of namespace names matching kind (and, for
+	// KindProject, the given project name). Callers should never invoke
+	// this for KindAccessible: that scope's classification is a no-op, and
+	// the caller is expected to skip building a classification selector
+	// entirely rather than route it through here.
+	Resolve(ctx context.Context, kind Kind, project string) (map[string]struct{}, error)
+}
+
+// LoopbackClassificationResolver resolves system/user/project classification
+// by listing Namespace objects directly through kube-apiserver's loopback
+// client with a label selector on ProjectLabel. This deliberately bypasses
+// permission-browser-apiserver: multitenancy-manager (the controller that
+// owns ProjectLabel) has no dependency on userAuthz.enableMultiTenancy, so
+// resolving system/project membership this way works regardless of whether
+// EE multi-tenancy authorization is turned on, and needs no impersonation --
+// the answer does not depend on which user is asking.
+type LoopbackClassificationResolver struct {
+	client kubernetes.Interface
+}
+
+var _ ClassificationResolver = (*LoopbackClassificationResolver)(nil)
+
+// NewLoopbackClassificationResolver builds a resolver from a loopback REST
+// config. The config is copied internally by kubernetes.NewForConfig;
+// callers may safely mutate it after this returns.
+func NewLoopbackClassificationResolver(loopbackConfig *restclient.Config) (*LoopbackClassificationResolver, error) {
+	cfg := restclient.CopyConfig(loopbackConfig)
+	client, err := kubernetes.NewForConfig(cfg)
+	if err != nil {
+		return nil, fmt.Errorf("build loopback clientset: %w", err)
+	}
+	return &LoopbackClassificationResolver{client: client}, nil
+}
+
+// Resolve implements ClassificationResolver.
+func (r *LoopbackClassificationResolver) Resolve(ctx context.Context, kind Kind, project string) (map[string]struct{}, error) {
+	var labelSelector string
+	switch kind {
+	case KindSystem:
+		// "!key" -- namespace does not carry ProjectLabel at all.
+		labelSelector = "!" + ProjectLabel
+	case KindUser:
+		// bare "key" -- namespace carries ProjectLabel with any value.
+		labelSelector = ProjectLabel
+	case KindProject:
+		if project == "" {
+			return nil, fmt.Errorf("scopefilter: project classification requires a project name")
+		}
+		labelSelector = ProjectLabel + "=" + project
+	default:
+		return nil, fmt.Errorf("scopefilter: %q is not a namespace-classification scope kind", kind)
+	}
+
+	list, err := r.client.CoreV1().Namespaces().List(ctx, metav1.ListOptions{LabelSelector: labelSelector})
+	if err != nil {
+		return nil, fmt.Errorf("list namespaces for classification %q: %w", kind, err)
+	}
+
+	names := make(map[string]struct{}, len(list.Items))
+	for _, ns := range list.Items {
+		names[ns.Name] = struct{}{}
+	}
+	return names, nil
+}
