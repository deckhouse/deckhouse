+limitations under the License.
+*/
+
+package scopefilter
+
+import (
+	"bytes"
+	"context"
+	"encoding/json"
+	"fmt"
+	"net/http"
+	"time"
+
+	"k8s.io/apimachinery/pkg/runtime/schema"
+	"k8s.io/apiserver/pkg/authentication/user"
+	restclient "k8s.io/client-go/rest"
+)
+
+// bulkSubjectAccessReviewAPIPath is the URL path under which Deckhouse's
+// permission-browser-apiserver registers its BulkSubjectAccessReview API
+// (create-only, ephemeral -- results are computed and returned, never
+// stored).
+const bulkSubjectAccessReviewAPIPath = "/apis/authorization.deckhouse.io/v1alpha1/bulksubjectaccessreviews"
+
+// RBACFloorResolver computes the RBAC safety floor for a denied-then-bypassed
+// request: the set of namespaces the user is both (a) allowed to see at all
+// (AccessibleNamespaceFetcher) and (b) specifically allowed to perform verb
+// on gvr within (BulkSubjectAccessReview). Both halves are required: (a)
+// alone would let a caller with rights to some unrelated resource in
+// namespace N see gvr's objects in N too -- exactly the privilege-escalation
+// bug this design was corrected to close (see the package doc).
+type RBACFloorResolver interface {
+	Resolve(ctx context.Context, u user.Info, gvr schema.GroupVersionResource, verb string) (map[string]struct{}, error)
+}
+
+// The following types mirror the on-the-wire JSON shape of
+// permission-browser-apiserver's BulkSubjectAccessReview
+// (authorization.deckhouse.io/v1alpha1). Only the fields this resolver uses
+// are decoded/encoded, matching the pattern in fetcher.go: new upstream
+// fields don't break this code. Deckhouse's own generated Go types are not
+// importable here -- they live in a separate module (deckhouse/deckhouse),
+// while this file ships inside the vendored Kubernetes source tree.
+type bulkSARRequestBody struct {
+	Spec bulkSARRequestSpec `json:"spec"`
+}
+
+type bulkSARRequestSpec struct {
+	Requests []bulkSARResourceRequest `json:"requests"`
+}
+
+type bulkSARResourceRequest struct {
+	ResourceAttributes bulkSARResourceAttributes `json:"resourceAttributes"`
+}
+
+type bulkSARResourceAttributes struct {
+	Namespace string `json:"namespace,omitempty"`
+	Verb      string `json:"verb,omitempty"`
+	Group     string `json:"group,omitempty"`
+	Version   string `json:"version,omitempty"`
+	Resource  string `json:"resource,omitempty"`
+}
+
+type bulkSARResponseBody struct {
+	Status bulkSARResponseStatus `json:"status"`
+}
+
+type bulkSARResponseStatus struct {
+	// Results is positional: Results[i] answers Spec.Requests[i].
+	Results []bulkSARResult `json:"results"`
+}
+
+type bulkSARResult struct {
+	Allowed bool `json:"allowed"`
+}
+
+// LoopbackRBACFloorResolver implements RBACFloorResolver via kube-apiserver's
+// loopback connection: an AccessibleNamespaceFetcher supplies the candidate
+// set, then a single BulkSubjectAccessReview call narrows it to namespaces
+// where (group, version, resource, verb) is actually allowed.
+type LoopbackRBACFloorResolver struct {
+	accessible   AccessibleNamespaceFetcher
+	baseURL      string
+	roundTripper http.RoundTripper
+	timeout      time.Duration
+}
+
+var _ RBACFloorResolver = (*LoopbackRBACFloorResolver)(nil)
+
+// NewLoopbackRBACFloorResolver builds a resolver from a loopback REST config
+// and an already-constructed AccessibleNamespaceFetcher (typically the same
+// instance used elsewhere, e.g. for the "accessible" scope kind -- no need
+// to build two).
+func NewLoopbackRBACFloorResolver(loopbackConfig *restclient.Config, accessible AccessibleNamespaceFetcher) (*LoopbackRBACFloorResolver, error) {
+	rt, baseURL, err := newLoopbackRoundTripper(loopbackConfig)
+	if err != nil {
+		return nil, err
+	}
+	return &LoopbackRBACFloorResolver{
+		accessible:   accessible,
+		baseURL:      baseURL,
+		roundTripper: rt,
+		timeout:      defaultHTTPTimeout,
+	}, nil
+}
+
+// Resolve implements RBACFloorResolver.
+func (r *LoopbackRBACFloorResolver) Resolve(ctx context.Context, u user.Info, gvr schema.GroupVersionResource, verb string) (map[string]struct{}, error) {
+	candidates, err := r.accessible.FetchAccessibleNamespaces(ctx, u)
+	if err != nil {
+		return nil, fmt.Errorf("rbac floor: fetch accessible namespaces for user %q: %w", u.GetName(), err)
+	}
+	if len(candidates) == 0 {
+		return map[string]struct{}{}, nil
+	}
+
+	reqBody := bulkSARRequestBody{Spec: bulkSARRequestSpec{Requests: make([]bulkSARResourceRequest, len(candidates))}}
+	for i, ns := range candidates {
+		reqBody.Spec.Requests[i] = bulkSARResourceRequest{ResourceAttributes: bulkSARResourceAttributes{
+			Namespace: ns,
+			Verb:      verb,
+			Group:     gvr.Group,
+			Version:   gvr.Version,
+			Resource:  gvr.Resource,
+		}}
+	}
+
+	payload, err := json.Marshal(reqBody)
+	if err != nil {
+		return nil, fmt.Errorf("rbac floor: marshal BulkSubjectAccessReview request: %w", err)
+	}
+
+	endpoint := r.baseURL + bulkSubjectAccessReviewAPIPath
+	httpReq, err := http.NewRequestWithContext(ctx, http.MethodPost, endpoint, bytes.NewReader(payload))
+	if err != nil {
+		return nil, fmt.Errorf("rbac floor: build BulkSubjectAccessReview request: %w", err)
+	}
+	httpReq.Header.Set("Content-Type", "application/json")
+	httpReq.Header.Set("Accept", "application/json")
+
+	resp, err := impersonatedHTTPClient(r.roundTripper, u, r.timeout).Do(httpReq)
+	if err != nil {
+		return nil, fmt.Errorf("rbac floor: BulkSubjectAccessReview for user %q: %w", u.GetName(), err)
+	}
+	defer resp.Body.Close()
+
+	if resp.StatusCode != http.StatusOK && resp.StatusCode != http.StatusCreated {
+		return nil, fmt.Errorf("rbac floor: BulkSubjectAccessReview for user %q: unexpected status %d: %s", u.GetName(), resp.StatusCode, readErrorBody(resp.Body))
+	}
+
+	var out bulkSARResponseBody
+	if err := json.NewDecoder(resp.Body).Decode(&out); err != nil {
+		return nil, fmt.Errorf("rbac floor: decode BulkSubjectAccessReview response for user %q: %w", u.GetName(), err)
+	}
+	if len(out.Status.Results) != len(candidates) {
+		return nil, fmt.Errorf("rbac floor: BulkSubjectAccessReview for user %q: got %d results for %d requests", u.GetName(), len(out.Status.Results), len(candidates))
+	}
+
+	floor := make(map[string]struct{})
+	for i, result := range out.Status.Results {
+		if result.Allowed {
+			floor[candidates[i]] = struct{}{}
+		}
+	}
+	return floor, nil
+}
