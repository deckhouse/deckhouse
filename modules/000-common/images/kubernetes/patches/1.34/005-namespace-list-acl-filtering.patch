+	createNamespace(t, storage, "ns-a")
+	createNamespace(t, storage, "ns-b")
+	createNamespace(t, storage, "ns-c")
+
+	list, err := storage.List(ctxFiltered("alice", nil), nil)
+	if err != nil {
+		t.Fatalf("List: %v", err)
+	}
+	got := nsNames(list.(*api.NamespaceList))
+	want := []string{"ns-a", "ns-c"}
+	if !equalStrings(got, want) {
+		t.Fatalf("filtered List items: want %v, got %v", want, got)
+	}
+	if fetcher.snapshotListCalls() != 1 {
+		t.Errorf("expected exactly 1 fetcher call, got %d", fetcher.snapshotListCalls())
+	}
+}
+
+func TestList_FilteringMode_EmptyACL_ReturnsEmpty(t *testing.T) {
