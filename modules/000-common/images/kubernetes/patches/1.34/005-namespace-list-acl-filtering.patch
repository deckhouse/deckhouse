+package rest
+
+import (
+	"context"
+
+	"k8s.io/apimachinery/pkg/runtime/schema"
+	genericregistry "k8s.io/apiserver/pkg/registry/generic/registry"
+	"k8s.io/apiserver/pkg/registry/generic/scopefilter"
+	restclient "k8s.io/client-go/rest"
+	"k8s.io/klog/v2"
+)
+
+// scopeFilterResolvers bundles the resolvers every generic `--scope=<kind>`
+// wiring needs. Built once from a loopback REST config and shared across
+// every built-in resource wired via wireScopeFilter -- there is no reason
+// for pods, and whatever resource joins the MVP allow-list next, to each pay
+// for their own set of loopback HTTP transports.
+type scopeFilterResolvers struct {
+	accessible scopefilter.AccessibleNamespaceFetcher
+	classify   scopefilter.ClassificationResolver
+	floor      scopefilter.RBACFloorResolver
+}
+
+// newScopeFilterResolvers builds the shared resolver bundle. Returns
+// (nil, nil) -- deliberately not an error -- when loopbackConfig is nil,
+// since some minimal/test configurations legitimately have none. Callers
+// must treat a nil bundle as "generic scope filtering unavailable this run"
+// and skip wiring; kube-apiserver still boots with vanilla behavior for
+// every resource that would otherwise have been wired.
+func newScopeFilterResolvers(loopbackConfig *restclient.Config) (*scopeFilterResolvers, error) {
+	if loopbackConfig == nil {
+		return nil, nil
+	}
+
+	accessible, err := scopefilter.NewLoopbackAccessibleNamespaceFetcher(loopbackConfig)
+	if err != nil {
+		return nil, err
+	}
+	classify, err := scopefilter.NewLoopbackClassificationResolver(loopbackConfig)
+	if err != nil {
+		return nil, err
+	}
+	floor, err := scopefilter.NewLoopbackRBACFloorResolver(loopbackConfig, accessible)
+	if err != nil {
+		return nil, err
+	}
+
+	return &scopeFilterResolvers{accessible: accessible, classify: classify, floor: floor}, nil
+}
+
+// wireScopeFilter installs a scopefilter.Decorator on store (Mode
+// IdentityByNamespace, header-gated Trigger) and registers gvr so the
+// authorization filter's header-gated bypass (see
+// staging/.../endpoints/filters/authorization.go) is willing to route
+// denied requests for it into the filtering path.
+//
+// A nil resolvers bundle (no loopback config available this run) is a
+// silent no-op: store keeps vanilla behavior, and gvr is never registered,
+// so no --scope header can ever bypass 403 for it. Covering another
+// built-in resource is exactly this one call at its own construction site --
+// no change to that resource's own storage.go, since the filtering hook
+// lives on *genericregistry.Store itself (see its ScopeFilter field doc).
+func wireScopeFilter(store *genericregistry.Store, resolvers *scopeFilterResolvers, gvr schema.GroupVersionResource) {
+	if resolvers == nil {
+		return
+	}
+
+	store.ScopeFilter = &scopefilter.Decorator{
+		Store:          store,
+		BuildPredicate: store.PredicateFunc,
+		Resource:       gvr,
+		Mode:           scopefilter.IdentityByNamespace,
+		Trigger:        scopeFilterTriggered,
+		Classify:       resolvers.classify,
+		RBACFloor:      resolvers.floor,
+		Accessible:     resolvers.accessible,
+	}
+	scopefilter.Register(gvr.GroupResource())
+	klog.V(2).InfoS("scopefilter: wired generic --scope filtering", "resource", gvr)
+}
+
+// scopeFilterTriggered reports whether ctx carries a scope request at all.
+// Set by the authorization filter on both the denied-then-bypassed path
+// (which also carries scopefilter.IsBypass) and the already-allowed path
+// (which does not) -- see scopefilter.WithBypass's doc for why those two
+// tags are independent.
+func scopeFilterTriggered(ctx context.Context) bool {
+	_, present := scopefilter.RequestFrom(ctx)
+	return present
+}
