+package scopefilter
+
+import (
+	"sync/atomic"
+
+	metav1 "k8s.io/apimachinery/pkg/apis/meta/v1"
+	"k8s.io/apimachinery/pkg/fields"
+)
+
+// NamespaceField is the field NameSetSelector matches against when the
+// listed resource's own namespace determines visibility (the generic case:
+// pods, CRDs, anything namespaced other than Namespace itself).
+const NamespaceField = "metadata.namespace"
+
+// NameField is the field NameSetSelector matches against when the listed
+// resource IS the identity being classified (the one existing case:
+// namespaces listing namespaces, where "which namespace is this" and "what
+// is this item called" are the same question). Equal to metav1.ObjectNameField.
+const NameField = metav1.ObjectNameField
+
+// NameSetSelector is a fields.Selector that matches an object iff the value
+// of a configured field (NameField or NamespaceField) is contained in a
+// dynamically-updated set of allowed values.
+//
+// It is meant to be combined with other selectors -- the caller's own
+// label/field selector, a classification selector, an RBAC-floor selector --
+// via fields.AndSelectors, and handed to a storage.SelectionPredicate for
+// genericregistry.Store's ListPredicate/WatchPredicate. Because
+// generic.ObjectMetaFieldsSet (used by every namespaced resource's default
+// AttrFunc) always populates both "metadata.name" and "metadata.namespace",
+// this works against any namespaced resource without per-resource wiring.
+//
+// The set is held behind an atomic.Pointer so a background poller can update
+// which values are allowed without any locking on the hot Matches() path.
+// The selector is shared (not copied) between the storage predicate and
+// whatever populates it, so both observe the same atomic value.
+//
+// Notes on the fields.Selector method contract:
+//
+//   - Empty() returns false unconditionally; otherwise an AndSelector
+//     containing this selector would silently degrade to "match everything".
+//   - RequiresExactMatch() returns ("", false): this selector is a
+//     set-membership test, not equality on a single value. Reporting an
+//     equality match would defeat MatchesSingle-style storage optimizations
+//     for user-supplied terms ANDed alongside it.
+//   - String() returns "" so a (potentially large, per-user) ACL/RBAC set
+//     never leaks into error messages or audit logs.
+//   - DeepCopySelector() returns self -- the shared atomic state is the
+//     point; apimachinery does not strictly rely on copy semantics here.
+type NameSetSelector struct {
+	field string
+	names atomic.Pointer[map[string]struct{}]
+}
+
+// NewNameSetSelector creates a selector matching field against the given
+// initial set of values. Pass nil to start in deny-everything mode.
+func NewNameSetSelector(field string, initial map[string]struct{}) *NameSetSelector {
+	s := &NameSetSelector{field: field}
+	if initial != nil {
+		s.names.Store(&initial)
+	}
+	return s
+}
+
+// Update atomically replaces the allowed-value set. The passed map MUST NOT
+// be mutated by the caller afterwards -- it is shared with concurrent
+// Matches() calls. Pass nil to switch into deny-everything mode.
+func (s *NameSetSelector) Update(set map[string]struct{}) {
+	if set == nil {
+		s.names.Store(nil)
+		return
+	}
+	s.names.Store(&set)
+}
+
+// Snapshot returns the currently active set (read-only; callers must not
+// mutate the returned map). Returns nil in deny-everything mode.
+func (s *NameSetSelector) Snapshot() map[string]struct{} {
+	set := s.names.Load()
+	if set == nil {
+		return nil
+	}
+	return *set
+}
+
+// Matches implements fields.Selector.
+func (s *NameSetSelector) Matches(f fields.Fields) bool {
+	set := s.names.Load()
+	if set == nil {
+		return false
+	}
+	_, ok := (*set)[f.Get(s.field)]
+	return ok
+}
+
+func (s *NameSetSelector) Empty() bool { return false }
+
+func (s *NameSetSelector) RequiresExactMatch(string) (string, bool) {
+	return "", false
+}
+
+func (s *NameSetSelector) Transform(fields.TransformFunc) (fields.Selector, error) {
+	return s, nil
+}
+
+func (s *NameSetSelector) Requirements() fields.Requirements { return nil }
+
+func (s *NameSetSelector) String() string { return "" }
+
+func (s *NameSetSelector) DeepCopySelector() fields.Selector { return s }
+
+// NamesToSet converts a slice of names into a set with a pre-sized backing
+// map. The returned map is owned by the caller and may be handed off to
+// Update() without further copying.
+func NamesToSet(names []string) map[string]struct{} {
+	set := make(map[string]struct{}, len(names))
+	for _, n := range names {
+		set[n] = struct{}{}
+	}
+	return set
+}
+
+// IntersectSets returns the set intersection of a and b. Both must be
+// non-nil (callers needing "no restriction" semantics must special-case
+// that themselves -- there is no sentinel value here for it, unlike
+// NameSetSelector.Update(nil), which deliberately means deny-everything).
+func IntersectSets(a, b map[string]struct{}) map[string]struct{} {
+	out := make(map[string]struct{})
+	small, big := a, b
+	if len(b) < len(a) {
+		small, big = b, a
+	}
+	for n := range small {
+		if _, ok := big[n]; ok {
+			out[n] = struct{}{}
+		}
+	}
+	return out
+}
+
+// DiffNameSets returns names present in next but not in prev (gained) and
+// names present in prev but not in next (lost).
+func DiffNameSets(next, prev map[string]struct{}) (gained, lost []string) {
+	for n := range next {
+		if _, ok := prev[n]; !ok {
+			gained = append(gained, n)
+		}
+	}
+	for n := range prev {
+		if _, ok := next[n]; !ok {
+			lost = append(lost, n)
+		}
+	}
+	return gained, lost
+}
