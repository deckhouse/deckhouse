+
+package scopefilter
+
+import (
+	"context"
+	"errors"
+	"net/http"
+	"sync"
+	"time"
+
+	apierrors "k8s.io/apimachinery/pkg/api/errors"
+	"k8s.io/apimachinery/pkg/api/meta"
+	metainternalversion "k8s.io/apimachinery/pkg/apis/meta/internalversion"
+	metav1 "k8s.io/apimachinery/pkg/apis/meta/v1"
+	"k8s.io/apimachinery/pkg/fields"
+	"k8s.io/apimachinery/pkg/labels"
+	"k8s.io/apimachinery/pkg/runtime"
+	utilruntime "k8s.io/apimachinery/pkg/util/runtime"
+	"k8s.io/apimachinery/pkg/watch"
+	genericapirequest "k8s.io/apiserver/pkg/endpoints/request"
+	"k8s.io/apiserver/pkg/storage"
+	"k8s.io/klog/v2"
+)
+
+// filteredWatchBufferSize controls the per-watch buffered channel that merges
+// events coming from the underlying storage watch with events synthesized by
+// the ACL poller. Sized to absorb a full re-list during a steady-state ACL
+// rotation; on overflow the watch errors out and the client is expected to
+// reconnect with a fresh LIST. Mirrors OpenShift's pkg/project/auth/watch.go
+// (1000).
+const filteredWatchBufferSize = 1000
+
+var errChannelOverflow = errors.New("scopefilter: filtered watch outgoing channel overflow; reconnect")
+
+// IdentityMode selects how FilteredWatch maps a watched object to the
+// (namespace-set key, item key) pair its ACL-diffing logic operates on.
+type IdentityMode int
+
+const (
+	// IdentityByName is for the one case where the listed resource IS the
+	// identity being classified: Namespace listing Namespace. nsKey and
+	// itemKey are both the object's own name.
+	IdentityByName IdentityMode = iota
+
+	// IdentityByNamespace is the generic case: nsKey is the object's
+	// metadata.namespace, itemKey is its metadata.name. A single ACL
+	// change (one namespace gained/lost) can therefore gain or lose many
+	// items at once.
+	IdentityByNamespace
+)
+
+func identityOf(mode IdentityMode, obj runtime.Object) (nsKey, itemKey string, ok bool) {
+	accessor, err := meta.Accessor(obj)
+	if err != nil {
+		return "", "", false
+	}
+	if mode == IdentityByName {
+		n := accessor.GetName()
+		return n, n, true
+	}
+	return accessor.GetNamespace(), accessor.GetName(), true
+}
+
+// WatchConfig groups the dependencies of a FilteredWatch. All fields are
+// required unless documented otherwise.
+type WatchConfig struct {
+	// Inner is the storage-layer watch, already filtered through the live
+	// Selector via a SelectionPredicate. FilteredWatch takes ownership and
+	// calls Stop() on it.
+	Inner watch.Interface
+
+	// Selector is the live NameSetSelector whose allowed-value set is
+	// updated on every poll tick. Shared with the SelectionPredicate
+	// passed to Inner; updates are seen by both immediately.
+	Selector *NameSetSelector
+
+	// Mode selects the identity-extraction strategy (see IdentityMode).
+	Mode IdentityMode
+
+	// Store performs the Get (IdentityByName) or ListPredicate
+	// (IdentityByNamespace) calls used to materialize objects for
+	// synthesized ADDED events, and New() for building DELETED stubs.
+	Store StoreAccessor
+
+	// BuildPredicate mirrors Decorator.BuildPredicate -- the resource's
+	// registered predicate-construction function, needed to build a
+	// correctly-attributed SelectionPredicate when IdentityByNamespace mode
+	// lists a newly-gained namespace's contents.
+	BuildPredicate func(label labels.Selector, field fields.Selector) storage.SelectionPredicate
+
+	// CallerLabel / CallerField are the requesting client's own selectors
+	// (from the original List/Watch call), reused via BuildPredicate when
+	// IdentityByNamespace mode lists a newly-gained namespace's contents.
+	// Unused in IdentityByName mode. Nil means "no selector", matching
+	// fields.Everything()/labels.Everything() semantics.
+	CallerLabel labels.Selector
+	CallerField fields.Selector
+
+	// Poll returns the current combined allowed namespace/name set (e.g.
+	// classification ∩ RBAC floor, or plain AccessibleNamespaces --
+	// FilteredWatch does not care which). Called once per refresh tick.
+	Poll func(ctx context.Context) (map[string]struct{}, error)
+
+	// Initial is the allowed set at watch-open, used to seed the ACL
+	// diff baseline so the first poll tick does not treat namespaces the
+	// inner watch is about to (or already did) replay as newly "gained".
+	Initial map[string]struct{}
+
+	// RefreshInterval governs how often the poller wakes up. A value <=0
+	// disables polling entirely (storage events still flow).
+	RefreshInterval time.Duration
+
+	// UserName identifies the watching client, for logging only.
+	UserName string
+}
+
+// FilteredWatch wraps a storage-layer watch.Interface and merges in
+// synthetic events derived from changes to a dynamically-computed allowed
+// namespace/name set (an "ACL" in the broad sense: could be
+// AccessibleNamespaces, a classification ∩ RBAC-floor intersection, or
+// anything else Poll computes).
+//
+// Architecture mirrors OpenShift's userProjectWatcher:
+//
+//   - The underlying storage watch is started with a SelectionPredicate
+//     containing a live NameSetSelector. The selector's atomic state is
+//     updated on every poll tick, so storage-layer events for
+//     now-inaccessible namespaces/names are silently dropped at the
+//     predicate layer -- no extra round-trips, no work in the cacher.
+//
+//   - In parallel, this wrapper polls Poll every RefreshInterval (typically
+//     1s). On each tick it diffs the result against the last-known allowed
+//     set and synthesizes events for the change:
+//
+//   - IdentityByName (namespaces): a single Get materializes the one
+//     gained object; a stub carrying only its name is emitted for a lost
+//     one.
+//
+//   - IdentityByNamespace (generic resources): a namespace-scoped List
+//     (via Store.ListPredicate, reusing the caller's own label/field
+//     selectors) materializes every item newly visible in a gained
+//     namespace; stubs are emitted for every item previously surfaced
+//     from a lost namespace, using bookkeeping kept for exactly this
+//     purpose (see knownItems below) -- there is no cheaper way to know
+//     what to retract than remembering what was shown.
+//
+//   - All events -- pass-through from storage and synthetic from the
+//     poller -- are funneled through a single buffered channel and emitted
+//     to the client in arrival order.
+//
+//   - On unrecoverable failure (channel overflow, inner watch closure) the
+//     watch emits a watch.Error, stops itself, and closes the outgoing
+//     channel -- clients ranging over ResultChan() unblock cleanly and let
+//     their reflector reconnect.
+type FilteredWatch struct {
+	inner          watch.Interface
+	selector       *NameSetSelector
+	mode           IdentityMode
+	store          StoreAccessor
+	buildPredicate func(label labels.Selector, field fields.Selector) storage.SelectionPredicate
+
+	callerLabel labels.Selector
+	callerField fields.Selector
+
+	poll            func(ctx context.Context) (map[string]struct{}, error)
+	refreshInterval time.Duration
+	userName        string
+
+	outgoing chan watch.Event
+
+	// mu guards knownACL and knownItems.
+	mu sync.Mutex
+	// knownACL is the allowed namespace/name set as of the last poll tick
+	// (or Initial, before the first tick). Drives gained/lost diffing.
+	knownACL map[string]struct{}
+	// knownItems maps nsKey -> the set of itemKeys surfaced to the client
+	// under that key and not yet retracted. In IdentityByName mode this
+	// always collapses to knownItems[n] == {n: {}}. Source of truth for
+	// ADDED-vs-MODIFIED demotion and for exactly which stubs to emit as
+	// DELETED when a namespace is lost.
+	knownItems map[string]map[string]struct{}
+
+	stopOnce sync.Once
+	stopCh   chan struct{}
+	cancel   context.CancelFunc
+	senders  sync.WaitGroup
+}
+
+// NewFilteredWatch wires together a storage watch with an ACL poller. The
+// returned watch owns cfg.Inner and will Stop() it when the watch ends.
+func NewFilteredWatch(parentCtx context.Context, cfg WatchConfig) *FilteredWatch {
+	ctx, cancel := context.WithCancel(parentCtx)
+
+	known := make(map[string]struct{}, len(cfg.Initial))
+	for n := range cfg.Initial {
+		known[n] = struct{}{}
+	}
+
+	w := &FilteredWatch{
+		inner:           cfg.Inner,
+		selector:        cfg.Selector,
+		mode:            cfg.Mode,
+		store:           cfg.Store,
+		buildPredicate:  cfg.BuildPredicate,
+		callerLabel:     cfg.CallerLabel,
+		callerField:     cfg.CallerField,
+		poll:            cfg.Poll,
+		refreshInterval: cfg.RefreshInterval,
+		userName:        cfg.UserName,
+		outgoing:        make(chan watch.Event, filteredWatchBufferSize),
+		knownACL:        known,
+		knownItems:      make(map[string]map[string]struct{}),
+		stopCh:          make(chan struct{}),
+		cancel:          cancel,
+	}
+
+	w.senders.Add(2)
+	go w.runStoragePump(ctx)
+	go w.runACLPoller(ctx)
+	go w.closeWhenDone()
+
+	return w
+}
+
+// ResultChan implements watch.Interface.
+func (w *FilteredWatch) ResultChan() <-chan watch.Event {
+	return w.outgoing
+}
+
+// Stop implements watch.Interface. Idempotent.
+func (w *FilteredWatch) Stop() {
+	w.stopOnce.Do(func() {
+		// Cancel first so background goroutines unblock from their
+		// selects before we tear down the inner watch.
+		w.cancel()
+		w.inner.Stop()
+		close(w.stopCh)
+	})
+}
+
+// closeWhenDone waits for both sender goroutines (storage pump and ACL
+// poller) to finish, then closes the outgoing channel exactly once -- the
+// canonical "single closer" pattern, guaranteeing no send-on-closed-channel
+// panic.
+func (w *FilteredWatch) closeWhenDone() {
+	w.senders.Wait()
+	close(w.outgoing)
+}
+
+// runStoragePump forwards events from the underlying storage watch into the
+// outgoing channel, maintaining knownItems so subsequent ACL diffs make
+// correct ADDED/DELETED decisions.
+func (w *FilteredWatch) runStoragePump(ctx context.Context) {
+	defer utilruntime.HandleCrash()
+	defer w.senders.Done()
+	defer w.Stop()
+
+	in := w.inner.ResultChan()
+	for {
+		select {
+		case <-ctx.Done():
+			return
+		case ev, ok := <-in:
+			if !ok {
+				// Inner watch closed (etcd disconnect, server
+				// shutdown). Propagate by stopping ourselves;
+				// client will reconnect with a fresh LIST.
+				return
+			}
+			ev = w.observeStorageEvent(ev)
+			if !w.emit(ev) {
+				return
+			}
+		}
+	}
+}
+
+// observeStorageEvent updates knownItems for an event the predicate just let
+// through and returns a (possibly mutated) event for emission. The event
+// type is demoted from ADDED to MODIFIED if the item was already known --
+// this happens, very rarely, when the ACL poller synthesized an ADDED for
+// the same item at almost the same instant a real etcd CREATE event for it
+// crossed the predicate. We never emit two ADDEDs for the same item without
+// an intervening DELETED.
+func (w *FilteredWatch) observeStorageEvent(ev watch.Event) watch.Event {
+	if ev.Object == nil {
+		return ev
+	}
+	nsKey, itemKey, ok := identityOf(w.mode, ev.Object)
+	if !ok {
+		return ev
+	}
+
+	w.mu.Lock()
+	defer w.mu.Unlock()
+	switch ev.Type {
+	case watch.Added:
+		items := w.knownItems[nsKey]
+		if items == nil {
+			items = make(map[string]struct{})
+			w.knownItems[nsKey] = items
+		}
+		if _, already := items[itemKey]; already {
+			ev.Type = watch.Modified
+		}
+		items[itemKey] = struct{}{}
+	case watch.Modified:
+		items := w.knownItems[nsKey]
+		if items == nil {
+			items = make(map[string]struct{})
+			w.knownItems[nsKey] = items
+		}
+		items[itemKey] = struct{}{}
+	case watch.Deleted:
+		if items, present := w.knownItems[nsKey]; present {
+			delete(items, itemKey)
+			if len(items) == 0 {
+				delete(w.knownItems, nsKey)
+			}
+		}
+	}
+	return ev
+}
+
+// runACLPoller periodically re-evaluates Poll and synthesizes ADDED/DELETED
+// events for the diff against knownACL. The constructor seeds knownACL from
+// Initial, so the first poll iteration sees no diff in the steady state and
+// only acts on subsequent changes.
+func (w *FilteredWatch) runACLPoller(ctx context.Context) {
+	defer utilruntime.HandleCrash()
+	defer w.senders.Done()
+	defer w.Stop()
+
+	if w.refreshInterval <= 0 {
+		// Misconfigured: a 0/negative interval would spin. Park the
+		// goroutine until shutdown; the storage pump still works, ACL
+		// changes won't be reflected until the client reconnects.
+		<-ctx.Done()
+		return
+	}
+
+	ticker := time.NewTicker(w.refreshInterval)
+	defer ticker.Stop()
+
+	for {
+		select {
+		case <-ctx.Done():
+			return
+		case <-ticker.C:
+			if !w.tickACL(ctx) {
+				return
+			}
+		}
+	}
+}
+
+// tickACL performs one ACL poll iteration. Returns false if the watch must
+// be torn down (e.g. on emit overflow).
+func (w *FilteredWatch) tickACL(ctx context.Context) bool {
+	next, err := w.poll(ctx)
+	if err != nil {
+		if errors.Is(err, context.Canceled) || errors.Is(err, context.DeadlineExceeded) {
+			// Normal teardown: ctx cancellation propagated into the
+			// resolver's HTTP client.
+			return true
+		}
+		// Anything else is operationally interesting: surface it at
+		// Warning so operators don't need -v=4 to notice. Keep the
+		// previous ACL state -- strictly safer than flipping to
+		// deny-everything, which would synthesize spurious DELETEDs
+		// across the whole allowed set.
+		klog.Warningf("scopefilter: failed to refresh allowed set for user %q (keeping previous state): %v", w.userName, err)
+		return true
+	}
+
+	w.selector.Update(next)
+
+	w.mu.Lock()
+	gained, lost := DiffNameSets(next, w.knownACL)
+	w.knownACL = next
+	w.mu.Unlock()
+
+	for _, ns := range lost {
+		if !w.retract(ns) {
+			return false
+		}
+	}
+	for _, ns := range gained {
+		if !w.materialize(ctx, ns) {
+			return false
+		}
+	}
+	return true
+}
+
+// retract emits DELETED stubs for every item currently known under nsKey and
+// clears its bookkeeping. Returns false if the watch must be torn down.
+func (w *FilteredWatch) retract(nsKey string) bool {
+	w.mu.Lock()
+	items := w.knownItems[nsKey]
+	delete(w.knownItems, nsKey)
+	w.mu.Unlock()
+
+	for itemKey := range items {
+		stub := w.newStub(nsKey, itemKey)
+		klog.V(4).InfoS("scopefilter: synthesizing DELETED for lost access", "user", w.userName, "namespace", nsKey, "name", itemKey)
+		if !w.emit(watch.Event{Type: watch.Deleted, Object: stub}) {
+			return false
+		}
+	}
+	return true
+}
+
+// newStub builds a minimal object carrying only identity fields, for a
+// synthesized DELETED event where the real object may no longer be
+// retrievable (or, in IdentityByNamespace mode, was never re-fetched).
+func (w *FilteredWatch) newStub(nsKey, itemKey string) runtime.Object {
+	obj := w.store.New()
+	accessor, err := meta.Accessor(obj)
+	if err != nil {
+		// Unreachable for any real registered type; New() always
+		// returns something meta.Accessor can handle. Fall back to
+		// the bare object rather than panicking.
+		return obj
+	}
+	accessor.SetName(itemKey)
+	if w.mode == IdentityByNamespace {
+		accessor.SetNamespace(nsKey)
+	}
+	return obj
+}
+
+// materialize fetches and emits ADDED events for every item newly visible
+// under nsKey. Returns false if the watch must be torn down.
+func (w *FilteredWatch) materialize(ctx context.Context, nsKey string) bool {
+	objs, err := w.fetchGained(ctx, nsKey)
+	if err != nil {
+		if apierrors.IsNotFound(err) {
+			// IdentityByName: the namespace vanished between the ACL
+			// tick and the Get (race with deletion). The client
+			// never saw it as ADDED and never will -- not an error.
+			return true
+		}
+		if errors.Is(err, context.Canceled) || errors.Is(err, context.DeadlineExceeded) {
+			return true
+		}
+		klog.Warningf("scopefilter: failed to fetch gained namespace %q for user %q: %v", nsKey, w.userName, err)
+		return true
+	}
+
+	for _, obj := range objs {
+		_, itemKey, ok := identityOf(w.mode, obj)
+		if !ok {
+			continue
+		}
+
+		// Re-check under lock just before emitting: the storage pump
+		// may have raced ahead and already announced this same item
+		// as ADDED (a real etcd CREATE event passing the now-updated
+		// predicate) between us gathering `objs` and arriving here.
+		// Best-effort; a tighter window would require holding the
+		// lock across the fetch, which can be slow.
+		w.mu.Lock()
+		items := w.knownItems[nsKey]
+		if items == nil {
+			items = make(map[string]struct{})
+			w.knownItems[nsKey] = items
+		}
+		if _, already := items[itemKey]; already {
+			w.mu.Unlock()
+			continue
+		}
+		items[itemKey] = struct{}{}
+		w.mu.Unlock()
+
+		klog.V(4).InfoS("scopefilter: synthesizing ADDED for gained access", "user", w.userName, "namespace", nsKey, "name", itemKey)
+		if !w.emit(watch.Event{Type: watch.Added, Object: obj}) {
+			return false
+		}
+	}
+	return true
+}
+
+// fetchGained retrieves the object(s) newly visible under nsKey: a single
+// Get in IdentityByName mode (nsKey IS the object's name), or a
+// namespace-scoped List reusing the caller's own selectors in
+// IdentityByNamespace mode.
+func (w *FilteredWatch) fetchGained(ctx context.Context, nsKey string) ([]runtime.Object, error) {
+	if w.mode == IdentityByName {
+		obj, err := w.store.Get(ctx, nsKey, &metav1.GetOptions{})
+		if err != nil {
+			return nil, err
+		}
+		return []runtime.Object{obj}, nil
+	}
+
+	nsCtx := genericapirequest.WithNamespace(ctx, nsKey)
+	predicate := w.buildPredicate(w.callerLabel, w.callerField)
+	list, err := w.store.ListPredicate(nsCtx, predicate, &metainternalversion.ListOptions{})
+	if err != nil {
+		return nil, err
+	}
+	return meta.ExtractList(list)
+}
+
+// emit pushes an event to the outgoing channel. Returns false if the watch
+// is being torn down or the outgoing buffer overflowed, so callers stop.
+//
+// On overflow we attempt a single non-blocking delivery of a watch.Error so
+// the client learns why their stream just ended; if even that fails (buffer
+// genuinely full, client unresponsive) the error is dropped -- the client
+// will notice anyway when ResultChan closes.
+func (w *FilteredWatch) emit(ev watch.Event) bool {
+	select {
+	case <-w.stopCh:
+		return false
+	case w.outgoing <- ev:
+		return true
+	default:
+		errEvt := watch.Event{
+			Type: watch.Error,
+			Object: &metav1.Status{
+				Status:  metav1.StatusFailure,
+				Message: errChannelOverflow.Error(),
+				Reason:  metav1.StatusReasonInternalError,
+				Code:    http.StatusInternalServerError,
+			},
+		}
+		select {
+		case w.outgoing <- errEvt:
+		default:
+		}
+		klog.Warningf("scopefilter: filtered watch outgoing channel full for user %q; closing watch", w.userName)
+		return false
+	}
+}
