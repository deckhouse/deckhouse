+// Package scopefilter_test exercises the IdentityByNamespace (generic
+// resource) path end to end against fake, in-memory implementations of
+// StoreAccessor and the three resolver interfaces -- deliberately not the
+// real *genericregistry.Store, so this stays a pure k8s.io/apiserver test
+// with no dependency on the main k8s.io/kubernetes module. The
+// IdentityByName (namespaces) path already has thorough coverage in
+// k8s.io/kubernetes/pkg/registry/core/namespace/storage's filtering_test.go.
+package scopefilter_test
+
+import (
+	"context"
+	"fmt"
+	"slices"
+	"sync"
+	"testing"
+	"time"
+
+	apierrors "k8s.io/apimachinery/pkg/api/errors"
+	metainternalversion "k8s.io/apimachinery/pkg/apis/meta/internalversion"
+	metav1 "k8s.io/apimachinery/pkg/apis/meta/v1"
+	"k8s.io/apimachinery/pkg/fields"
+	"k8s.io/apimachinery/pkg/labels"
+	"k8s.io/apimachinery/pkg/runtime"
+	"k8s.io/apimachinery/pkg/runtime/schema"
+	"k8s.io/apimachinery/pkg/watch"
+	"k8s.io/apiserver/pkg/authentication/user"
+	genericapirequest "k8s.io/apiserver/pkg/endpoints/request"
+	"k8s.io/apiserver/pkg/registry/generic"
+	"k8s.io/apiserver/pkg/registry/generic/scopefilter"
+	"k8s.io/apiserver/pkg/storage"
+)
+
+// ----- fake namespaced resource type (stands in for e.g. a Pod) -----------
+
+type fakeItem struct {
+	metav1.TypeMeta
+	metav1.ObjectMeta
+}
+
+func (i *fakeItem) DeepCopyObject() runtime.Object {
+	return &fakeItem{TypeMeta: i.TypeMeta, ObjectMeta: *i.ObjectMeta.DeepCopy()}
+}
+
+type fakeItemList struct {
+	metav1.TypeMeta
+	metav1.ListMeta
+	Items []fakeItem
+}
+
+func (l *fakeItemList) DeepCopyObject() runtime.Object {
+	out := &fakeItemList{TypeMeta: l.TypeMeta, ListMeta: l.ListMeta, Items: make([]fakeItem, len(l.Items))}
+	for i := range l.Items {
+		out.Items[i] = *l.Items[i].DeepCopyObject().(*fakeItem)
+	}
+	return out
+}
+
+// ----- fake StoreAccessor ---------------------------------------------------
+
+// fakeStore is a minimal, in-memory stand-in for *genericregistry.Store,
+// just enough to exercise Decorator/FilteredWatch's own logic (selector
+// composition, gained/lost synthesis) without pulling in etcd or the main
+// module's registrytest helpers.
+type fakeStore struct {
+	mu    sync.Mutex
+	items map[string]map[string]*fakeItem // namespace -> name -> item
+}
+
+func newFakeStore() *fakeStore {
+	return &fakeStore{items: make(map[string]map[string]*fakeItem)}
+}
+
+func (s *fakeStore) put(namespace, name string) {
+	s.mu.Lock()
+	defer s.mu.Unlock()
+	if s.items[namespace] == nil {
+		s.items[namespace] = make(map[string]*fakeItem)
+	}
+	s.items[namespace][name] = &fakeItem{ObjectMeta: metav1.ObjectMeta{Namespace: namespace, Name: name}}
+}
+
+func (s *fakeStore) New() runtime.Object { return &fakeItem{} }
+
+// buildPredicate mirrors what a real Store.PredicateFunc field does: wire
+// GetAttrs so the selector machinery can see metadata.namespace/name/labels,
+// exactly like generic.DefaultNamespaceScopedAttr would for a real resource.
+func (s *fakeStore) buildPredicate(label labels.Selector, field fields.Selector) storage.SelectionPredicate {
+	return storage.SelectionPredicate{
+		Label: label,
+		Field: field,
+		GetAttrs: func(obj runtime.Object) (labels.Set, fields.Set, error) {
+			item, ok := obj.(*fakeItem)
+			if !ok {
+				return nil, nil, fmt.Errorf("unexpected type %T", obj)
+			}
+			return labels.Set(item.Labels), generic.ObjectMetaFieldsSet(&item.ObjectMeta, true), nil
+		},
+	}
+}
+
+func (s *fakeStore) Get(ctx context.Context, name string, _ *metav1.GetOptions) (runtime.Object, error) {
+	ns, _ := genericapirequest.NamespaceFrom(ctx)
+	s.mu.Lock()
+	defer s.mu.Unlock()
+	item, ok := s.items[ns][name]
+	if !ok {
+		return nil, apierrors.NewNotFound(schema.GroupResource{Resource: "fakeitems"}, name)
+	}
+	return item.DeepCopyObject(), nil
+}
+
+func (s *fakeStore) ListPredicate(_ context.Context, p storage.SelectionPredicate, _ *metainternalversion.ListOptions) (runtime.Object, error) {
+	s.mu.Lock()
+	defer s.mu.Unlock()
+	out := &fakeItemList{}
+	for _, byName := range s.items {
+		for _, item := range byName {
+			ok, err := p.Matches(item)
+			if err != nil {
+				return nil, err
+			}
+			if ok {
+				out.Items = append(out.Items, *item.DeepCopyObject().(*fakeItem))
+			}
+		}
+	}
+	return out, nil
+}
+
+func (s *fakeStore) WatchPredicate(context.Context, storage.SelectionPredicate, string, *bool) (watch.Interface, error) {
+	return newFakeWatch(), nil
+}
+
+var _ scopefilter.StoreAccessor = (*fakeStore)(nil)
+
+// ----- fake watch.Interface -------------------------------------------------
+
+type fakeWatch struct {
+	ch       chan watch.Event
+	stopOnce sync.Once
+}
+
+func newFakeWatch() *fakeWatch {
+	return &fakeWatch{ch: make(chan watch.Event, 16)}
+}
+
+func (w *fakeWatch) ResultChan() <-chan watch.Event { return w.ch }
+func (w *fakeWatch) Stop()                          { w.stopOnce.Do(func() { close(w.ch) }) }
+
+// ----- fake resolvers --------------------------------------------------------
+
+type fakeAccessible struct{ names []string }
+
+func (f *fakeAccessible) FetchAccessibleNamespaces(context.Context, user.Info) ([]string, error) {
+	return f.names, nil
+}
+
+func (f *fakeAccessible) IsNamespaceAccessible(_ context.Context, _ user.Info, ns string) (bool, error) {
+	return slices.Contains(f.names, ns), nil
+}
+
+// fakeClassify answers classification per scope Kind with a fixed,
+// pre-programmed set -- Project is ignored since the invariant test below
+// only exercises KindSystem.
+type fakeClassify struct{ byKind map[scopefilter.Kind]map[string]struct{} }
+
+func (f *fakeClassify) Resolve(_ context.Context, kind scopefilter.Kind, _ string) (map[string]struct{}, error) {
+	return f.byKind[kind], nil
+}
+
+// fakeFloor answers the RBAC floor keyed by "<resource>/<verb>" -- the whole
+// point of TestDecorator_List_RBACFloorNarrowsByResourceAndVerb is to prove
+// Decorator only ever consults the entry for the ACTUAL resource+verb of the
+// request, never a broader "has access to something in this namespace" set.
+type fakeFloor struct{ allowed map[string]map[string]struct{} }
+
+func floorKey(gvr schema.GroupVersionResource, verb string) string {
+	return gvr.Resource + "/" + verb
+}
+
+func (f *fakeFloor) Resolve(_ context.Context, _ user.Info, gvr schema.GroupVersionResource, verb string) (map[string]struct{}, error) {
+	return f.allowed[floorKey(gvr, verb)], nil
+}
+
+// ----- the invariant test ---------------------------------------------------
+
+// TestDecorator_List_RBACFloorNarrowsByResourceAndVerb is the direct
+// regression test for the design's load-bearing security invariant: the
+// RBAC safety floor added on a denied-then-bypassed request MUST be
+// AccessibleNamespaces() ∩ BulkSubjectAccessReview(group, resource, verb) of
+// the ACTUAL request being served, never a looser "has RBAC for anything in
+// this namespace" check. A caller with rights to list secrets (but not
+// pods) in ns-a, requesting pods with --scope=system, must see nothing from
+// ns-a -- even though ns-a is both AccessibleNamespaces-visible to them and
+// classified "system".
+func TestDecorator_List_RBACFloorNarrowsByResourceAndVerb(t *testing.T) {
+	podsGVR := schema.GroupVersionResource{Group: "", Version: "v1", Resource: "pods"}
+
+	classify := &fakeClassify{byKind: map[scopefilter.Kind]map[string]struct{}{
+		scopefilter.KindSystem: {"ns-a": {}},
+	}}
+
+	tests := []struct {
+		name         string
+		floorAllowed map[string]map[string]struct{}
+		wantNames    []string
+	}{
+		{
+			name: "attack: floor scoped to a different resource+verb must not leak ns-a's pods",
+			floorAllowed: map[string]map[string]struct{}{
+				// user can list secrets in ns-a -- NOT pods.
+				"secrets/list": {"ns-a": {}},
+			},
+			wantNames: nil,
+		},
+		{
+			name: "control: floor scoped to pods/list in ns-a surfaces its pods",
+			floorAllowed: map[string]map[string]struct{}{
+				"pods/list": {"ns-a": {}},
+			},
+			wantNames: []string{"pod-1"},
+		},
+	}
+
+	for _, tt := range tests {
+		t.Run(tt.name, func(t *testing.T) {
+			store := newFakeStore()
+			store.put("ns-a", "pod-1")
+			store.put("ns-b", "pod-2") // not system-classified; must never appear either way
+
+			d := &scopefilter.Decorator{
+				Store:          store,
+				BuildPredicate: store.buildPredicate,
+				Resource:       podsGVR,
+				Mode:           scopefilter.IdentityByNamespace,
+				Classify:       classify,
+				RBACFloor:      &fakeFloor{allowed: tt.floorAllowed},
+				Accessible:     &fakeAccessible{names: []string{"ns-a"}},
+			}
+
+			ctx := genericapirequest.WithUser(genericapirequest.NewContext(), &user.DefaultInfo{Name: "alice"})
+			ctx = scopefilter.WithRequest(ctx, scopefilter.Request{Kind: scopefilter.KindSystem})
+			ctx = scopefilter.WithBypass(ctx)
+
+			out, err := d.List(ctx, nil)
+			if err != nil {
+				t.Fatalf("List: %v", err)
+			}
+			list, ok := out.(*fakeItemList)
+			if !ok {
+				t.Fatalf("List returned %T, want *fakeItemList", out)
+			}
+
+			var got []string
+			for _, item := range list.Items {
+				got = append(got, item.Name)
+			}
+			slices.Sort(got)
+			want := slices.Clone(tt.wantNames)
+			slices.Sort(want)
+			if !slices.Equal(got, want) {
+				t.Fatalf("List names: got %v, want %v", got, want)
+			}
+		})
+	}
+}
+
+// TestDecorator_Watch_NoRestriction_DegradesToPlainWatchPredicate covers the
+// "fully privileged caller passing --scope=accessible" degenerate case: no
+// classification (accessible is a no-op) and no floor (never denied, so
+// never bypassed) must mean the FilteredWatch wrapper is skipped entirely.
+func TestDecorator_Watch_NoRestriction_DegradesToPlainWatchPredicate(t *testing.T) {
+	store := newFakeStore()
+	d := &scopefilter.Decorator{
+		Store:          store,
+		BuildPredicate: store.buildPredicate,
+		Resource:       schema.GroupVersionResource{Group: "", Version: "v1", Resource: "pods"},
+		Mode:           scopefilter.IdentityByNamespace,
+		Accessible:     &fakeAccessible{},
+	}
+
+	ctx := genericapirequest.WithUser(genericapirequest.NewContext(), &user.DefaultInfo{Name: "alice"})
+	ctx = scopefilter.WithRequest(ctx, scopefilter.Request{Kind: scopefilter.KindAccessible})
+	// Deliberately NOT WithBypass: RBAC allowed this caller outright.
+
+	w, err := d.Watch(ctx, nil)
+	if err != nil {
+		t.Fatalf("Watch: %v", err)
+	}
+	defer w.Stop()
+
+	if _, ok := w.(*fakeWatch); !ok {
+		t.Fatalf("Watch returned %T, want the raw *fakeWatch (no FilteredWatch wrapping expected)", w)
+	}
+}
+
+// ----- generic (IdentityByNamespace) watch synthesis ------------------------
+
+// TestFilteredWatch_IdentityByNamespace_SynthesizesAcrossNamespaceGainAndLoss
+// is the direct regression test for the riskiest previously-untested code
+// path: unlike namespaces (IdentityByName, one object per identity), a
+// single namespace gain/loss here must synthesize ADDED/DELETED for EVERY
+// item in that namespace, and FilteredWatch must remember exactly what it
+// synthesized so it can retract the right set later.
+func TestFilteredWatch_IdentityByNamespace_SynthesizesAcrossNamespaceGainAndLoss(t *testing.T) {
+	store := newFakeStore()
+	store.put("ns-a", "pod-1")
+	store.put("ns-b", "pod-2")
+	store.put("ns-b", "pod-3")
+
+	selector := scopefilter.NewNameSetSelector(scopefilter.NamespaceField, map[string]struct{}{"ns-a": {}})
+
+	var mu sync.Mutex
+	current := map[string]struct{}{"ns-a": {}}
+	poll := func(context.Context) (map[string]struct{}, error) {
+		mu.Lock()
+		defer mu.Unlock()
+		out := make(map[string]struct{}, len(current))
+		for k := range current {
+			out[k] = struct{}{}
+		}
+		return out, nil
+	}
+
+	w := scopefilter.NewFilteredWatch(context.Background(), scopefilter.WatchConfig{
+		Inner:           newFakeWatch(),
+		Selector:        selector,
+		Mode:            scopefilter.IdentityByNamespace,
+		Store:           store,
+		BuildPredicate:  store.buildPredicate,
+		CallerLabel:     labels.Everything(),
+		CallerField:     fields.Everything(),
+		Poll:            poll,
+		Initial:         map[string]struct{}{"ns-a": {}},
+		RefreshInterval: 20 * time.Millisecond,
+		UserName:        "alice",
+	})
+	defer w.Stop()
+
+	mu.Lock()
+	current = map[string]struct{}{"ns-a": {}, "ns-b": {}}
+	mu.Unlock()
+
+	added := collectEvents(t, w.ResultChan(), watch.Added, "ns-b", 3*time.Second, "pod-2", "pod-3")
+	if !added {
+		t.Fatal("did not observe synthesized ADDED for both ns-b pods within 3s of gaining ns-b")
+	}
+
+	mu.Lock()
+	current = map[string]struct{}{"ns-a": {}}
+	mu.Unlock()
+
+	deleted := collectEvents(t, w.ResultChan(), watch.Deleted, "ns-b", 3*time.Second, "pod-2", "pod-3")
+	if !deleted {
+		t.Fatal("did not observe synthesized DELETED for both ns-b pods within 3s of losing ns-b")
+	}
+}
+
+// collectEvents drains ch until every name in want has been seen with the
+// given (evType, namespace), or timeout elapses. Events not matching
+// evType/namespace (e.g. from an unrelated namespace) are ignored rather
+// than treated as failures.
+func collectEvents(t *testing.T, ch <-chan watch.Event, evType watch.EventType, namespace string, timeout time.Duration, want ...string) bool {
+	t.Helper()
+	remaining := make(map[string]bool, len(want))
+	for _, n := range want {
+		remaining[n] = true
+	}
+
+	deadline := time.NewTimer(timeout)
+	defer deadline.Stop()
+	for len(remaining) > 0 {
+		select {
+		case ev := <-ch:
+			if ev.Type != evType {
+				continue
+			}
+			item, ok := ev.Object.(*fakeItem)
+			if !ok || item.Namespace != namespace {
+				continue
+			}
+			delete(remaining, item.Name)
+		case <-deadline.C:
+			return false
+		}
+	}
+	return true
+}
