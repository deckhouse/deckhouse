+
+package scopefilter
+
+import (
+	"sync"
+
+	"k8s.io/apimachinery/pkg/runtime/schema"
+)
+
+var (
+	registryMu   sync.RWMutex
+	registryData = map[schema.GroupResource]struct{}{}
+)
+
+// Register marks gr as having scope-filtering storage wired in. Called once,
+// at construction time, by every storage_<group>.go site that wraps its
+// *genericregistry.Store with a Decorator, and by the CRD handler for every
+// namespaced CustomResourceDefinition it serves.
+//
+// The authorization filter consults IsRegistered before bypassing a 403 for
+// a scope-header request: a header alone must never be sufficient, because
+// bypassing authz for a resource with no filtering decorator actually wired
+// would hand a fully unfiltered list back to a caller RBAC just denied.
+func Register(gr schema.GroupResource) {
+	registryMu.Lock()
+	defer registryMu.Unlock()
+	registryData[gr] = struct{}{}
+}
+
+// Unregister removes gr from the allow-list. Used when a
+// CustomResourceDefinition is deleted, so that a future CRD reusing the same
+// group/resource name does not inherit stale registration state left over
+// from the deleted one.
+func Unregister(gr schema.GroupResource) {
+	registryMu.Lock()
+	defer registryMu.Unlock()
+	delete(registryData, gr)
+}
+
+// IsRegistered reports whether gr has scope-filtering storage wired in.
+func IsRegistered(gr schema.GroupResource) bool {
+	registryMu.RLock()
+	defer registryMu.RUnlock()
+	_, ok := registryData[gr]
+	return ok
+}
