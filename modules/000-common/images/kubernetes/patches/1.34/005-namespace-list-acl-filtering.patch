+			name:       "get registered resource with header bypasses",
+			method:     http.MethodGet,
+			path:       "/api/v1/namespaces/ns-a/widgets/foo",
+			header:     "accessible",
+			wantBypass: true,
+		},
+		{
+			name:       "watch registered resource with header bypasses",
+			method:     http.MethodGet,
+			path:       "/api/v1/widgets?watch=true",
+			header:     "user",
+			wantBypass: true,
+		},
+		{
+			name:       "no header at all never bypasses regardless of resource",
+			method:     http.MethodGet,
+			path:       "/api/v1/widgets",
+			header:     "",
+			wantBypass: false,
+		},
+		{
+			name:       "unregistered resource with header never bypasses",
+			method:     http.MethodGet,
+			path:       "/api/v1/pods", // deliberately not scopefilter.Register'd in this test
+			header:     "system",
+			wantBypass: false,
+		},
+		{
+			name:       "create verb never bypasses even with header",
+			method:     http.MethodPost,
+			path:       "/api/v1/namespaces/ns-a/widgets",
+			header:     "system",
+			wantBypass: false,
+		},
+		{
+			name:       "update (PUT) verb never bypasses",
+			method:     http.MethodPut,
+			path:       "/api/v1/namespaces/ns-a/widgets/foo",
+			header:     "system",
+			wantBypass: false,
+		},
+		{
+			name:       "delete verb never bypasses",
+			method:     http.MethodDelete,
+			path:       "/api/v1/namespaces/ns-a/widgets/foo",
+			header:     "system",
+			wantBypass: false,
+		},
+		{
+			name:       "patch verb never bypasses",
+			method:     http.MethodPatch,
+			path:       "/api/v1/namespaces/ns-a/widgets/foo",
+			header:     "system",
+			wantBypass: false,
+		},
+		{
+			name:       "subresource never bypasses even with header on a registered resource",
+			method:     http.MethodGet,
+			path:       "/api/v1/namespaces/ns-a/widgets/foo/status",
+			header:     "system",
+			wantBypass: false,
+		},
+		{
+			name: "cluster-scoped resource with header never bypasses when not registered " +
+				"(real wiring never registers cluster-scoped resources -- see wireScopeFilter)",
+			method:     http.MethodGet,
+			path:       "/apis/rbac.authorization.k8s.io/v1/clusterroles",
+			header:     "system",
+			wantBypass: false,
+		},
+	}
+
+	for _, tt := range tests {
+		t.Run(tt.name, func(t *testing.T) {
+			handler := &scopeTestHandler{}
+			wrapped := WithAuthorization(handler, denyAllAuthorizer(), negotiatedSerializer)
+			req := newScopeTestRequest(t, tt.method, tt.path, tt.header)
+			w := httptest.NewRecorder()
+			wrapped.ServeHTTP(w, req)
+
+			if tt.wantBypass {
+				if !handler.called {
+					t.Fatalf("expected bypass (handler invoked), got HTTP %d: %s", w.Code, w.Body.String())
+				}
+				if !handler.gotPresent {
+					t.Fatal("handler ran but scopefilter.RequestFrom found nothing on its context")
+				}
+				if !handler.gotBypass {
+					t.Fatal("handler ran but scopefilter.IsBypass is false -- a denied-then-bypassed request must carry it")
+				}
+				return
+			}
+
+			if handler.called {
+				t.Fatal("expected no bypass, but the wrapped handler was invoked anyway")
+			}
+			if w.Code != http.StatusForbidden {
+				t.Fatalf("expected 403 Forbidden, got %d: %s", w.Code, w.Body.String())
+			}
+		})
+	}
+}
+
+// TestWithAuthorization_GenericScopeBypass_AllowedCallerStillGetsTagged
+// covers the OTHER branch: a caller RBAC already allows (never denied, so
+// never bypassed) still gets scopefilter.WithRequest set when they send the
+// header, WITHOUT scopefilter.WithBypass -- letting a privileged caller use
+// --scope=system to narrow their own view without ever triggering the RBAC
+// floor computation. See withAuthorization's DecisionAllow branch and
+// scopefilter.WithBypass's doc for why these two tags are independent.
+func TestWithAuthorization_GenericScopeBypass_AllowedCallerStillGetsTagged(t *testing.T) {
+	registered := schema.GroupResource{Resource: "widgets"}
+	scopefilter.Register(registered)
+	t.Cleanup(func() { scopefilter.Unregister(registered) })
+
+	scheme := runtime.NewScheme()
+	negotiatedSerializer := serializer.NewCodecFactory(scheme).WithoutConversion()
+
+	handler := &scopeTestHandler{}
+	allowAll := fakeAuthorizer{authorizer.DecisionAllow, "allowed for test", nil}
+	wrapped := WithAuthorization(handler, allowAll, negotiatedSerializer)
+
+	req := newScopeTestRequest(t, http.MethodGet, "/api/v1/widgets", "system")
+	w := httptest.NewRecorder()
+	wrapped.ServeHTTP(w, req)
+
+	if !handler.called {
+		t.Fatalf("expected the handler to run (RBAC allowed), got HTTP %d", w.Code)
+	}
+	if !handler.gotPresent {
+		t.Fatal("allowed caller with --scope header must still get scopefilter.WithRequest tagged")
+	}
+	if handler.gotBypass {
+		t.Fatal("allowed (non-denied) caller must NOT carry scopefilter.IsBypass -- RBAC floor must never be computed for them")
+	}
+	if handler.gotRequest.Kind != scopefilter.KindSystem {
+		t.Fatalf("scope request kind = %q, want %q", handler.gotRequest.Kind, scopefilter.KindSystem)
+	}
+}
