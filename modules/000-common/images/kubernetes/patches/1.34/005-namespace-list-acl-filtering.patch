+
+package scopefilter_test
+
+import (
+	"sync"
+	"testing"
+	"time"
+
+	"k8s.io/apiserver/pkg/registry/generic/scopefilter"
+)
+
+func fieldsOf(pairs ...string) fakeFields {
+	m := make(map[string]string, len(pairs)/2)
+	for i := 0; i+1 < len(pairs); i += 2 {
+		m[pairs[i]] = pairs[i+1]
+	}
+	return fakeFields(m)
+}
+
+// fakeFields implements fields.Fields directly over a plain map, so these
+// tests don't need a real runtime.Object just to exercise Matches.
+type fakeFields map[string]string
+
+func (f fakeFields) Has(field string) bool   { _, ok := f[field]; return ok }
+func (f fakeFields) Get(field string) string { return f[field] }
+
+func TestNameSetSelector_MatchesByConfiguredField(t *testing.T) {
+	nameSel := scopefilter.NewNameSetSelector(scopefilter.NameField, scopefilter.NamesToSet([]string{"ns-a"}))
+	if !nameSel.Matches(fieldsOf(scopefilter.NameField, "ns-a")) {
+		t.Fatal("NameField selector should match metadata.name=ns-a")
+	}
+	if nameSel.Matches(fieldsOf(scopefilter.NamespaceField, "ns-a")) {
+		t.Fatal("NameField selector must not match on metadata.namespace, even with the same value")
+	}
+
+	nsSel := scopefilter.NewNameSetSelector(scopefilter.NamespaceField, scopefilter.NamesToSet([]string{"ns-a"}))
+	if !nsSel.Matches(fieldsOf(scopefilter.NamespaceField, "ns-a")) {
+		t.Fatal("NamespaceField selector should match metadata.namespace=ns-a")
+	}
+	if nsSel.Matches(fieldsOf(scopefilter.NameField, "ns-a")) {
+		t.Fatal("NamespaceField selector must not match on metadata.name, even with the same value")
+	}
+}
+
+func TestNameSetSelector_NilSetDeniesEverything(t *testing.T) {
+	sel := scopefilter.NewNameSetSelector(scopefilter.NamespaceField, nil)
+	if sel.Matches(fieldsOf(scopefilter.NamespaceField, "ns-a")) {
+		t.Fatal("a selector constructed with a nil set must deny everything")
+	}
+
+	sel.Update(scopefilter.NamesToSet([]string{"ns-a"}))
+	if !sel.Matches(fieldsOf(scopefilter.NamespaceField, "ns-a")) {
+		t.Fatal("after Update with a real set, a previously-nil selector must start matching")
+	}
+
+	sel.Update(nil)
+	if sel.Matches(fieldsOf(scopefilter.NamespaceField, "ns-a")) {
+		t.Fatal("Update(nil) must switch back to deny-everything")
+	}
+}
+
+func TestNameSetSelector_ContractForAndSelectorComposition(t *testing.T) {
+	// fields.AndSelectors treats an Empty() selector as "match everything";
+	// NameSetSelector must never report Empty() == true, or composing it
+	// into an AND chain would silently drop the restriction it exists to
+	// enforce.
+	sel := scopefilter.NewNameSetSelector(scopefilter.NamespaceField, scopefilter.NamesToSet([]string{"ns-a"}))
+	if sel.Empty() {
+		t.Fatal("NameSetSelector.Empty() must always be false")
+	}
+
+	// RequiresExactMatch reporting a match here would let storage-layer
+	// single-key optimizations (MatchesSingle) treat this set-membership
+	// selector as an equality constraint on one value, silently narrowing
+	// results to a single (wrong) key once the set has more than one member.
+	if _, ok := sel.RequiresExactMatch("anything"); ok {
+		t.Fatal("NameSetSelector.RequiresExactMatch must always report (_, false)")
+	}
+}
+
+// TestNameSetSelector_ConcurrentUpdateDuringMatches is a regression guard
+// for the concurrency contract the whole watch-polling design depends on:
+// runACLPoller calls Update() from its own goroutine on every tick while the
+// storage layer's cacher concurrently calls Matches() from arbitrary
+// goroutines for every incoming watch event. Run with `go test -race` to
+// have any real teeth -- a non-atomic implementation would be flagged by
+// the race detector even though the assertions below would still pass.
+func TestNameSetSelector_ConcurrentUpdateDuringMatches(t *testing.T) {
+	sel := scopefilter.NewNameSetSelector(scopefilter.NamespaceField, scopefilter.NamesToSet([]string{"ns-a"}))
+
+	stop := make(chan struct{})
+	var wg sync.WaitGroup
+
+	wg.Add(1)
+	go func() {
+		defer wg.Done()
+		toggle := false
+		for {
+			select {
+			case <-stop:
+				return
+			default:
+				if toggle {
+					sel.Update(scopefilter.NamesToSet([]string{"ns-a", "ns-b"}))
+				} else {
+					sel.Update(scopefilter.NamesToSet([]string{"ns-a"}))
+				}
+				toggle = !toggle
+			}
+		}
+	}()
+
+	const readers = 8
+	wg.Add(readers)
+	for i := 0; i < readers; i++ {
+		go func() {
+			defer wg.Done()
+			for {
+				select {
+				case <-stop:
+					return
+				default:
+					// ns-a must always match regardless of which of the
+					// two Update'd sets is currently active -- both
+					// contain it. A racy implementation could observe a
+					// torn/partial map here; the race detector is the
+					// real judge, this assertion is a sanity backstop.
+					if !sel.Matches(fieldsOf(scopefilter.NamespaceField, "ns-a")) {
+						t.Error("ns-a must always match: it is present in both sets Update alternates between")
+						return
+					}
+				}
+			}
+		}()
+	}
+
+	time.Sleep(50 * time.Millisecond)
+	close(stop)
+	wg.Wait()
+}
+
+func TestDiffNameSets(t *testing.T) {
+	prev := scopefilter.NamesToSet([]string{"ns-a", "ns-b"})
+	next := scopefilter.NamesToSet([]string{"ns-b", "ns-c"})
+
+	gained, lost := scopefilter.DiffNameSets(next, prev)
+	if len(gained) != 1 || gained[0] != "ns-c" {
+		t.Fatalf("gained = %v, want [ns-c]", gained)
+	}
+	if len(lost) != 1 || lost[0] != "ns-a" {
+		t.Fatalf("lost = %v, want [ns-a]", lost)
+	}
+}
+
+func TestIntersectSets(t *testing.T) {
+	a := scopefilter.NamesToSet([]string{"ns-a", "ns-b"})
+	b := scopefilter.NamesToSet([]string{"ns-b", "ns-c"})
+
+	got := scopefilter.IntersectSets(a, b)
+	if len(got) != 1 {
+		t.Fatalf("IntersectSets(%v, %v) = %v, want exactly {ns-b}", a, b, got)
+	}
+	if _, ok := got["ns-b"]; !ok {
+		t.Fatalf("IntersectSets(%v, %v) = %v, want exactly {ns-b}", a, b, got)
+	}
+}
