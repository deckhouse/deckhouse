+WITHOUT WARRANTIES OR CONDITIONS OF ANY KIND, either express or implied.
+See the License for the specific language governing permissions and
+limitations under the License.
+*/
+
+package scopefilter
+
+import (
+	"context"
+	"fmt"
+	"net/http"
+	"strings"
+)
+
+// Wire headers carrying the client-requested scope. The CLI exposes a single
+// --scope=<kind>[:<project>] flag, but splits it into two headers before
+// sending: this keeps the wire contract a flat enum plus an optional
+// companion parameter, rather than a tagged-value string the server has to
+// parse out of one header.
+const (
+	HeaderScope   = "X-Deckhouse-Scope"
+	HeaderProject = "X-Deckhouse-Project"
+)
+
+// Kind enumerates the supported --scope values.
+type Kind string
+
+const (
+	KindAccessible Kind = "accessible"
+	KindUser       Kind = "user"
+	KindSystem     Kind = "system"
+	KindProject    Kind = "project"
+)
+
+// Request is the parsed, validated scope request carried on a single API
+// call, decoded from the wire headers.
+type Request struct {
+	Kind    Kind
+	Project string // set only when Kind == KindProject
+}
+
+// ParseHeaders extracts a Request from the two scope headers.
+//
+// present is false when no scope header was sent at all -- the caller is not
+// asking for scope filtering, and callers of this function must treat that
+// identically to plain upstream behavior (no bypass, no filtering). This is
+// distinct from Request{Kind: KindAccessible}, which IS an explicit request,
+// just the broadest one available.
+func ParseHeaders(h http.Header) (req Request, present bool, err error) {
+	raw := h.Get(HeaderScope)
+	if raw == "" {
+		return Request{}, false, nil
+	}
+
+	kind := Kind(strings.ToLower(raw))
+	project := h.Get(HeaderProject)
+
+	switch kind {
+	case KindAccessible, KindUser, KindSystem:
+		if project != "" {
+			return Request{}, true, fmt.Errorf("scopefilter: %s header is only valid together with %s=%s", HeaderProject, HeaderScope, KindProject)
+		}
+		return Request{Kind: kind}, true, nil
+	case KindProject:
+		if project == "" {
+			return Request{}, true, fmt.Errorf("scopefilter: %s=%s requires the %s header", HeaderScope, KindProject, HeaderProject)
+		}
+		return Request{Kind: kind, Project: project}, true, nil
+	default:
+		return Request{}, true, fmt.Errorf("scopefilter: invalid %s value %q", HeaderScope, raw)
+	}
+}
+
+type requestContextKey struct{}
+
+// WithRequest returns a derivative context carrying the parsed scope
+// request. Production code reaches this via the authorization filter, which
+// parses the incoming headers once per request; tests use this helper
+// directly.
+func WithRequest(ctx context.Context, req Request) context.Context {
+	return context.WithValue(ctx, requestContextKey{}, req)
+}
+
+// RequestFrom reports the scope request tagged on ctx, if any. Its absence
+// means the caller did not send a scope header at all.
+func RequestFrom(ctx context.Context) (Request, bool) {
+	req, ok := ctx.Value(requestContextKey{}).(Request)
+	return req, ok
+}
+
+type bypassContextKey struct{}
+
+// WithBypass marks ctx as "RBAC denied this request, but the authorization
+// filter chose to hand it to the storage layer for ACL-based filtering
+// instead of returning 403". The storage layer reads this to decide whether
+// the RBAC safety floor (AccessibleNamespaces ∩ BulkSubjectAccessReview) must
+// be computed and intersected into the final result.
+//
+// This is intentionally independent from WithRequest: a fully privileged
+// caller can pass --scope=system purely to narrow their own view without
+// ever being denied by RBAC. In that case RequestFrom is set but IsBypass is
+// not, and the (expensive) RBAC floor is never computed -- only a denied,
+// bypassed caller pays that cost.
+func WithBypass(ctx context.Context) context.Context {
+	return context.WithValue(ctx, bypassContextKey{}, true)
+}
+
+// IsBypass reports whether ctx was tagged by WithBypass.
+func IsBypass(ctx context.Context) bool {
+	v, ok := ctx.Value(bypassContextKey{}).(bool)
+	return ok && v
+}
