+		path       string
+		header     string
+		wantBypass bool
+	}{
+		{
+			name:       "list registered resource with header bypasses",
+			method:     http.MethodGet,
+			path:       "/api/v1/widgets",
+			header:     "system",
+			wantBypass: true,
+		},
