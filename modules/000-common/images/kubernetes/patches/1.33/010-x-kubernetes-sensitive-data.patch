+// TestSensitiveDataValidation verifies the validation rules for x-kubernetes-sensitive-data marker.
+func TestSensitiveDataValidation(t *testing.T) {
+	tests := []struct {
+		name          string
+		gateEnabled   bool
+		schema        *apiextensions.JSONSchemaProps
+		expectErrors  []validationMatch
+		expectNoError bool
+	}{
+		// --- feature gate disabled ---
+		{
+			name:        "feature gate disabled: XSensitiveData on string field is rejected",
+			gateEnabled: false,
+			schema: &apiextensions.JSONSchemaProps{
+				Type: "object",
+				Properties: map[string]apiextensions.JSONSchemaProps{
+					"password": {Type: "string", XSensitiveData: true},
+				},
+			},
+			expectErrors: []validationMatch{
+				forbidden("spec", "validation", "openAPIV3Schema", "properties[password]", "x-kubernetes-sensitive-data"),
+			},
+		},
+		{
+			name:        "feature gate disabled: XSensitiveData on nested field is rejected",
+			gateEnabled: false,
+			schema: &apiextensions.JSONSchemaProps{
+				Type: "object",
+				Properties: map[string]apiextensions.JSONSchemaProps{
+					"spec": {
+						Type: "object",
+						Properties: map[string]apiextensions.JSONSchemaProps{
+							"token": {Type: "string", XSensitiveData: true},
+						},
+					},
+				},
+			},
+			expectErrors: []validationMatch{
+				forbidden("spec", "validation", "openAPIV3Schema", "properties[spec]", "properties[token]", "x-kubernetes-sensitive-data"),
+			},
+		},
+		// --- feature gate enabled: forbidden cases ---
+		{
+			name:        "feature gate enabled: XSensitiveData on root schema is rejected",
+			gateEnabled: true,
+			schema: &apiextensions.JSONSchemaProps{
+				Type:           "object",
+				XSensitiveData: true,
+				Properties: map[string]apiextensions.JSONSchemaProps{
+					"password": {Type: "string"},
+				},
+			},
+			expectErrors: []validationMatch{
+				forbidden("spec", "validation", "openAPIV3Schema", "x-kubernetes-sensitive-data"),
+			},
+		},
+		// --- feature gate enabled: allowed cases ---
+		{
+			name:        "feature gate enabled: XSensitiveData on string field is valid",
+			gateEnabled: true,
+			schema: &apiextensions.JSONSchemaProps{
+				Type: "object",
+				Properties: map[string]apiextensions.JSONSchemaProps{
+					"password": {Type: "string", XSensitiveData: true},
+				},
+			},
+			expectNoError: true,
+		},
+		{
+			name:        "feature gate enabled: XSensitiveData on integer field is valid",
+			gateEnabled: true,
+			schema: &apiextensions.JSONSchemaProps{
+				Type: "object",
+				Properties: map[string]apiextensions.JSONSchemaProps{
+					"pin": {Type: "integer", XSensitiveData: true},
+				},
+			},
+			expectNoError: true,
+		},
+		{
+			name:        "feature gate enabled: XSensitiveData on number field is valid",
+			gateEnabled: true,
+			schema: &apiextensions.JSONSchemaProps{
+				Type: "object",
+				Properties: map[string]apiextensions.JSONSchemaProps{
+					"coefficient": {Type: "number", XSensitiveData: true},
+				},
+			},
+			expectNoError: true,
+		},
+		{
+			name:        "feature gate enabled: XSensitiveData on boolean field is valid",
+			gateEnabled: true,
+			schema: &apiextensions.JSONSchemaProps{
+				Type: "object",
+				Properties: map[string]apiextensions.JSONSchemaProps{
+					"enabled": {Type: "boolean", XSensitiveData: true},
+				},
+			},
+			expectNoError: true,
+		},
+		{
+			name:        "feature gate enabled: XSensitiveData on object field (subtree) is valid",
+			gateEnabled: true,
+			schema: &apiextensions.JSONSchemaProps{
+				Type: "object",
+				Properties: map[string]apiextensions.JSONSchemaProps{
+					"credentials": {
+						Type:           "object",
+						XSensitiveData: true,
+						Properties: map[string]apiextensions.JSONSchemaProps{
+							"user":     {Type: "string"},
+							"password": {Type: "string"},
+						},
+					},
+				},
+			},
+			expectNoError: true,
+		},
+		{
+			name:        "feature gate enabled: XSensitiveData on array field (subtree) is valid",
+			gateEnabled: true,
+			schema: &apiextensions.JSONSchemaProps{
+				Type: "object",
+				Properties: map[string]apiextensions.JSONSchemaProps{
+					"keys": {
+						Type:           "array",
+						XSensitiveData: true,
+						Items: &apiextensions.JSONSchemaPropsOrArray{
+							Schema: &apiextensions.JSONSchemaProps{Type: "string"},
+						},
+					},
+				},
+			},
+			expectNoError: true,
+		},
+		{
+			name:        "feature gate enabled: XSensitiveData on nested string field is valid",
+			gateEnabled: true,
+			schema: &apiextensions.JSONSchemaProps{
+				Type: "object",
+				Properties: map[string]apiextensions.JSONSchemaProps{
+					"spec": {
+						Type: "object",
+						Properties: map[string]apiextensions.JSONSchemaProps{
+							"password": {Type: "string", XSensitiveData: true},
+							"apiKey":   {Type: "string", XSensitiveData: true},
+						},
+					},
+				},
+			},
+			expectNoError: true,
+		},
+		{
+			name:        "feature gate enabled: XSensitiveData on multiple fields at different depths is valid",
+			gateEnabled: true,
+			schema: &apiextensions.JSONSchemaProps{
+				Type: "object",
+				Properties: map[string]apiextensions.JSONSchemaProps{
+					"password": {Type: "string", XSensitiveData: true},
+					"tls": {
+						Type: "object",
+						Properties: map[string]apiextensions.JSONSchemaProps{
+							"key": {Type: "string", XSensitiveData: true},
+						},
+					},
+				},
+			},
+			expectNoError: true,
+		},
+		// --- anyOf cases ---
+		{
+			name:        "feature gate enabled: XSensitiveData on nested string field with anyOf is valid",
+			gateEnabled: true,
+			schema: &apiextensions.JSONSchemaProps{
+				Type: "object",
+				Properties: map[string]apiextensions.JSONSchemaProps{
+					"spec": {
+						Type: "object",
+						Properties: map[string]apiextensions.JSONSchemaProps{
+							"token": {
+								Type:           "string",
+								XSensitiveData: true,
+								AnyOf: []apiextensions.JSONSchemaProps{
+									{MinLength: func() *int64 { v := int64(16); return &v }()},
+								},
+							},
+						},
+					},
+				},
+			},
+			expectNoError: true,
+		},
+		{
+			name:        "feature gate disabled: XSensitiveData on anyOf field is rejected",
+			gateEnabled: false,
+			schema: &apiextensions.JSONSchemaProps{
+				Type: "object",
+				Properties: map[string]apiextensions.JSONSchemaProps{
+					"password": {
+						Type:           "string",
+						XSensitiveData: true,
+						AnyOf: []apiextensions.JSONSchemaProps{
+							{MinLength: func() *int64 { v := int64(8); return &v }()},
+						},
+					},
+				},
+			},
+			expectErrors: []validationMatch{
+				forbidden("spec", "validation", "openAPIV3Schema", "properties[password]", "x-kubernetes-sensitive-data"),
+			},
+		},
+		{
+			name:        "feature gate enabled: XSensitiveData inside anyOf branch is rejected",
+			gateEnabled: true,
+			schema: &apiextensions.JSONSchemaProps{
+				Type: "object",
+				Properties: map[string]apiextensions.JSONSchemaProps{
+					"password": {
+						Type: "string",
+						AnyOf: []apiextensions.JSONSchemaProps{
+							{XSensitiveData: true},
+						},
+					},
+				},
+			},
+			expectErrors: []validationMatch{
+				forbidden("spec", "validation", "openAPIV3Schema", "properties[password]", "anyOf[0]", "x-kubernetes-sensitive-data"),
+			},
+		},
+		// --- x-kubernetes-int-or-string cases ---
+		{
+			// x-kubernetes-int-or-string is the one structural-schema exception where type IS
+			// allowed inside anyOf. Combined with XSensitiveData the field should be accepted.
+			name:        "feature gate enabled: XSensitiveData on int-or-string field with anyOf pattern is valid",
+			gateEnabled: true,
+			schema: &apiextensions.JSONSchemaProps{
+				Type: "object",
+				Properties: map[string]apiextensions.JSONSchemaProps{
+					"portOrName": {
+						XIntOrString:   true,
+						XSensitiveData: true,
+						AnyOf: []apiextensions.JSONSchemaProps{
+							{Type: "integer"},
+							{Type: "string"},
+						},
+					},
+				},
+			},
+			expectNoError: true,
+		},
+		{
+			// x-kubernetes-int-or-string without anyOf is also valid structurally.
+			name:        "feature gate enabled: XSensitiveData on int-or-string field without anyOf is valid",
+			gateEnabled: true,
+			schema: &apiextensions.JSONSchemaProps{
+				Type: "object",
+				Properties: map[string]apiextensions.JSONSchemaProps{
+					"portOrName": {
+						XIntOrString:   true,
+						XSensitiveData: true,
+					},
+				},
+			},
+			expectNoError: true,
+		},
+		{
+			name:        "feature gate disabled: XSensitiveData on int-or-string field is rejected",
+			gateEnabled: false,
+			schema: &apiextensions.JSONSchemaProps{
+				Type: "object",
+				Properties: map[string]apiextensions.JSONSchemaProps{
+					"portOrName": {
+						XIntOrString:   true,
+						XSensitiveData: true,
+						AnyOf: []apiextensions.JSONSchemaProps{
+							{Type: "integer"},
+							{Type: "string"},
+						},
+					},
+				},
+			},
+			expectErrors: []validationMatch{
+				forbidden("spec", "validation", "openAPIV3Schema", "properties[portOrName]", "x-kubernetes-sensitive-data"),
+			},
+		},
+	}
+
+	for _, tc := range tests {
+		t.Run(tc.name, func(t *testing.T) {
+			featuregatetesting.SetFeatureGateDuringTest(t, utilfeature.DefaultFeatureGate, apiextensionsfeatures.CRDSensitiveData, tc.gateEnabled)
+
+			crd := makeSensitiveCRD(tc.schema)
+			errs := ValidateCustomResourceDefinition(context.TODO(), crd)
+
+			if tc.expectNoError {
+				if len(errs) > 0 {
+					t.Errorf("expected no errors, got: %v", errs)
+				}
+				return
+			}
+
+			seenErrs := make([]bool, len(errs))
+			for _, expectedError := range tc.expectErrors {
+				found := false
+				for i, err := range errs {
+					if expectedError.matches(err) && !seenErrs[i] {
+						found = true
+						seenErrs[i] = true
+						break
+					}
+				}
+				if !found {
+					t.Errorf("expected %v at %v, got %v", expectedError.errorType, expectedError.path.String(), errs)
+				}
+			}
+			for i, seen := range seenErrs {
+				if !seen {
+					t.Errorf("unexpected error: %v", errs[i])
+				}
+			}
+		})
+	}
+}
