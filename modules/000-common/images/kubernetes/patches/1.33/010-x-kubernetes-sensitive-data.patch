+// MaskedValue is the replacement string used by MaskSensitiveFields.
+const MaskedValue = "******"
+
+var metaFields = map[string]bool{
+	"apiVersion": true,
+	"kind":       true,
+	"metadata":   true,
+}
+
+// HasSensitiveFields returns true if the schema contains at least one field
+// with XSensitiveData == true anywhere in the tree.
+func HasSensitiveFields(s *structuralschema.Structural) bool {
+	if s == nil {
+		return false
+	}
+	if s.XSensitiveData {
+		return true
+	}
+	if s.Items != nil && HasSensitiveFields(s.Items) {
+		return true
+	}
+	for _, prop := range s.Properties {
+		if HasSensitiveFields(&prop) {
+			return true
+		}
+	}
+	if s.AdditionalProperties != nil && s.AdditionalProperties.Structural != nil {
+		if HasSensitiveFields(s.AdditionalProperties.Structural) {
+			return true
+		}
+	}
+	return false
+}
+
+// CollectSensitivePaths returns a sorted list of JSON paths for all fields in the
+// schema that have XSensitiveData == true (e.g. ".spec.password", ".spec.tls.key").
+func CollectSensitivePaths(s *structuralschema.Structural) []string {
+	paths := collectSensitivePaths(s, "")
+	sort.Strings(paths)
+	return paths
+}
+
+// StripSensitiveFields removes all sensitive fields from the unstructured object in-place.
+// It skips TypeMeta and ObjectMeta fields if XEmbeddedResource is set to true, or for the
+// root if isResourceRoot=true, following the same convention as pruning.Prune.
+func StripSensitiveFields(obj interface{}, s *structuralschema.Structural, isResourceRoot bool) {
+	s = withResourceRoot(s, isResourceRoot)
+	processSensitive(obj, s, true)
+}
+
+// MaskSensitiveFields replaces all sensitive field values with MaskedValue ("******") in-place.
+// It skips TypeMeta and ObjectMeta fields if XEmbeddedResource is set to true, or for the
+// root if isResourceRoot=true, following the same convention as pruning.Prune.
+func MaskSensitiveFields(obj interface{}, s *structuralschema.Structural, isResourceRoot bool) {
+	s = withResourceRoot(s, isResourceRoot)
+	processSensitive(obj, s, false)
+}
+
+// withResourceRoot normalizes isResourceRoot into XEmbeddedResource on the schema,
+// following the same pattern as pruning.PruneWithOptions.
+func withResourceRoot(s *structuralschema.Structural, isResourceRoot bool) *structuralschema.Structural {
+	if !isResourceRoot {
+		return s
+	}
+	if s == nil {
+		s = &structuralschema.Structural{}
+	}
+	if !s.XEmbeddedResource {
+		clone := *s
+		clone.XEmbeddedResource = true
+		s = &clone
+	}
+	return s
+}
+
+func collectSensitivePaths(s *structuralschema.Structural, path string) []string {
+	if s == nil {
+		return nil
+	}
+	var paths []string
+	if s.XSensitiveData {
+		if path == "" {
+			paths = append(paths, ".")
+		} else {
+			paths = append(paths, path)
+		}
+	}
+	for name, prop := range s.Properties {
+		paths = append(paths, collectSensitivePaths(&prop, path+"."+name)...)
+	}
+	if s.Items != nil {
+		paths = append(paths, collectSensitivePaths(s.Items, path+"[]")...)
+	}
+	if s.AdditionalProperties != nil && s.AdditionalProperties.Structural != nil {
+		paths = append(paths, collectSensitivePaths(s.AdditionalProperties.Structural, path+"[*]")...)
+	}
+	return paths
+}
+
+func processSensitive(obj interface{}, s *structuralschema.Structural, strip bool) {
+	if s == nil || obj == nil {
+		return
+	}
+	switch x := obj.(type) {
+	case map[string]interface{}:
+		for k, v := range x {
+			if s.XEmbeddedResource && metaFields[k] {
+				continue
+			}
+			if prop, ok := s.Properties[k]; ok {
+				if prop.XSensitiveData {
+					if strip {
+						delete(x, k)
+					} else {
+						x[k] = MaskedValue
+					}
+					continue
+				}
+				processSensitive(v, &prop, strip)
+			} else if s.AdditionalProperties != nil && s.AdditionalProperties.Structural != nil {
+				ap := s.AdditionalProperties.Structural
+				if ap.XSensitiveData {
+					if strip {
+						delete(x, k)
+					} else {
+						x[k] = MaskedValue
+					}
+					continue
+				}
+				processSensitive(v, ap, strip)
+			}
+		}
+	case []interface{}:
+		if s.Items == nil {
+			return
+		}
+		if s.Items.XSensitiveData {
+			for i := range x {
+				if strip {
+					x[i] = nil
+				} else {
+					x[i] = MaskedValue
+				}
+			}
+			return
+		}
+		for _, v := range x {
+			processSensitive(v, s.Items, strip)
+		}
+	}
+}
