+			}()
+			return
 		}
 	}
 	if mirrorPod == nil || deleted {
diff --git a/pkg/kubelet/pod/mirror_client.go b/pkg/kubelet/pod/mirror_client.go
index 22ea62b1a31..9777cf30b2e 100644
--- a/pkg/kubelet/pod/mirror_client.go
+++ b/pkg/kubelet/pod/mirror_client.go
@@ -19,6 +19,7 @@ package pod
 import (
 	"context"
 	"fmt"
+	"sync"
 
 	v1 "k8s.io/api/core/v1"
 	apierrors "k8s.io/apimachinery/pkg/api/errors"
@@ -55,6 +56,11 @@ type basicMirrorClient struct {
 	apiserverClient clientset.Interface
 	nodeGetter      nodeGetter
 	nodeName        string
+	// deletingPods tracks pods for which a DeleteMirrorPod call is already
+	// in-flight. Keys are "namespace/name/uid" strings. This prevents
+	// duplicate concurrent DELETEs when tryReconcileMirrorPods fires on every
+	// SyncPod tick while the API server is temporarily unavailable.
+	deletingPods sync.Map
 }
 
 // NewBasicMirrorClient returns a new MirrorClient.
@@ -127,6 +133,16 @@ func (mc *basicMirrorClient) DeleteMirrorPod(podFullName string, uid *types.UID)
 	if uid != nil {
 		uidValue = *uid
 	}
+
+	// Deduplicate concurrent calls for the same pod: if a DELETE is already
+	// in-flight (e.g. from a previous SyncPod tick while the API server was
+	// unavailable), skip issuing another one.
+	sfKey := podFullName + "/" + string(uidValue)
+	if _, loaded := mc.deletingPods.LoadOrStore(sfKey, struct{}{}); loaded {
+		return false, nil
+	}
+	defer mc.deletingPods.Delete(sfKey)
+
 	klog.V(2).InfoS("Deleting a mirror pod", "pod", klog.KRef(namespace, name), "podUID", uidValue)
 
 	var GracePeriodSeconds int64
