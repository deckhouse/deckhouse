-				klog.InfoS("Deleted mirror pod as it didn't match the static Pod", "pod", klog.KObj(mirrorPod))
-			}
+			mirrorPodRef := mirrorPod
+			go func() {
+				if _, err := kl.mirrorPodClient.DeleteMirrorPod(podFullName, &mirrorPodRef.UID); err != nil {
+					klog.ErrorS(err, "Failed deleting mirror pod", "pod", klog.KObj(mirrorPodRef))
+				} else {
+					klog.InfoS("Deleted mirror pod as it didn't match the static Pod", "pod", klog.KObj(mirrorPodRef))
