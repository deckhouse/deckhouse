+// TestSchemaHasKubernetesExtensionsWithSensitiveData verifies that schemaHasKubernetesExtensions
+// correctly detects XSensitiveData.
+func TestSchemaHasKubernetesExtensionsWithSensitiveData(t *testing.T) {
+	tests := []struct {
+		name   string
+		schema *apiextensions.JSONSchemaProps
+		want   bool
+	}{
+		{
+			name: "schema without XSensitiveData returns false",
+			schema: &apiextensions.JSONSchemaProps{
+				Type: "object",
+				Properties: map[string]apiextensions.JSONSchemaProps{
+					"foo": {Type: "string"},
+				},
+			},
+			want: false,
+		},
+		{
+			name: "schema with XSensitiveData on a property returns true",
+			schema: &apiextensions.JSONSchemaProps{
+				Type: "object",
+				Properties: map[string]apiextensions.JSONSchemaProps{
+					"password": {Type: "string", XSensitiveData: true},
+				},
+			},
+			want: true,
+		},
+		{
+			name: "schema with XSensitiveData deep in the tree returns true",
+			schema: &apiextensions.JSONSchemaProps{
+				Type: "object",
+				Properties: map[string]apiextensions.JSONSchemaProps{
+					"spec": {
+						Type: "object",
+						Properties: map[string]apiextensions.JSONSchemaProps{
+							"nested": {
+								Type: "object",
+								Properties: map[string]apiextensions.JSONSchemaProps{
+									"secret": {Type: "string", XSensitiveData: true},
+								},
+							},
+						},
+					},
+				},
+			},
+			want: true,
+		},
+		{
+			name:   "nil schema returns false",
+			schema: nil,
+			want:   false,
+		},
+	}
+
+	for _, tc := range tests {
+		t.Run(tc.name, func(t *testing.T) {
+			got := schemaHasKubernetesExtensions(tc.schema)
+			if got != tc.want {
+				t.Errorf("schemaHasKubernetesExtensions() = %v, want %v", got, tc.want)
+			}
+		})
+	}
+}
