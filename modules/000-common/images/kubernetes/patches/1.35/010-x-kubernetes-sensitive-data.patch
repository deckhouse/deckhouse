+	secretsGR := schema.GroupResource{Group: "", Resource: "secrets"}
+	crdGR := schema.GroupResource{Group: "example.com", Resource: "databases"}
+
+	secretsTransformer := value.PrefixTransformer{Prefix: []byte("k8s:enc:test:"), Transformer: &identityTransformer{}}
+	overrides := map[schema.GroupResource]value.Transformer{
+		secretsGR: value.NewPrefixTransformers(nil, secretsTransformer),
+	}
+
+	dt := NewDynamicTransformers(overrides, nil, func() {}, 0)
+
+	t.Run("unregistered sensitive resource falls through to identity", func(t *testing.T) {
+		transformer := dt.TransformerForResource(crdGR)
+		out, err := transformer.TransformToStorage(context.Background(), []byte("data"), value.DefaultContext(nil))
+		if err != nil {
+			t.Fatal(err)
+		}
+		if !bytes.Equal(out, []byte("data")) {
+			t.Errorf("expected identity (no-op) transformer, got output %q", string(out))
+		}
+	})
+
+	t.Run("registered sensitive resource uses secrets transformer", func(t *testing.T) {
+		dt.RegisterSensitiveResource(crdGR)
+
+		transformer := dt.TransformerForResource(crdGR)
+		out, err := transformer.TransformToStorage(context.Background(), []byte("data"), value.DefaultContext(nil))
+		if err != nil {
+			t.Fatal(err)
+		}
+		if !bytes.HasPrefix(out, []byte("k8s:enc:test:")) {
+			t.Errorf("expected secrets transformer prefix, got output %q", string(out))
+		}
+	})
+
+	t.Run("unregistered sensitive resource reverts to identity", func(t *testing.T) {
+		dt.UnregisterSensitiveResource(crdGR)
+
+		transformer := dt.TransformerForResource(crdGR)
+		out, err := transformer.TransformToStorage(context.Background(), []byte("data"), value.DefaultContext(nil))
+		if err != nil {
+			t.Fatal(err)
+		}
+		if !bytes.Equal(out, []byte("data")) {
+			t.Errorf("expected identity transformer after unregister, got output %q", string(out))
+		}
+	})
+}
+
+func TestTransformerFromOverridesWithSensitiveResources(t *testing.T) {
+	secretsGR := schema.GroupResource{Group: "", Resource: "secrets"}
+	crdGR := schema.GroupResource{Group: "example.com", Resource: "databases"}
+	explicitGR := schema.GroupResource{Group: "example.com", Resource: "configs"}
+
+	secretsTransformer := value.PrefixTransformer{Prefix: []byte("k8s:enc:secrets:"), Transformer: &identityTransformer{}}
+	explicitTransformer := value.PrefixTransformer{Prefix: []byte("k8s:enc:explicit:"), Transformer: &identityTransformer{}}
+
+	overrides := map[schema.GroupResource]value.Transformer{
+		secretsGR:  value.NewPrefixTransformers(nil, secretsTransformer),
+		explicitGR: value.NewPrefixTransformers(nil, explicitTransformer),
+	}
+
+	sensitiveResources := &sync.Map{}
+	sensitiveResources.Store(crdGR, struct{}{})
+	sensitiveResources.Store(explicitGR, struct{}{})
+
+	t.Run("sensitive resource with no explicit override gets secrets transformer", func(t *testing.T) {
+		transformer := transformerFromOverrides(overrides, crdGR, sensitiveResources)
+		out, err := transformer.TransformToStorage(context.Background(), []byte("data"), value.DefaultContext(nil))
+		if err != nil {
+			t.Fatal(err)
+		}
+		if !bytes.HasPrefix(out, []byte("k8s:enc:secrets:")) {
+			t.Errorf("expected secrets transformer, got %q", string(out))
+		}
+	})
+
+	t.Run("explicit override takes precedence over sensitive registration", func(t *testing.T) {
+		transformer := transformerFromOverrides(overrides, explicitGR, sensitiveResources)
+		out, err := transformer.TransformToStorage(context.Background(), []byte("data"), value.DefaultContext(nil))
+		if err != nil {
+			t.Fatal(err)
+		}
+		if !bytes.HasPrefix(out, []byte("k8s:enc:explicit:")) {
+			t.Errorf("expected explicit transformer, got %q", string(out))
+		}
+	})
+
+	t.Run("non-sensitive resource without override gets identity", func(t *testing.T) {
+		otherGR := schema.GroupResource{Group: "other.io", Resource: "things"}
+		transformer := transformerFromOverrides(overrides, otherGR, sensitiveResources)
+		out, err := transformer.TransformToStorage(context.Background(), []byte("data"), value.DefaultContext(nil))
+		if err != nil {
+			t.Fatal(err)
+		}
+		if !bytes.Equal(out, []byte("data")) {
+			t.Errorf("expected identity transformer, got %q", string(out))
+		}
+	})
+
+	t.Run("nil sensitiveResources is safe", func(t *testing.T) {
+		transformer := transformerFromOverrides(overrides, crdGR, nil)
+		out, err := transformer.TransformToStorage(context.Background(), []byte("data"), value.DefaultContext(nil))
+		if err != nil {
+			t.Fatal(err)
+		}
+		if !bytes.Equal(out, []byte("data")) {
+			t.Errorf("expected identity transformer with nil sensitiveResources, got %q", string(out))
+		}
+	})
+
+	t.Run("sensitive resource without secrets config gets identity", func(t *testing.T) {
+		emptyOverrides := map[schema.GroupResource]value.Transformer{}
+		transformer := transformerFromOverrides(emptyOverrides, crdGR, sensitiveResources)
+		out, err := transformer.TransformToStorage(context.Background(), []byte("data"), value.DefaultContext(nil))
+		if err != nil {
+			t.Fatal(err)
+		}
+		if !bytes.Equal(out, []byte("data")) {
+			t.Errorf("expected identity when secrets not configured, got %q", string(out))
+		}
+	})
+}
+
+type identityTransformer struct{}
+
+func (t *identityTransformer) TransformFromStorage(ctx context.Context, data []byte, dataCtx value.Context) ([]byte, bool, error) {
+	return data, false, nil
+}
+
+func (t *identityTransformer) TransformToStorage(ctx context.Context, data []byte, dataCtx value.Context) ([]byte, error) {
+	return data, nil
+}
