+// newSensitiveMaskingTransformer returns an ObjectTransformer that masks sensitive fields
+// in Unstructured objects using the provided structural schema.
+func newSensitiveMaskingTransformer(schema *structuralschema.Structural) audit.ObjectTransformer {
+	return func(obj runtime.Object) runtime.Object {
+		defer func() {
+			if r := recover(); r != nil {
+				klog.Errorf("Recovered from panic in sensitive masking transformer: %v", r)
+			}
+		}()
+
+		obj = obj.DeepCopyObject()
+
+		switch t := obj.(type) {
+		case *unstructured.Unstructured:
+			sensitive.MaskSensitiveFields(t.Object, schema, true)
+			maskLastAppliedConfigAnnotation(t.Object, []*structuralschema.Structural{schema})
+		case *unstructured.UnstructuredList:
+			for i := range t.Items {
+				sensitive.MaskSensitiveFields(t.Items[i].Object, schema, true)
+				maskLastAppliedConfigAnnotation(t.Items[i].Object, []*structuralschema.Structural{schema})
+			}
+		}
+		return obj
+	}
+}
+
+// maskLastAppliedConfigAnnotation parses the last-applied-configuration annotation,
+// applies MaskSensitiveFields for each schema, and writes the masked JSON back.
+func maskLastAppliedConfigAnnotation(obj map[string]interface{}, schemas []*structuralschema.Structural) {
+	metadata, ok := obj["metadata"].(map[string]interface{})
+	if !ok {
+		return
+	}
+	annotations, ok := metadata["annotations"].(map[string]interface{})
+	if !ok {
+		return
+	}
+	raw, ok := annotations[corev1.LastAppliedConfigAnnotation].(string)
+	if !ok || raw == "" {
+		return
+	}
+
+	var parsed map[string]interface{}
+	if err := json.Unmarshal([]byte(raw), &parsed); err != nil {
+		return
+	}
+
+	for _, s := range schemas {
+		sensitive.MaskSensitiveFields(parsed, s, true)
+	}
+
+	masked, err := json.Marshal(parsed)
+	if err != nil {
+		return
+	}
+	annotations[corev1.LastAppliedConfigAnnotation] = string(masked)
+}
+
+// newSensitivePatchTransformer returns a PatchTransformer that masks sensitive fields
+// in patch payloads using the provided structural schema.
+func newSensitivePatchTransformer(schema *structuralschema.Structural) audit.PatchTransformer {
+	sensitivePaths := sensitive.CollectSensitivePaths(schema)
+
+	return func(patchBytes []byte, contentType string) []byte {
+		defer func() {
+			if r := recover(); r != nil {
+				klog.Errorf("Recovered from panic in sensitive patch transformer: %v", r)
+			}
+		}()
+
+		switch contentType {
+		case "application/json-patch+json":
+			return maskJSONPatch(patchBytes, sensitivePaths)
+		case "application/merge-patch+json":
+			return maskMergePatch(patchBytes, schema)
+		case "application/apply-patch+yaml":
+			return maskSSAPatchYAML(patchBytes, schema)
+		case "application/apply-patch+cbor":
+			return maskSSAPatchCBOR(patchBytes, schema)
+		default:
+			// Unknown content type, attempt merge-patch masking as fallback
+			return maskMergePatch(patchBytes, schema)
+		}
+	}
+}
+
+// maskJSONPatch masks values in JSON Patch operations whose paths target sensitive fields.
+func maskJSONPatch(patchBytes []byte, sensitivePaths []string) []byte {
+	var ops []map[string]interface{}
+	if err := json.Unmarshal(patchBytes, &ops); err != nil {
+		return redactedPatchBytes()
+	}
+
+	// Build a set of sensitive JSON Pointer prefixes from the dot-notation paths.
+	sensitivePointers := make(map[string]bool, len(sensitivePaths))
+	for _, p := range sensitivePaths {
+		pointer := dotPathToJSONPointer(p)
+		sensitivePointers[pointer] = true
+	}
+
+	modified := false
+	for i, op := range ops {
+		path, ok := op["path"].(string)
+		if !ok {
+			continue
+		}
+		if isSensitiveJSONPointer(path, sensitivePointers) {
+			if _, hasValue := op["value"]; hasValue {
+				ops[i]["value"] = sensitive.MaskedValue
+				modified = true
+			}
+		}
+	}
+
+	if !modified {
+		return patchBytes
+	}
+
+	result, err := json.Marshal(ops)
+	if err != nil {
+		return redactedPatchBytes()
+	}
+	return result
+}
+
+// maskMergePatch masks sensitive fields in a JSON merge patch.
+func maskMergePatch(patchBytes []byte, schema *structuralschema.Structural) []byte {
+	var patch map[string]interface{}
+	if err := json.Unmarshal(patchBytes, &patch); err != nil {
+		return redactedPatchBytes()
+	}
+
+	sensitive.MaskSensitiveFields(patch, schema, true)
+
+	result, err := json.Marshal(patch)
+	if err != nil {
+		return redactedPatchBytes()
+	}
+	return result
+}
+
+// maskSSAPatchYAML masks sensitive fields in an SSA (server-side apply) YAML patch.
+func maskSSAPatchYAML(patchBytes []byte, schema *structuralschema.Structural) []byte {
+	var patch map[string]interface{}
+	if err := yaml.Unmarshal(patchBytes, &patch); err != nil {
+		return redactedPatchBytes()
+	}
+
+	sensitive.MaskSensitiveFields(patch, schema, true)
+
+	result, err := json.Marshal(patch)
+	if err != nil {
+		return redactedPatchBytes()
+	}
+	return result
+}
+
+// maskSSAPatchCBOR masks sensitive fields in an SSA (server-side apply) CBOR patch.
+// CBOR decoding requires specific handling, so we redact the patch entirely.
+// CBOR patches in audit are rare; for safety, redact them entirely
+// rather than introducing a CBOR dependency here.
+func maskSSAPatchCBOR(patchBytes []byte, schema *structuralschema.Structural) []byte {
+	return redactedPatchBytes()
+}
+
+// redactedPatchBytes returns a JSON fallback indicating the patch was redacted.
+func redactedPatchBytes() []byte {
+	return []byte(`{"redacted":"patch contains sensitive fields"}`)
+}
+
+// dotPathToJSONPointer converts a dot-notation path to a JSON Pointer
+func dotPathToJSONPointer(dotPath string) string {
+	dotPath = strings.TrimPrefix(dotPath, ".")
+	if dotPath == "" {
+		return "/" // root
+	}
+	return "/" + strings.ReplaceAll(dotPath, ".", "/") // e.g. .spec.password -> /spec/password
+}
+
+// isSensitiveJSONPointer checks if the given JSON Pointer targets a sensitive field.
+// It checks both exact match and prefix match (for nested operations).
+func isSensitiveJSONPointer(pointer string, sensitivePointers map[string]bool) bool {
+	if sensitivePointers[pointer] {
+		return true
+	}
+	// Check if the pointer is a child of a sensitive path
+	for sp := range sensitivePointers {
+		if strings.HasPrefix(pointer, sp+"/") {
+			return true
+		}
+	}
+	return false
+}
