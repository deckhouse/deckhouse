        }
      ],
      "status": "not_affected",
      "justification": "vulnerable_code_not_present",
      "impact_statement": "Уязвимость CVE-2026-39828 невозможно эксплуатировать в рамках Deckhouse: импорта golang.org/x/crypto/ssh в control-plane-manager нет; компонент не является SSH-сервером и не использует auth через PartialSuccessError.",
      "timestamp": "2026-07-21T10:25:00Z"
    },
    {
      "vulnerability": {
        "name": "CVE-2026-39829"
      },
