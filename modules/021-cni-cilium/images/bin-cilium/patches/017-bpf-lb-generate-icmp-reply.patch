+// LBICMPReplyHandleSvcDecrement decrements the port=0 ICMP entry's service-port
+// count when a LoadBalancer service-port is deleted. If the count reaches zero,
+// the port=0 entry is removed from the BPF map.
+func LBICMPReplyHandleSvcDecrement(svc loadbalancer.L3n4AddrID, svcType loadbalancer.SVCType, ipv6 bool) {
+	if svc.Port == 0 || svcType != loadbalancer.SVCTypeLoadBalancer {
+		return
+	}
+
+	var portZeroKey ServiceKey
+	if ipv6 {
+		portZeroKey = NewService6Key(svc.AddrCluster.AsNetIP(), 0, ICMPProto, svc.Scope, 0)
+	} else {
+		portZeroKey = NewService4Key(svc.AddrCluster.AsNetIP(), 0, ICMPProto, svc.Scope, 0)
+	}
+
+	existingValue, err := portZeroKey.Map().Lookup(portZeroKey.ToNetwork())
+	if err != nil {
+		if errors.Is(err, ebpf.ErrKeyNotExist) {
+			log.WithFields(logrus.Fields{
+				logfields.ServiceKey: portZeroKey,
+			}).Debug("LoadBalancerICMPReply ICMP instance does not exist, Nothing to handle")
+		} else {
+			log.WithFields(logrus.Fields{
+				logfields.ServiceKey: portZeroKey,
+			}).WithError(err).Warn("LoadBalancerICMPReply Unable to lookup ICMP instance")
+		}
+		return
+	}
+
+	existingValueHost := existingValue.(ServiceValue).ToHost()
+	newCount := existingValueHost.GetCount() - 1
+
+	if newCount <= 0 {
+		// No more service-ports behind this IP — remove the ICMP entry.
+		if err := deleteServiceLocked(portZeroKey); err != nil {
+			log.WithFields(logrus.Fields{
+				logfields.ServiceKey: portZeroKey,
+			}).WithError(err).Warn("LoadBalancerICMPReply Unable to delete ICMP key after decrement")
+		}
+	} else {
+		existingValueHost.SetCount(newCount)
+		if err := portZeroKey.Map().Update(portZeroKey.ToNetwork(), existingValueHost.ToNetwork()); err != nil {
+			log.WithFields(logrus.Fields{
+				logfields.ServiceKey: portZeroKey,
+			}).WithError(err).Warn("LoadBalancerICMPReply Unable to update ICMP key count after decrement")
+		}
+	}
+}
+
+// lbICMPReplyHandleSvcIncrement increments the port=0 ICMP entry's service-port
+// count when a new LoadBalancer service-port is first written to the BPF map.
+// If the port=0 entry does not exist yet, it is created with Count=1.
+func lbICMPReplyHandleSvcIncrement(fe ServiceKey, svcType loadbalancer.SVCType) error {
+	if svcType != loadbalancer.SVCTypeLoadBalancer || fe.GetPort() == 0 {
+		return nil
+	}
+
+	// Only act when the service-port key is new (not yet in the BPF map).
+	_, lookupErr := fe.Map().Lookup(fe.ToNetwork())
+	if lookupErr == nil {
+		return nil
+	}
+
+	var portZeroKey ServiceKey
+	if fe.IsIPv6() {
+		portZeroKey = NewService6Key(fe.GetAddress(), 0, ICMPProto, fe.GetScope(), 0)
+	} else {
+		portZeroKey = NewService4Key(fe.GetAddress(), 0, ICMPProto, fe.GetScope(), 0)
+	}
+
+	existingValue, err := portZeroKey.Map().Lookup(portZeroKey.ToNetwork())
+	if err != nil {
+		if !errors.Is(err, ebpf.ErrKeyNotExist) {
+			return fmt.Errorf("EnableLoadBalancerICMPReply unable to lookup ICMP key: %w", err)
+		}
+
+		// Port=0 key doesn't exist yet — create it with Count=1.
+		var portZeroValue ServiceValue
+		if fe.IsIPv6() {
+			portZeroValue = &Service6Value{}
+		} else {
+			portZeroValue = &Service4Value{}
+		}
+		portZeroValue.SetCount(1)
+		portZeroValue.SetRevNat(0)
+		portZeroValue.SetFlags(0)
+		portZeroValue.SetQCount(0)
+		if err := portZeroKey.Map().Update(portZeroKey.ToNetwork(), portZeroValue.ToNetwork()); err != nil {
+			return fmt.Errorf("EnableLoadBalancerICMPReply unable to create ICMP key: %w", err)
+		}
+		return nil
+	}
+
+	// Port=0 key already exists — increment its Count.
+	existingValueHost := existingValue.(ServiceValue).ToHost()
+	existingValueHost.SetCount(existingValueHost.GetCount() + 1)
+	if err := portZeroKey.Map().Update(portZeroKey.ToNetwork(), existingValueHost.ToNetwork()); err != nil {
+		return fmt.Errorf("EnableLoadBalancerICMPReply unable to increment ICMP key count: %w", err)
+	}
+	return nil
+}
