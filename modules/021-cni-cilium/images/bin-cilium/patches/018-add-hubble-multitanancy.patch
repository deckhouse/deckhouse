diff --git a/hubble/cmd/common/conn/kube_token.go b/hubble/cmd/common/conn/kube_token.go
new file mode 100644
index 0000000000..a09e8518d5
--- /dev/null
+++ b/hubble/cmd/common/conn/kube_token.go
@@ -0,0 +1,66 @@
+// SPDX-License-Identifier: Apache-2.0
+// Copyright Authors of Hubble
+
+package conn
+
+import (
+	"fmt"
+	"net/http"
+	"os"
+	"strings"
+
+	"github.com/spf13/viper"
+	"k8s.io/client-go/tools/clientcmd"
+	"k8s.io/client-go/transport"
+
+	"github.com/cilium/cilium/hubble/cmd/common/config"
+)
+
+// kubeBearerTokenFromConfig returns a bearer token using the current kubeconfig (static token,
+// token file, or exec auth plugins).
+func kubeBearerTokenFromConfig(vp *viper.Viper) (string, error) {
+	loadingRules := clientcmd.NewDefaultClientConfigLoadingRules()
+	if p := vp.GetString(config.KeyKubeconfig); p != "" {
+		loadingRules.ExplicitPath = p
+	}
+	overrides := &clientcmd.ConfigOverrides{}
+	if ctx := vp.GetString(config.KeyKubeContext); ctx != "" {
+		overrides.CurrentContext = ctx
+	}
+	clientcfg := clientcmd.NewNonInteractiveDeferredLoadingClientConfig(loadingRules, overrides)
+	cfg, err := clientcfg.ClientConfig()
+	if err != nil {
+		return "", err
+	}
+	if cfg.BearerToken != "" {
+		return cfg.BearerToken, nil
+	}
+	if cfg.BearerTokenFile != "" {
+		b, err := os.ReadFile(cfg.BearerTokenFile)
+		if err != nil {
+			return "", err
+		}
+		return strings.TrimSpace(string(b)), nil
+	}
+	tc, err := cfg.TransportConfig()
+	if err != nil {
+		return "", err
+	}
+	rt, err := transport.New(tc)
+	if err != nil {
+		return "", err
+	}
+	req, err := http.NewRequest(http.MethodGet, strings.TrimRight(cfg.Host, "/")+"/version", nil)
+	if err != nil {
+		return "", err
+	}
+	_, err = rt.RoundTrip(req)
+	if err != nil {
+		return "", fmt.Errorf("kube exec auth: %w", err)
+	}
+	auth := strings.TrimSpace(req.Header.Get("Authorization"))
+	if len(auth) > 7 && strings.EqualFold(auth[:7], "bearer ") {
+		return strings.TrimSpace(auth[7:]), nil
+	}
+	return "", fmt.Errorf("kubeconfig: no bearer token could be resolved (use --bearer-token)")
+}
diff --git a/pkg/hubble/relay/authz/authorizer.go b/pkg/hubble/relay/authz/authorizer.go
new file mode 100644
index 0000000000..5077f5d895
--- /dev/null
+++ b/pkg/hubble/relay/authz/authorizer.go
@@ -0,0 +1,149 @@
+// SPDX-License-Identifier: Apache-2.0
+// Copyright Authors of Cilium
+
+package authz
+
+import (
+	"context"
+	"fmt"
+	"sync"
+	"time"
+
+	authenticationv1 "k8s.io/api/authentication/v1"
+	metav1 "k8s.io/apimachinery/pkg/apis/meta/v1"
+	"k8s.io/client-go/kubernetes"
+	"k8s.io/client-go/rest"
+)
+
+// AuthResult holds authorization outcome for a client token.
+type AuthResult struct {
+	UserInfo          *authenticationv1.UserInfo
+	AllowedNamespaces map[string]struct{}
+	IsAdmin           bool
+}
+
+// Authorizer performs TokenReview, cluster-admin detection, and per-namespace SAR with caching.
+type Authorizer struct {
+	restCfg   *rest.Config
+	relayKube kubernetes.Interface
+	sarCache  *sarCache
+	ttl       time.Duration
+
+	mu          sync.Mutex
+	fullResults map[string]fullResultEntry
+}
+
+type fullResultEntry struct {
+	res     AuthResult
+	expires time.Time
+}
+
+// NewAuthorizer builds an Authorizer. relayCfg is the in-cluster (relay SA) REST config;
+// relayKube must be built from relayCfg.
+func NewAuthorizer(relayCfg *rest.Config, relayKube kubernetes.Interface, ttl time.Duration) *Authorizer {
+	if ttl <= 0 {
+		ttl = 30 * time.Second
+	}
+	return &Authorizer{
+		restCfg:     relayCfg,
+		relayKube:   relayKube,
+		sarCache:    newSARCache(ttl),
+		ttl:         ttl,
+		fullResults: make(map[string]fullResultEntry),
+	}
+}
+
+// Stop releases background resources.
+func (a *Authorizer) Stop() {
+	if a.sarCache != nil {
+		a.sarCache.Stop()
+	}
+}
+
+func (a *Authorizer) userClient(token string) (*kubernetes.Clientset, error) {
+	cfg := rest.CopyConfig(a.restCfg)
+	cfg.BearerToken = token
+	cfg.BearerTokenFile = ""
+	cfg.ExecProvider = nil
+	cfg.AuthProvider = nil
+	cfg.Username = ""
+	cfg.Password = ""
+	return kubernetes.NewForConfig(cfg)
+}
+
+// Authorize validates the token and returns allowed namespaces (or full access for admins).
+func (a *Authorizer) Authorize(ctx context.Context, token string) (AuthResult, error) {
+	th := HashToken(token)
+	if r, ok := a.cachedFull(th); ok {
+		return r, nil
+	}
+
+	userInfo, err := Authenticate(ctx, a.relayKube, token)
+	if err != nil {
+		return AuthResult{}, fmt.Errorf("token review: %w", err)
+	}
+
+	userKube, err := a.userClient(token)
+	if err != nil {
+		return AuthResult{}, fmt.Errorf("user client: %w", err)
+	}
+
+	admin, err := CheckClusterAdmin(ctx, userKube)
+	if err != nil {
+		return AuthResult{}, fmt.Errorf("cluster admin check: %w", err)
+	}
+	if admin {
+		res := AuthResult{UserInfo: userInfo, IsAdmin: true, AllowedNamespaces: nil}
+		a.storeFull(th, res)
+		return res, nil
+	}
+
+	nsList, err := a.relayKube.CoreV1().Namespaces().List(ctx, metav1.ListOptions{})
+	if err != nil {
+		return AuthResult{}, fmt.Errorf("list namespaces: %w", err)
+	}
+
+	allowed := make(map[string]struct{})
+	for _, ns := range nsList.Items {
+		name := ns.Name
+		cacheKey := th + ":" + name
+		if ok, hit := a.sarCache.Get(cacheKey); hit {
+			if ok {
+				allowed[name] = struct{}{}
+			}
+			continue
+		}
+		ok, err := CheckNamespaceAccess(ctx, userKube, name)
+		if err != nil {
+			return AuthResult{}, fmt.Errorf("sar namespace %s: %w", name, err)
+		}
+		a.sarCache.Set(cacheKey, ok)
+		if ok {
+			allowed[name] = struct{}{}
+		}
+	}
+
+	res := AuthResult{
+		UserInfo:          userInfo,
+		IsAdmin:           false,
+		AllowedNamespaces: allowed,
+	}
+	a.storeFull(th, res)
+	return res, nil
+}
+
+func (a *Authorizer) cachedFull(tokenHash string) (AuthResult, bool) {
+	a.mu.Lock()
+	defer a.mu.Unlock()
+	e, ok := a.fullResults[tokenHash]
+	if !ok || time.Now().After(e.expires) {
+		return AuthResult{}, false
+	}
+	return e.res, true
+}
+
+func (a *Authorizer) storeFull(tokenHash string, res AuthResult) {
+	a.mu.Lock()
+	defer a.mu.Unlock()
+	a.fullResults[tokenHash] = fullResultEntry{res: res, expires: time.Now().Add(a.ttl)}
+}
diff --git a/pkg/hubble/relay/authz/authz.go b/pkg/hubble/relay/authz/authz.go
new file mode 100644
index 0000000000..7ddca8911e
--- /dev/null
+++ b/pkg/hubble/relay/authz/authz.go
@@ -0,0 +1,101 @@
+// SPDX-License-Identifier: Apache-2.0
+// Copyright Authors of Cilium
+
+package authz
+
+import (
+	"context"
+	"crypto/sha256"
+	"encoding/hex"
+	"fmt"
+	"strings"
+
+	authenticationv1 "k8s.io/api/authentication/v1"
+	authorizationv1 "k8s.io/api/authorization/v1"
+	metav1 "k8s.io/apimachinery/pkg/apis/meta/v1"
+	"k8s.io/client-go/kubernetes"
+)
+
+// HashToken returns a SHA-256 hex digest of the token (for cache keys; never log).
+func HashToken(token string) string {
+	sum := sha256.Sum256([]byte(token))
+	return hex.EncodeToString(sum[:])
+}
+
+// ExtractBearerToken returns the bearer token from gRPC metadata map (keys are lower-case).
+func ExtractBearerToken(md map[string][]string) (string, bool) {
+	for k, vals := range md {
+		if !strings.EqualFold(k, "authorization") || len(vals) == 0 {
+			continue
+		}
+		return parseBearer(vals[0])
+	}
+	return "", false
+}
+
+func parseBearer(v string) (string, bool) {
+	v = strings.TrimSpace(v)
+	const prefix = "Bearer "
+	if len(v) <= len(prefix) || !strings.EqualFold(v[:len(prefix)], prefix) {
+		return "", false
+	}
+	t := strings.TrimSpace(v[len(prefix):])
+	if t == "" {
+		return "", false
+	}
+	return t, true
+}
+
+// Authenticate validates the token using TokenReview (must use the relay service account).
+func Authenticate(ctx context.Context, relayKube kubernetes.Interface, token string) (*authenticationv1.UserInfo, error) {
+	tr, err := relayKube.AuthenticationV1().TokenReviews().Create(ctx, &authenticationv1.TokenReview{
+		Spec: authenticationv1.TokenReviewSpec{
+			Token: token,
+		},
+	}, metav1.CreateOptions{})
+	if err != nil {
+		return nil, err
+	}
+	if !tr.Status.Authenticated {
+		return nil, fmt.Errorf("token not authenticated")
+	}
+	return &tr.Status.User, nil
+}
+
+// CheckNamespaceAccess reports whether the current identity (from the REST client's credentials)
+// may list pods in the given namespace.
+func CheckNamespaceAccess(ctx context.Context, userKube kubernetes.Interface, namespace string) (bool, error) {
+	sar, err := userKube.AuthorizationV1().SelfSubjectAccessReviews().Create(ctx, &authorizationv1.SelfSubjectAccessReview{
+		Spec: authorizationv1.SelfSubjectAccessReviewSpec{
+			ResourceAttributes: &authorizationv1.ResourceAttributes{
+				Namespace: namespace,
+				Verb:      "list",
+				Group:     "",
+				Resource:  "pods",
+				Version:   "v1",
+			},
+		},
+	}, metav1.CreateOptions{})
+	if err != nil {
+		return false, err
+	}
+	return sar.Status.Allowed, nil
+}
+
+// CheckClusterAdmin reports whether the identity can list pods cluster-wide (all namespaces).
+func CheckClusterAdmin(ctx context.Context, userKube kubernetes.Interface) (bool, error) {
+	sar, err := userKube.AuthorizationV1().SelfSubjectAccessReviews().Create(ctx, &authorizationv1.SelfSubjectAccessReview{
+		Spec: authorizationv1.SelfSubjectAccessReviewSpec{
+			ResourceAttributes: &authorizationv1.ResourceAttributes{
+				Verb:     "list",
+				Group:    "",
+				Resource: "pods",
+				Version:  "v1",
+			},
+		},
+	}, metav1.CreateOptions{})
+	if err != nil {
+		return false, err
+	}
+	return sar.Status.Allowed, nil
+}
