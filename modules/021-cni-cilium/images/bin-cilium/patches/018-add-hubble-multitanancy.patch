index 0000000000..74b415a73a
--- /dev/null
+++ b/pkg/hubble/relay/server/auth_interceptor.go
@@ -0,0 +1,177 @@
+// SPDX-License-Identifier: Apache-2.0
+// Copyright Authors of Cilium
+
+package server
+
+import (
+	"context"
+	"os"
+	"strings"
+	"sync"
+
+	observerpb "github.com/cilium/cilium/api/v1/observer"
+	"github.com/cilium/cilium/pkg/hubble/relay/authz"
+	"google.golang.org/grpc"
+	"google.golang.org/grpc/codes"
+	"google.golang.org/grpc/metadata"
+	"google.golang.org/grpc/status"
+	"k8s.io/client-go/kubernetes"
+	"k8s.io/client-go/rest"
+)
+
+const envAuthEnabled = "HUBBLE_RELAY_AUTH_ENABLED"
+
+var (
+	authRelayOnce sync.Once
+	authRelay     *authz.Authorizer
+	authRelayErr  error
+)
+
+func authEnabled() bool {
+	return os.Getenv(envAuthEnabled) == "true"
+}
+
+func relayAuthorizer() (*authz.Authorizer, error) {
+	authRelayOnce.Do(func() {
+		cfg, err := rest.InClusterConfig()
+		if err != nil {
+			authRelayErr = err
+			return
+		}
+		kube, err := kubernetes.NewForConfig(cfg)
+		if err != nil {
+			authRelayErr = err
+			return
+		}
+		authRelay = authz.NewAuthorizer(cfg, kube, 0)
+	})
+	if authRelayErr != nil {
+		return nil, authRelayErr
+	}
+	return authRelay, nil
+}
+
+func init() {
+	if !authEnabled() {
+		return
+	}
+	DefaultOptions = append(DefaultOptions,
+		WithGRPCUnaryInterceptor(authUnaryInterceptor),
+		WithGRPCStreamInterceptor(authStreamInterceptor),
+	)
+}
+
+func authUnaryInterceptor(ctx context.Context, req interface{}, info *grpc.UnaryServerInfo, handler grpc.UnaryHandler) (interface{}, error) {
+	if !authEnabled() {
+		return handler(ctx, req)
+	}
+	if !strings.HasPrefix(info.FullMethod, "/observer.Observer/") {
+		return handler(ctx, req)
+	}
+	md, _ := metadata.FromIncomingContext(ctx)
+	token, ok := authz.ExtractBearerToken(md)
+	if !ok || token == "" {
+		return nil, status.Error(codes.Unauthenticated, "missing bearer token")
+	}
+	a, err := relayAuthorizer()
+	if err != nil {
+		return nil, status.Errorf(codes.Internal, "relay auth initialization: %v", err)
+	}
+	ar, err := a.Authorize(ctx, token)
+	if err != nil {
+		return nil, status.Errorf(codes.Unauthenticated, "authorize: %v", err)
+	}
+	switch info.FullMethod {
+	case observerpb.Observer_GetNodes_FullMethodName, observerpb.Observer_ServerStatus_FullMethodName:
+		if !ar.IsAdmin {
+			return nil, status.Error(codes.PermissionDenied, "admin only")
+		}
+		return handler(ctx, req)
+	case observerpb.Observer_GetNamespaces_FullMethodName:
+		if ar.IsAdmin {
+			return handler(ctx, req)
+		}
+		resp, err := handler(ctx, req)
+		if err != nil {
+			return nil, err
+		}
+		nsResp, ok := resp.(*observerpb.GetNamespacesResponse)
+		if !ok {
+			return resp, nil
+		}
+		return filterNamespacesResponse(nsResp, ar), nil
+	default:
+		return handler(ctx, req)
+	}
+}
+
+func authStreamInterceptor(srv interface{}, ss grpc.ServerStream, info *grpc.StreamServerInfo, handler grpc.StreamHandler) error {
+	if !authEnabled() {
+		return handler(srv, ss)
+	}
+	if !strings.HasPrefix(info.FullMethod, "/observer.Observer/") {
+		return handler(srv, ss)
+	}
+	md, _ := metadata.FromIncomingContext(ss.Context())
+	token, ok := authz.ExtractBearerToken(md)
+	if !ok || token == "" {
+		return status.Error(codes.Unauthenticated, "missing bearer token")
+	}
+	a, err := relayAuthorizer()
+	if err != nil {
+		return status.Errorf(codes.Internal, "relay auth initialization: %v", err)
+	}
+	ar, err := a.Authorize(ss.Context(), token)
+	if err != nil {
+		return status.Errorf(codes.Unauthenticated, "authorize: %v", err)
+	}
+	switch info.FullMethod {
+	case observerpb.Observer_GetFlows_FullMethodName:
+		if ar.IsAdmin {
+			return handler(srv, ss)
+		}
+		return handler(srv, newGetFlowsAuthStream(ss, ar))
+	case observerpb.Observer_GetAgentEvents_FullMethodName, observerpb.Observer_GetDebugEvents_FullMethodName:
+		if !ar.IsAdmin {
+			return status.Error(codes.PermissionDenied, "admin only")
+		}
+		return handler(srv, ss)
+	default:
+		return handler(srv, ss)
+	}
+}
+
+// getFlowsAuthStream validates/injects the first GetFlowsRequest and filters outbound flows.
+type getFlowsAuthStream struct {
+	grpc.ServerStream
+	ar       authz.AuthResult
+	recvDone bool
+}
+
+func newGetFlowsAuthStream(inner grpc.ServerStream, ar authz.AuthResult) *getFlowsAuthStream {
+	return &getFlowsAuthStream{ServerStream: inner, ar: ar}
+}
+
+func (s *getFlowsAuthStream) RecvMsg(m interface{}) error {
+	if s.recvDone {
+		return s.ServerStream.RecvMsg(m)
+	}
+	s.recvDone = true
+	if err := s.ServerStream.RecvMsg(m); err != nil {
+		return err
+	}
+	req, ok := m.(*observerpb.GetFlowsRequest)
+	if !ok {
+		return nil
+	}
+	return validateAndInjectGetFlowsRequest(req, s.ar)
+}
+
+func (s *getFlowsAuthStream) SendMsg(m interface{}) error {
+	if resp, ok := m.(*observerpb.GetFlowsResponse); ok {
+		if !flowResponseAllowed(resp, s.ar) {
+			return nil
+		}
+	}
+	return s.ServerStream.SendMsg(m)
+}
diff --git a/pkg/hubble/relay/server/auth_request_filter.go b/pkg/hubble/relay/server/auth_request_filter.go
new file mode 100644
index 0000000000..f8fee4391b
--- /dev/null
+++ b/pkg/hubble/relay/server/auth_request_filter.go
@@ -0,0 +1,79 @@
+// SPDX-License-Identifier: Apache-2.0
+// Copyright Authors of Cilium
+
+package server
+
+import (
+	flowpb "github.com/cilium/cilium/api/v1/flow"
+	observerpb "github.com/cilium/cilium/api/v1/observer"
+	"github.com/cilium/cilium/pkg/hubble/k8s"
+	"github.com/cilium/cilium/pkg/hubble/relay/authz"
+	"google.golang.org/grpc/codes"
+	"google.golang.org/grpc/status"
+)
+
+// validateAndInjectGetFlowsRequest enforces namespace access on user-supplied filters and, when
+// there are no namespace-scoped pod filters, appends whitelist entries for allowed namespaces.
+func validateAndInjectGetFlowsRequest(req *observerpb.GetFlowsRequest, ar authz.AuthResult) error {
+	if ar.IsAdmin {
+		return nil
+	}
+
+	referenced := namespacesReferencedFromFlowFilters(req.GetBlacklist())
+	referenced = append(referenced, namespacesReferencedFromFlowFilters(req.GetWhitelist())...)
+	for _, ns := range referenced {
+		if ns == "" {
+			continue
+		}
+		if _, ok := ar.AllowedNamespaces[ns]; !ok {
+			return status.Errorf(codes.PermissionDenied, "not allowed to access namespace %q", ns)
+		}
+	}
+
+	if len(referenced) > 0 {
+		return nil
+	}
+
+	prefixes := namespacePrefixes(ar)
+	for _, w := range namespaceWhitelistEntries(prefixes) {
+		req.Whitelist = append(req.Whitelist, w)
+	}
+	return nil
+}
+
+func namespacesReferencedFromFlowFilters(filters []*flowpb.FlowFilter) []string {
+	var out []string
+	for _, f := range filters {
+		for _, sp := range f.GetSourcePod() {
+			ns, _ := k8s.ParseNamespaceName(sp)
+			if ns != "" {
+				out = append(out, ns)
+			}
+		}
+		for _, dp := range f.GetDestinationPod() {
+			ns, _ := k8s.ParseNamespaceName(dp)
+			if ns != "" {
+				out = append(out, ns)
+			}
+		}
+	}
+	return out
+}
+
+func namespacePrefixes(ar authz.AuthResult) []string {
+	prefixes := make([]string, 0, len(ar.AllowedNamespaces))
+	for ns := range ar.AllowedNamespaces {
+		prefixes = append(prefixes, ns+"/")
+	}
+	return prefixes
+}
+
+func namespaceWhitelistEntries(prefixes []string) []*flowpb.FlowFilter {
+	if len(prefixes) == 0 {
+		return nil
+	}
+	return []*flowpb.FlowFilter{
+		{SourcePod: append([]string(nil), prefixes...)},
+		{DestinationPod: append([]string(nil), prefixes...)},
+	}
+}
