+func grpcBearerAuth(vp *viper.Viper) (grpc.DialOption, error) {
+	if t := vp.GetString(config.KeyBearerToken); t != "" {
+		return WithBearerToken(t), nil
+	}
+
+	if !vp.GetBool(config.KeyKubeAuth) && !vp.GetBool(config.KeyPortForward) {
+		return nil, nil
+	}
+
+	t, err := kubeBearerTokenFromConfig(vp)
+	if err != nil {
+		if vp.GetBool(config.KeyKubeAuth) {
+			return nil, err
+		}
+		logger.Logger.Debug("could not load kube token for gRPC metadata", "error", err)
+		return nil, nil
+	}
+	return WithBearerToken(t), nil
+}
