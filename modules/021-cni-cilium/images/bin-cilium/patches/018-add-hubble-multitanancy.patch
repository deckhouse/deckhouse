+// SPDX-License-Identifier: Apache-2.0
+// Copyright Authors of Cilium
+
+package authz
+
+import (
+	"testing"
+
+	"github.com/stretchr/testify/require"
+)
+
+func TestExtractBearerToken(t *testing.T) {
+	md := map[string][]string{
+		"authorization": {"Bearer secret-token"},
+	}
+	tok, ok := ExtractBearerToken(md)
+	require.True(t, ok)
+	require.Equal(t, "secret-token", tok)
+
+	md2 := map[string][]string{
+		"Authorization": {"bearer lower"},
+	}
+	tok2, ok2 := ExtractBearerToken(md2)
+	require.True(t, ok2)
+	require.Equal(t, "lower", tok2)
+
+	_, ok3 := ExtractBearerToken(map[string][]string{"authorization": {"Basic x"}})
+	require.False(t, ok3)
+}
diff --git a/pkg/hubble/relay/authz/cache.go b/pkg/hubble/relay/authz/cache.go
new file mode 100644
index 0000000000..14356aa41e
--- /dev/null
+++ b/pkg/hubble/relay/authz/cache.go
@@ -0,0 +1,77 @@
+// SPDX-License-Identifier: Apache-2.0
+// Copyright Authors of Cilium
+
+package authz
+
+import (
+	"sync"
+	"time"
+)
+
+// sarCache caches SubjectAccessReview outcomes per (token hash, namespace).
+type sarCache struct {
+	mu       sync.RWMutex
+	entries  map[string]sarEntry
+	ttl      time.Duration
+	stopOnce sync.Once
+	stopCh   chan struct{}
+}
+
+type sarEntry struct {
+	allowed bool
+	expiry  time.Time
+}
+
+func newSARCache(ttl time.Duration) *sarCache {
+	c := &sarCache{
+		entries: make(map[string]sarEntry),
+		ttl:     ttl,
+		stopCh:  make(chan struct{}),
+	}
+	go c.backgroundCleanup()
+	return c
+}
+
+func (c *sarCache) Stop() {
+	c.stopOnce.Do(func() { close(c.stopCh) })
+}
+
+func (c *sarCache) Get(key string) (allowed bool, ok bool) {
+	c.mu.RLock()
+	defer c.mu.RUnlock()
+	e, exists := c.entries[key]
+	if !exists || time.Now().After(e.expiry) {
+		return false, false
+	}
+	return e.allowed, true
+}
+
+func (c *sarCache) Set(key string, allowed bool) {
+	c.mu.Lock()
+	defer c.mu.Unlock()
+	c.entries[key] = sarEntry{allowed: allowed, expiry: time.Now().Add(c.ttl)}
+}
+
+func (c *sarCache) backgroundCleanup() {
+	ticker := time.NewTicker(c.ttl / 2)
+	defer ticker.Stop()
+	for {
+		select {
+		case <-c.stopCh:
+			return
+		case <-ticker.C:
+			c.evictExpired()
+		}
+	}
+}
+
+func (c *sarCache) evictExpired() {
+	now := time.Now()
+	c.mu.Lock()
+	defer c.mu.Unlock()
+	for k, e := range c.entries {
+		if now.After(e.expiry) {
+			delete(c.entries, k)
+		}
+	}
+}
diff --git a/pkg/hubble/relay/server/auth_filter.go b/pkg/hubble/relay/server/auth_filter.go
new file mode 100644
index 0000000000..f520663709
--- /dev/null
+++ b/pkg/hubble/relay/server/auth_filter.go
@@ -0,0 +1,51 @@
+// SPDX-License-Identifier: Apache-2.0
+// Copyright Authors of Cilium
+
+package server
+
+import (
+	observerpb "github.com/cilium/cilium/api/v1/observer"
+	"github.com/cilium/cilium/pkg/hubble/relay/authz"
+)
+
+func filterNamespacesResponse(resp *observerpb.GetNamespacesResponse, ar authz.AuthResult) *observerpb.GetNamespacesResponse {
+	if ar.IsAdmin || resp == nil {
+		return resp
+	}
+	filtered := make([]*observerpb.Namespace, 0, len(resp.GetNamespaces()))
+	for _, n := range resp.GetNamespaces() {
+		ns := n.GetNamespace()
+		if ns == "" {
+			continue
+		}
+		if _, ok := ar.AllowedNamespaces[ns]; ok {
+			filtered = append(filtered, n)
+		}
+	}
+	resp.Namespaces = filtered
+	return resp
+}
+
+func flowResponseAllowed(resp *observerpb.GetFlowsResponse, ar authz.AuthResult) bool {
+	if ar.IsAdmin {
+		return true
+	}
+	if resp == nil {
+		return true
+	}
+	f := resp.GetFlow()
+	if f == nil {
+		return true
+	}
+	src := f.GetSource().GetNamespace()
+	dst := f.GetDestination().GetNamespace()
+	return namespaceAllowed(src, ar) || namespaceAllowed(dst, ar)
+}
+
+func namespaceAllowed(ns string, ar authz.AuthResult) bool {
+	if ns == "" {
+		return false
+	}
+	_, ok := ar.AllowedNamespaces[ns]
+	return ok
+}
