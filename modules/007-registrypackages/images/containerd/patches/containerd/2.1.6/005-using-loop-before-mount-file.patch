index a8cec6481..103ea51a9 100644
--- a/pkg/kernelversion/kernel_linux.go
+++ b/pkg/kernelversion/kernel_linux.go
@@ -23,7 +23,11 @@ package kernelversion
 
 import (
 	"bytes"
+	"compress/gzip"
 	"fmt"
+	"io"
+	"os"
+	"strings"
 	"sync"
 
 	"golang.org/x/sys/unix"
@@ -92,3 +96,87 @@ func GreaterEqualThan(minVersion KernelVersion) (bool, error) {
 	}
 	return false, nil
 }
+
+var (
+	erofsFileBacked     bool
+	erofsFileBackedOnce sync.Once
+)
+
+// DetectErofsBackedByFile reports whether the running kernel supports mounting
+// EROFS directly from a regular file (CONFIG_EROFS_FS_BACKED_BY_FILE).
+//
+// When false, callers should supply the "loop" mount option for .erofs blobs
+// to avoid emitting a misleading "Can't open blockdev" line in dmesg.
+func DetectErofsBackedByFile() bool {
+	erofsFileBackedOnce.Do(func() {
+		erofsFileBacked = probeErofsFileBacked()
+	})
+	return erofsFileBacked
+}
+
+func probeErofsFileBacked() bool {
+	// CONFIG_EROFS_FS_BACKED_BY_FILE was introduced in Linux 6.12.
+	// Kernels older than that never have it regardless of config.
+	ok, err := GreaterEqualThan(KernelVersion{Kernel: 6, Major: 12})
+	if err != nil || !ok {
+		return false
+	}
+	// Kernel is >= 6.12; try to confirm the option is compiled in.
+	enabled, err := readKernelConfigOption("CONFIG_EROFS_FS_BACKED_BY_FILE")
+	if err != nil {
+		return true
+	}
+	return enabled
+}
+
+// readKernelConfigOption searches the running kernel's config files for the
+// given option and reports whether it is set to "y" or "m". Returns an error when no config file is readable.
+func readKernelConfigOption(option string) (bool, error) {
+	var release string
+	var uts unix.Utsname
+	if err := unix.Uname(&uts); err == nil {
+		release = string(uts.Release[:bytes.IndexByte(uts.Release[:], 0)])
+	}
+
+	paths := []string{
+		"/proc/config.gz",
+		fmt.Sprintf("/boot/config-%s", release),
+		"/boot/config",
+	}
+
+	for _, path := range paths {
+		data, err := readConfigFile(path)
+		if err != nil {
+			continue
+		}
+		needle := option + "="
+		for _, line := range strings.Split(string(data), "\n") {
+			if strings.HasPrefix(line, needle) {
+				val := strings.TrimPrefix(line, needle)
+				return val == "y" || val == "m", nil
+			}
+		}
+		// Config was readable but the option is absent - explicitly disabled.
+		return false, nil
+	}
+	return false, fmt.Errorf("no readable kernel config found in %v", paths)
+}
+
+// readConfigFile reads a plain-text or gzip-compressed kernel config file.
+func readConfigFile(path string) ([]byte, error) {
+	f, err := os.Open(path)
+	if err != nil {
+		return nil, err
+	}
+	defer f.Close()
+
+	if strings.HasSuffix(path, ".gz") {
+		gz, err := gzip.NewReader(f)
+		if err != nil {
+			return nil, err
+		}
+		defer gz.Close()
+		return io.ReadAll(gz)
+	}
+	return io.ReadAll(f)
+}
