-// [os.Create]: https://pkg.go.dev/os#Create
-func (r *Root) Create(path string, flags int, mode os.FileMode) (*os.File, error) {
-	unixMode, err := toUnixMode(mode, false)
-	if err != nil {
-		return nil, err
