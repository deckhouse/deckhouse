source /shell_lib.sh

function __config__(){
  cat <<EOF
configVersion: v1
kubernetesValidating:
- name: role-validating.deckhouse.io
  group: main
  matchConditions:
  - expression: ("system:apiserver" != request.userInfo.username)
    name: exclude-kube-apiserver
  - expression: ("system:serviceaccount:d8-system:deckhouse" != request.userInfo.username)
    name: exclude-deckhouse
  rules:
  - apiGroups:   ["rbac.authorization.k8s.io"]
    apiVersions: ["*"]
    operations:  ["CREATE"]
    resources:   ["clusterrolebindings"]
    scope:       "Cluster"
EOF
}

# The decision is made purely from roleRef on the object under review: namespace- and
# project-scoped RBACv2 roles (and their capabilities, including the d8:custom:* variants)
# carry well-known name prefixes and must never be bound cluster-wide via a ClusterRoleBinding.
# This is intentionally snapshot-free: relying on a `.snapshots.roles` binding made the hook
# fail open whenever the shell-operator snapshot was empty.
function __main__() {
  roleRefKind=$(context::jq -r '.review.request.object.roleRef.kind')
  clusterRoleName=$(context::jq -r '.review.request.object.roleRef.name')

  if [[ "$roleRefKind" == "ClusterRole" ]]; then
    case "$clusterRoleName" in
      d8:namespace:* | \
      d8:project:* | \
      d8:namespace-capability:* | \
      d8:project-capability:* | \
      d8:custom:namespace:* | \
      d8:custom:namespace-capability:* | \
      d8:custom:project:* | \
      d8:custom:project-capability:*)
        cat <<EOF > "$VALIDATING_RESPONSE_PATH"
{"allowed":false, "message":"ClusterRole '$clusterRoleName' cannot be used in ClusterRoleBinding. Use RoleBinding instead."}
EOF
        return 0
        ;;
    esac
  fi

  cat <<EOF > "$VALIDATING_RESPONSE_PATH"
{"allowed":true}
EOF
}

hook::run "$@"
