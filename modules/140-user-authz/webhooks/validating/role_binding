source /shell_lib.sh

function __config__(){
  cat <<EOF
configVersion: v1
kubernetes:
  - name: roles
    apiVersion: rbac.authorization.k8s.io/v1
    kind: ClusterRole
    queue: authorization
    # NB: this snapshot-only binding must NOT be in the same `group` as the validating webhook.
    # A binding that is both in a group and never triggers the hook (executeHookOnEvent: [] +
    # executeHookOnSynchronization: false) gets coalesced by the group and its informer is not
    # started, so the snapshot stays empty and the webhook (includeSnapshotsFrom: ["roles"]) fails
    # open. Keep it standalone — exactly like the working kube-dns cluster-domain-alias hook.
    executeHookOnEvent: []
    executeHookOnSynchronization: false
    keepFullObjectsInMemory: false
    labelSelector:
      matchExpressions:
        - key: rbac.deckhouse.io/scope
          operator: In
          values: ["namespace", "project"]
    jqFilter: |
      {
        "name": .metadata.name
      }
kubernetesValidating:
- name: role-validating.deckhouse.io
  group: main
  # The decision needs the "roles" snapshot (namespace/project-scoped ClusterRoles). With the
  # updated shell-operator, group membership alone no longer injects sibling snapshots into a
  # validating webhook context, so request it explicitly — otherwise .snapshots.roles is empty and
  # the hook fails open, letting namespace/project roles be bound cluster-wide.
  includeSnapshotsFrom: ["roles"]
  matchConditions:
  - expression: ("system:apiserver" != request.userInfo.username)
    name: exclude-kube-apiserver
  - expression: ("system:serviceaccount:d8-system:deckhouse" != request.userInfo.username)
    name: exclude-deckhouse
  rules:
  - apiGroups:   ["rbac.authorization.k8s.io"]
    apiVersions: ["*"]
    operations:  ["CREATE"]
    resources:   ["clusterrolebindings"]
    scope:       "Cluster"
EOF
}

function __main__() {
  clusterRoleName=$(context::jq -r '.review.request.object.roleRef.name')
  result=$(context::jq -r --arg role "$clusterRoleName" '.snapshots.roles[].filterResult | select(.name == $role)')
  if [[ "$result" ]]; then
        cat <<EOF > "$VALIDATING_RESPONSE_PATH"
{"allowed":false, "message":"ClusterRole '$clusterRoleName' cannot be used in ClusterRoleBinding. Use RoleBinding instead."}
EOF
  return 0;
  fi
  cat <<EOF > "$VALIDATING_RESPONSE_PATH"
{"allowed":true}
EOF
}

hook::run "$@"
