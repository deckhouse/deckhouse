+package scope
+
+import (
+	"fmt"
+	"hash/fnv"
+	"strings"
+)
+
+const (
+	daemonSetKind = "DaemonSet"
+	labelPrefix   = "__vpa_scope_"
+)
+
+// IsScopedDaemonSet returns true when target is DaemonSet and scopeKey is set.
+func IsScopedDaemonSet(kind, scopeKey string) bool {
+	return kind == daemonSetKind && scopeKey != ""
+}
+
+// AggregationLabelKey returns a deterministic synthetic pod label key for scopeKey.
+func AggregationLabelKey(scopeKey string) string {
+	h := fnv.New32a()
+	_, _ = h.Write([]byte(scopeKey))
+	return fmt.Sprintf("%s%x", labelPrefix, h.Sum32())
+}
+
+// RecommendationScope builds serialized scope key-value pair.
+func RecommendationScope(scopeKey, scopeValue string) string {
+	return scopeKey + "=" + scopeValue
+}
+
+// ParseRecommendationScope parses "<scopeKey>=<scopeValue>".
+func ParseRecommendationScope(raw string) (string, string, bool) {
+	parts := strings.SplitN(raw, "=", 2)
+	if len(parts) != 2 || parts[0] == "" || parts[1] == "" {
+		return "", "", false
+	}
+	return parts[0], parts[1], true
+}
