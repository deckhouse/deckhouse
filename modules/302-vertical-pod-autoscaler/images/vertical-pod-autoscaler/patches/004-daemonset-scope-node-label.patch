+			selected = append(selected, recommendation)
+		}
+	}
+	if len(selected) != 0 {
+		return selected, nil
+	}
+
+	for _, group := range vpa.Status.Groups {
+		if group.ScopeValue == scopeValue {
+			return group.ContainerRecommendations, nil
+		}
+	}
+	return []vpa_types.RecommendedContainerResources{}, nil
