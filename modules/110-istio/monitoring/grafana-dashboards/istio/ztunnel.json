            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "eds"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Endpoints"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "lds"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Listeners"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "rds"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Routes"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "nds"
