            "properties": [
              {
                "id": "displayName",
                "value": "Authorizations"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "type.googleapis.com/istio.workload.Address"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Addresses"
              }
            ]
          }
