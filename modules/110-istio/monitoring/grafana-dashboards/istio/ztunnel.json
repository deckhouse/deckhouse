          },
          {
            "matcher": {
              "id": "byName",
              "options": "istio.io/debug"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Debug"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "istio.io/debug/syncz"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Debug"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "wads"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Authorization"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "wds"
