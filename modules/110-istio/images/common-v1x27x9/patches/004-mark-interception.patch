+// newUpstreamDNSClient builds a miekg/dns Client used to forward queries to the
+// real upstream resolver (e.g. CoreDNS). When outboundMark is set (mark-based
+// outbound interception), the dialer tags its socket with SO_MARK so that the
+// iptables mark-RETURN rule exempts the forwarded query from being redirected
+// back into the local DNS proxy (which would loop forever, since the agent
+// shares the application's UID/GID and cannot be excluded by owner).
+func newUpstreamDNSClient(protocol, outboundMark string) *dns.Client {
+	c := &dns.Client{
+		Net:          protocol,
+		DialTimeout:  5 * time.Second,
+		ReadTimeout:  5 * time.Second,
+		WriteTimeout: 5 * time.Second,
+	}
+	if outboundMark != "" {
+		mark, err := strconv.Atoi(outboundMark)
+		if err == nil && mark > 0 {
+			c.Dialer = &net.Dialer{
+				Timeout:  5 * time.Second,
+				Control: func(network, address string, c syscall.RawConn) error {
+					var serr error
+					if err := c.Control(func(fd uintptr) {
+						serr = unix.SetsockoptInt(int(fd), unix.SOL_SOCKET, unix.SO_MARK, mark)
+					}); err != nil {
+						return err
+					}
+					return serr
+				},
+			}
+		}
+	}
+	return c
+}
+
