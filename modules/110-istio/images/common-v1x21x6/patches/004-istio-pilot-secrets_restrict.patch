 func (c *Controller) AddHandler(h ClusterHandler) {
+	log.Infof("AddHandler called, registering handler %T. Current handlers count: %d", h, len(c.handlers))
 	c.handlers = append(c.handlers, h)
+	log.Infof("Handler registered. New handlers count: %d", len(c.handlers))
+
+	// Call ClusterAdded for all existing remote clusters to ensure the handler is notified
+	// about clusters that were added before the handler was registered
+	allClusters := c.cs.All()
+	log.Infof("Calling ClusterAdded for %d existing remote clusters", c.cs.Len())
+	for secretKey, clusters := range allClusters {
+		for clusterID, cluster := range clusters {
+			// Skip config cluster as it's handled separately in Run()
+			if cluster.ID == c.configClusterID {
+				log.Debugf("Skipping config cluster %v", clusterID)
+				continue
+			}
+			log.Infof("Calling ClusterAdded for existing cluster %v from secret %s", clusterID, secretKey)
+			h.ClusterAdded(cluster, cluster.stop)
+		}
+	}
+	log.Infof("Finished calling ClusterAdded for existing remote clusters")
 }
 
 // Run starts the controller until it receives a message over stopCh
@@ -309,7 +328,9 @@ func (c *Controller) deleteCluster(secretKey string, cluster *Cluster) {
 }
 
 func (c *Controller) handleAdd(cluster *Cluster, stop <-chan struct{}) {
+	log.Infof("handleAdd called for cluster %v with %d handlers", cluster.ID, len(c.handlers))
 	for _, handler := range c.handlers {
+		log.Infof("Calling ClusterAdded for cluster %v on handler %T", cluster.ID, handler)
 		handler.ClusterAdded(cluster, stop)
 	}
 }
