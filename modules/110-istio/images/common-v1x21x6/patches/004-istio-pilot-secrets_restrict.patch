+		secretName := secret.GetName()
+		secretNamespace := secret.GetNamespace()
+
+		// Only allow secrets from d8-istio namespace
+		if secretNamespace != istioNamespace {
+			return false
+		}
+
+		// Only allow specific secret names
+		return allowedSecrets[secretName]
+	}
+
 	secrets := kclient.NewFiltered[*v1.Secret](kc, kclient.Filter{
+		Namespace:     istioNamespace,
 		FieldSelector: fieldSelector,
+		ObjectFilter:  objectFilter,
 	})
 
