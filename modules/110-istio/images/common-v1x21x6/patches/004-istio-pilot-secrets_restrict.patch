+func newNamedSecretInformer(kc kube.Client, secretName, namespace string) kclient.Informer[*v1.Secret] {
+	secretInterface := kc.Kube().CoreV1().Secrets(namespace)
+
+	lw := &cache.ListWatch{
+		ListFunc: func(options metav1.ListOptions) (runtime.Object, error) {
+			secret, err := secretInterface.Get(context.Background(), secretName, metav1.GetOptions{})
+			if err != nil {
+				return &v1.SecretList{
+					TypeMeta: metav1.TypeMeta{
+						Kind:       "SecretList",
+						APIVersion: "v1",
+					},
+					ListMeta: metav1.ListMeta{},
+					Items:    []v1.Secret{},
+				}, nil
+			}
+			return &v1.SecretList{
+				TypeMeta: metav1.TypeMeta{
+					Kind:       "SecretList",
+					APIVersion: "v1",
+				},
+				ListMeta: metav1.ListMeta{},
+				Items:    []v1.Secret{*secret},
+			}, nil
+		},
+		WatchFunc: func(options metav1.ListOptions) (watch.Interface, error) {
+			options.FieldSelector = fields.OneTermEqualSelector("metadata.name", secretName).String()
+			return secretInterface.Watch(context.Background(), options)
+		},
+	}
+
+	inf := cache.NewSharedIndexInformer(
+		lw,
+		&v1.Secret{},
+		0,
+		cache.Indexers{cache.NamespaceIndex: cache.MetaNamespaceIndexFunc},
+	)
+
+	return &informerClientWrapper[*v1.Secret]{
+		informer: inf,
+		startInformer: func(stopCh <-chan struct{}) {
+			go inf.Run(stopCh)
+		},
+	}
+}
+
+type informerClientWrapper[T controllers.ComparableObject] struct {
+	informer      cache.SharedIndexInformer
+	startInformer func(stopCh <-chan struct{})
+	filter        func(t any) bool
+	handlerMu     sync.RWMutex
+	handlers      []cache.ResourceEventHandlerRegistration
+}
+
+func (w *informerClientWrapper[T]) Get(name, namespace string) T {
+	obj, exists, err := w.informer.GetIndexer().GetByKey(keyFunc(name, namespace))
+	if err != nil || !exists {
+		return ptr.Empty[T]()
+	}
+	return obj.(T)
+}
+
+func (w *informerClientWrapper[T]) List(namespace string, selector klabels.Selector) []T {
+	var res []T
+	err := cache.ListAllByNamespace(w.informer.GetIndexer(), namespace, selector, func(i any) {
+		cast := i.(T)
+		if w.filter == nil || w.filter(cast) {
+			res = append(res, cast)
+		}
+	})
+	if err != nil && features.EnableUnsafeAssertions {
+		log.Fatalf("lister returned err for %v: %v", namespace, err)
+	}
+	return res
+}
+
+func (w *informerClientWrapper[T]) ListUnfiltered(namespace string, selector klabels.Selector) []T {
+	var res []T
+	err := cache.ListAllByNamespace(w.informer.GetIndexer(), namespace, selector, func(i any) {
+		cast := i.(T)
+		res = append(res, cast)
+	})
+	if err != nil && features.EnableUnsafeAssertions {
+		log.Fatalf("lister returned err for %v: %v", namespace, err)
+	}
+	return res
+}
+
+func (w *informerClientWrapper[T]) AddEventHandler(h cache.ResourceEventHandler) {
+	reg, _ := w.informer.AddEventHandler(h)
+	w.handlerMu.Lock()
+	defer w.handlerMu.Unlock()
+	w.handlers = append(w.handlers, reg)
+}
+
+func (w *informerClientWrapper[T]) HasSynced() bool {
+	return w.informer.HasSynced()
+}
+
+func (w *informerClientWrapper[T]) ShutdownHandlers() {
+	w.handlerMu.Lock()
+	defer w.handlerMu.Unlock()
+	for _, c := range w.handlers {
+		_ = w.informer.RemoveEventHandler(c)
+	}
+}
+
+func (w *informerClientWrapper[T]) Start(stopCh <-chan struct{}) {
+	w.startInformer(stopCh)
+}
+
+func keyFunc(name, namespace string) string {
+	if len(namespace) == 0 {
+		return name
+	}
+	return namespace + "/" + name
+}
