+// applyOutboundSocketMark tags upstream sockets with SO_MARK when the proxy advertises
+// OutboundMark (sidecar running with the same UID as the app). Envoy's setsockopt(SO_MARK)
+// requires CAP_NET_RAW (kernel >=5.17) or CAP_NET_ADMIN; iptables exempts marked packets.
+func (cb *ClusterBuilder) applyOutboundSocketMark(c *cluster.Cluster) {
+	if !cb.sidecarProxy() {
+		return
+	}
+	if cb.outboundMark == "" {
+		return
+	}
+	mark, err := strconv.ParseUint(cb.outboundMark, 10, 32)
+	if err != nil {
+		return
+	}
+	sockOpt := &core.SocketOption{
+		Description: "outbound socket mark to distinguish Envoy traffic in iptables",
+		Level:       1, // SOL_SOCKET
+		Name:        36, // SO_MARK
+		Value: &core.SocketOption_IntValue{
+			IntValue: int64(mark),
+		},
+		State: core.SocketOption_STATE_PREBIND,
+	}
+	if c.UpstreamBindConfig == nil {
+		c.UpstreamBindConfig = &core.BindConfig{}
+	}
+	c.UpstreamBindConfig.SocketOptions = append(c.UpstreamBindConfig.SocketOptions, sockOpt)
+}
