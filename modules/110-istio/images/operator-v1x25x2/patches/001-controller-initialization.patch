+func (r *Reconciler) installHelmCharts(ctx context.Context, rev *v1.IstioRevision) (ctrl.Result, error) {
+	log := logf.FromContext(ctx)
+	releaseName := getReleaseName(rev)
+	targetNamespace := rev.Spec.Namespace
+
+	// Check if we've retried too many times
+	if retryCount, ok := ctx.Value("retryCount").(int); ok && retryCount >= 3 {
+		log.Error(nil, "Maximum retries reached for uninstalling release",
+			"release", releaseName,
+			"retryCount", retryCount)
+		return ctrl.Result{}, fmt.Errorf("release %s stuck in uninstalling state", releaseName)
+	}
+
+	log.Info("Installing Helm chart",
+		"release", releaseName,
+		"namespace", targetNamespace,
+		"chart", constants.IstiodChartName,
+		"version", rev.Spec.Version)
+
+	// First attempt normal installation
+	result, installErr := r.tryInstall(ctx, rev)
+	if installErr == nil {
+		return result, nil
+	}
+
+	// Handle uninstalling state
+	if strings.Contains(installErr.Error(), "unexpected helm release status uninstalling") {
+		log.Info("Investigating stuck uninstall", "release", releaseName)
+
+		// 1. Check for remaining resources
+		if cleanupErr := r.cleanupOrphanedResources(ctx, rev); cleanupErr != nil {
+			log.Error(cleanupErr, "Failed to cleanup orphaned resources")
+			return ctrl.Result{RequeueAfter: 30 * time.Second}, nil
+		}
+
+		// 2. Progressive backoff
+		retryCount := 1
+		if ctxRetry, ok := ctx.Value("retryCount").(int); ok {
+			retryCount = ctxRetry + 1
+		}
+		requeueAfter := time.Duration(retryCount) * time.Minute
+
+		log.Info("Release still uninstalling, will retry",
+			"release", releaseName,
+			"retryCount", retryCount,
+			"nextAttemptIn", requeueAfter)
+
+		return ctrl.Result{RequeueAfter: requeueAfter}, nil
+	}
+
+	// Handle other errors
+	return result, installErr
+}
