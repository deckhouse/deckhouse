+// Helper function to check if resource belongs to release
+func belongsToRelease(obj unstructured.Unstructured, releaseName string) bool {
+	annotations := obj.GetAnnotations()
+	if annotations == nil {
+		return false
+	}
+	return annotations["meta.helm.sh/release-name"] == releaseName
+}
+
+// Main installation function
+func (r *Reconciler) installHelmCharts(ctx context.Context, rev *v1.IstioRevision) (ctrl.Result, error) {
+	log := logf.FromContext(ctx)
+	releaseName := getReleaseName(rev)
+	namespace := rev.Spec.Namespace
+
+	// Check for force reinstall annotation
+	if rev.Annotations["sail.istio.io/force-reinstall"] == "true" {
+		if err := r.forceCleanup(ctx, rev); err != nil {
+			return ctrl.Result{}, fmt.Errorf("force cleanup failed: %w", err)
+		}
+		// Remove annotation
+		patch := client.MergeFrom(rev.DeepCopy())
+		delete(rev.Annotations, "sail.istio.io/force-reinstall")
+		if err := r.Client.Patch(ctx, rev, patch); err != nil {
+			log.Error(err, "Failed to remove force-reinstall annotation")
+		}
+	}
+
+	// Attempt installation
+	_, err := r.ChartManager.UpgradeOrInstallChart(ctx, r.getChartDir(rev),
+		helm.FromValues(rev.Spec.Values), namespace, releaseName, getOwnerReference(rev))
+
+	if err == nil {
+		return ctrl.Result{}, nil
+	}
+
+	// Handle specific error cases
+	if strings.Contains(err.Error(), "unexpected helm release status uninstalling") {
+		return r.handleStuckRelease(ctx, rev, err)
+	}
+
+	if strings.Contains(err.Error(), "is forbidden") {
+		return ctrl.Result{}, fmt.Errorf("RBAC permissions missing: %w", err)
+	}
+
+	return ctrl.Result{}, fmt.Errorf("installation failed: %w", err)
+}
+
+func (r *Reconciler) handleStuckRelease(ctx context.Context, rev *v1.IstioRevision, installErr error) (ctrl.Result, error) {
+	log := logf.FromContext(ctx)
+	releaseName := getReleaseName(rev)
+	namespace := rev.Spec.Namespace
+
+	// Log detailed error
+	log.Error(installErr, "Release stuck in uninstalling state")
+
+	// Find and log stuck resources
+	if stuckResources, err := r.findStuckResources(ctx, releaseName, namespace); err == nil {
+		for _, res := range stuckResources {
+			log.Info("Stuck resource",
+				"kind", res.GetKind(),
+				"name", res.GetName(),
+				"namespace", res.GetNamespace())
+		}
+	}
+
+	// Provide clear recovery instructions
+	log.Info("Manual recovery required",
+		"action1", fmt.Sprintf("kubectl delete secret -n %s -l owner=helm,name=%s", namespace, releaseName),
+		"action2", fmt.Sprintf("kubectl delete deploy,svc,sa -n %s -l release=%s", namespace, releaseName),
+		"action3", "kubectl annotate istiorevision "+rev.Name+" sail.istio.io/force-reinstall=true --overwrite")
+
+	return ctrl.Result{}, fmt.Errorf("release %s stuck in uninstalling state - manual cleanup required", releaseName)
+}
