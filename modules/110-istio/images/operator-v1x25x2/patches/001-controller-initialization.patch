+func (r *Reconciler) cleanupOrphanedResources(ctx context.Context, rev *v1.IstioRevision) error {
+	log := logf.FromContext(ctx)
+	releaseName := getReleaseName(rev)
+	namespace := rev.Spec.Namespace
+
+	// List of resource types with their GVK
+	resourceTypes := []struct {
+		gvk schema.GroupVersionKind
+		obj client.Object
+	}{
+		{
+			gvk: schema.GroupVersionKind{Group: "apps", Version: "v1", Kind: "Deployment"},
+			obj: &appsv1.Deployment{},
+		},
+		{
+			gvk: schema.GroupVersionKind{Group: "", Version: "v1", Kind: "Service"},
+			obj: &corev1.Service{},
+		},
+		{
+			gvk: schema.GroupVersionKind{Group: "", Version: "v1", Kind: "ServiceAccount"},
+			obj: &corev1.ServiceAccount{},
+		},
+		{
+			gvk: schema.GroupVersionKind{Group: "", Version: "v1", Kind: "Secret"},
+			obj: &corev1.Secret{},
+		},
+	}
+
+	for _, resource := range resourceTypes {
+		list := &unstructured.UnstructuredList{}
+		list.SetGroupVersionKind(resource.gvk)
+
+		if err := r.Client.List(ctx, list, client.InNamespace(namespace)); err != nil {
+			log.Error(err, "Failed to list resources", "kind", resource.gvk.Kind)
+			continue
+		}
+
+		for _, item := range list.Items {
+			if belongsToRelease(item, releaseName) {
+				log.Info("Cleaning up orphaned resource",
+					"kind", item.GetKind(),
+					"name", item.GetName(),
+					"namespace", item.GetNamespace())
+
+				// Convert back to typed object for proper deletion
+				obj := resource.obj.DeepCopyObject().(client.Object)
+				if err := runtime.DefaultUnstructuredConverter.FromUnstructured(item.Object, obj); err != nil {
+					log.Error(err, "Failed to convert unstructured object")
+					continue
+				}
+
+				if err := r.Client.Delete(ctx, obj); err != nil && !apierrors.IsNotFound(err) {
+					log.Error(err, "Failed to delete orphaned resource")
+				}
+			}
+		}
 	}
 	return nil
 }
 
+func belongsToRelease(obj unstructured.Unstructured, releaseName string) bool {
+	annotations := obj.GetAnnotations()
+	if annotations == nil {
+		return false
+	}
+	return annotations["meta.helm.sh/release-name"] == releaseName
+}
+
 func getReleaseName(rev *v1.IstioRevision) string {
 	return fmt.Sprintf("%s-%s", rev.Name, constants.IstiodChartName)
 }
