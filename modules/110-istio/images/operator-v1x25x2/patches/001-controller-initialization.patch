+// Force cleanup implementation
+func (r *Reconciler) forceCleanup(ctx context.Context, rev *v1.IstioRevision) error {
+	log := logf.FromContext(ctx)
+	releaseName := getReleaseName(rev)
+	namespace := rev.Spec.Namespace
+
+	// 1. Delete the helm secret
+	if err := r.deleteHelmSecret(ctx, releaseName, namespace); err != nil {
+		log.Error(err, "Failed to delete helm secret")
+	}
 
+	// 2. Clean up remaining resources
+	resourceTypes := []schema.GroupVersionKind{
+		{Group: "apps", Version: "v1", Kind: "Deployment"},
+		{Group: "", Version: "v1", Kind: "Service"},
+		{Group: "", Version: "v1", Kind: "ServiceAccount"},
+	}
+
+	for _, gvk := range resourceTypes {
+		if err := r.deleteResourcesByType(ctx, gvk, namespace, releaseName); err != nil {
+			log.Error(err, "Failed to cleanup resources", "kind", gvk.Kind)
+		}
+	}
+
+	return nil
+}
+
+// Delete helm secrets
+func (r *Reconciler) deleteHelmSecret(ctx context.Context, releaseName, namespace string) error {
+	secretList := &corev1.SecretList{}
+	if err := r.Client.List(ctx, secretList, client.InNamespace(namespace)); err != nil {
+		return err
+	}
+
+	for _, secret := range secretList.Items {
+		if secret.Type == "helm.sh/release.v1" && strings.HasPrefix(secret.Name, "sh.helm.release.v1."+releaseName) {
+			if err := r.Client.Delete(ctx, &secret); err != nil {
+				return err
+			}
+		}
+	}
+	return nil
+}
+
+// Delete resources by type
+func (r *Reconciler) deleteResourcesByType(ctx context.Context, gvk schema.GroupVersionKind, namespace, releaseName string) error {
+	list := &unstructured.UnstructuredList{}
+	list.SetGroupVersionKind(gvk)
+
+	if err := r.Client.List(ctx, list, client.InNamespace(namespace)); err != nil {
+		return err
+	}
+
+	for _, item := range list.Items {
+		if belongsToRelease(item, releaseName) {
+			if err := r.Client.Delete(ctx, &item); err != nil && !apierrors.IsNotFound(err) {
+				return err
+			}
+		}
+	}
+	return nil
+}
+
+// Find stuck resources
+func (r *Reconciler) findStuckResources(ctx context.Context, releaseName, namespace string) ([]unstructured.Unstructured, error) {
+	var stuckResources []unstructured.Unstructured
+	resourceTypes := []schema.GroupVersionKind{
+		{Group: "apps", Version: "v1", Kind: "Deployment"},
+		{Group: "", Version: "v1", Kind: "Service"},
+		{Group: "", Version: "v1", Kind: "ServiceAccount"},
+	}
+
+	for _, gvk := range resourceTypes {
+		list := &unstructured.UnstructuredList{}
+		list.SetGroupVersionKind(gvk)
+
+		if err := r.Client.List(ctx, list, client.InNamespace(namespace)); err != nil {
+			return nil, err
+		}
+
+		for _, item := range list.Items {
+			if belongsToRelease(item, releaseName) {
+				stuckResources = append(stuckResources, item)
+			}
+		}
+	}
+	return stuckResources, nil
+}
+
+func (r *Reconciler) setRetryCount(ctx context.Context, rev *v1.IstioRevision, count int) error {
+	patch := client.MergeFrom(rev.DeepCopy())
+	if rev.Annotations == nil {
+		rev.Annotations = make(map[string]string)
+	}
+	rev.Annotations["retry-count"] = strconv.Itoa(count)
+	return r.Client.Patch(ctx, rev, patch)
+}
+
+func (r *Reconciler) clearRetryCount(ctx context.Context, rev *v1.IstioRevision) error {
+	if rev.Annotations == nil || rev.Annotations["retry-count"] == "" {
+		return nil
+	}
+	patch := client.MergeFrom(rev.DeepCopy())
+	delete(rev.Annotations, "retry-count")
+	return r.Client.Patch(ctx, rev, patch)
+}
