+func (r *Reconciler) cleanupOrphanedResources(ctx context.Context, rev *v1.IstioRevision) error {
+	log := logf.FromContext(ctx)
+	releaseName := getReleaseName(rev)
+	namespace := rev.Spec.Namespace
+
+	// List of resource types that might be stuck
+	resourceTypes := []client.Object{
+		&appsv1.Deployment{},
+		&corev1.Service{},
+		&corev1.ServiceAccount{},
+		&corev1.Secret{},
+	}
+
+	for _, obj := range resourceTypes {
+		list := unstructured.UnstructuredList{}
+		list.SetGroupVersionKind(obj.GetObjectKind().GroupVersionKind())
+
+		if err := r.Client.List(ctx, &list, client.InNamespace(namespace)); err != nil {
+			log.Error(err, "Failed to list resources for cleanup")
+			continue
+		}
+
+		for _, item := range list.Items {
+			if belongsToRelease(item, releaseName) {
+				log.Info("Cleaning up orphaned resource",
+					"kind", item.GetKind(),
+					"name", item.GetName())
+				if err := r.Client.Delete(ctx, &item); err != nil {
+					log.Error(err, "Failed to delete orphaned resource")
+				}
+			}
+		}
 	}
 	return nil
 }
 
+func belongsToRelease(obj unstructured.Unstructured, releaseName string) bool {
+	annotations := obj.GetAnnotations()
+	if annotations == nil {
+		return false
+	}
+	return annotations["meta.helm.sh/release-name"] == releaseName
+}
+
 func getReleaseName(rev *v1.IstioRevision) string {
 	return fmt.Sprintf("%s-%s", rev.Name, constants.IstiodChartName)
 }
