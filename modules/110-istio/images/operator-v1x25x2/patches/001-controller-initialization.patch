+func (r *Reconciler) setRetryCount(ctx context.Context, rev *v1.IstioRevision, count int) error {
+	patch := client.MergeFrom(rev.DeepCopy())
+	if rev.Annotations == nil {
+		rev.Annotations = make(map[string]string)
+	}
+	rev.Annotations["retry-count"] = strconv.Itoa(count)
+	return r.Client.Patch(ctx, rev, patch)
+}
+
+func (r *Reconciler) clearRetryCount(ctx context.Context, rev *v1.IstioRevision) error {
+	if rev.Annotations == nil || rev.Annotations["retry-count"] == "" {
+		return nil
+	}
+	patch := client.MergeFrom(rev.DeepCopy())
+	delete(rev.Annotations, "retry-count")
+	return r.Client.Patch(ctx, rev, patch)
+}
