+// directSecretClient uses direct Get calls instead of informers to avoid requiring 'list' permission
+type directSecretClient struct {
+	kc            kube.Client
+	namespace     string
+	secretNames   []string
+	cache         map[string]*v1.Secret
+	cacheMu       sync.RWMutex
+	handlers      []cache.ResourceEventHandler
+	handlersMu    sync.RWMutex
+	stopCh        chan struct{}
+	started       bool
+	startedMu     sync.Mutex
+	initialSync   bool
+	initialSyncMu sync.Mutex
+	pollInterval  time.Duration
+}
+
+var _ kclient.Informer[*v1.Secret] = &directSecretClient{}
+
+func newDirectSecretClient(kc kube.Client, namespace string, secretNames []string) kclient.Informer[*v1.Secret] {
+	return &directSecretClient{
+		kc:           kc,
+		namespace:    namespace,
+		secretNames:  secretNames,
+		cache:        make(map[string]*v1.Secret),
+		stopCh:       make(chan struct{}),
+		pollInterval: 30 * time.Second, // Poll every 30 seconds for changes
+	}
+}
+
+func (d *directSecretClient) Get(name, namespace string) *v1.Secret {
+	if namespace != d.namespace {
+		return nil
+	}
+	d.cacheMu.RLock()
+	defer d.cacheMu.RUnlock()
+	return d.cache[name]
+}
+
+func (d *directSecretClient) List(namespace string, selector klabels.Selector) []*v1.Secret {
+	if namespace != d.namespace && namespace != metav1.NamespaceAll {
+		return nil
+	}
+	d.cacheMu.RLock()
+	defer d.cacheMu.RUnlock()
+	var res []*v1.Secret
+	for _, secret := range d.cache {
+		if selector.Matches(klabels.Set(secret.Labels)) {
+			res = append(res, secret)
+		}
+	}
+	return res
+}
+
+func (d *directSecretClient) ListUnfiltered(namespace string, selector klabels.Selector) []*v1.Secret {
+	return d.List(namespace, selector)
+}
+
+func (d *directSecretClient) AddEventHandler(h cache.ResourceEventHandler) cache.ResourceEventHandlerRegistration {
+	d.handlersMu.Lock()
+	defer d.handlersMu.Unlock()
+	d.handlers = append(d.handlers, h)
+	// Return a dummy registration
+	return &dummyRegistration{client: d, handler: h}
+}
+
+type dummyRegistration struct {
+	client  *directSecretClient
+	handler cache.ResourceEventHandler
+}
+
+func (d *dummyRegistration) HasSynced() bool {
+	return true
+}
+
+func (d *directSecretClient) HasSynced() bool {
+	d.startedMu.Lock()
+	defer d.startedMu.Unlock()
+	return d.started
+}
+
+func (d *directSecretClient) HasSyncedIgnoringHandlers() bool {
+	return d.HasSynced()
+}
+
+func (d *directSecretClient) ShutdownHandlers() {
+	d.handlersMu.Lock()
+	defer d.handlersMu.Unlock()
+	d.handlers = nil
+}
+
+func (d *directSecretClient) Start(stop <-chan struct{}) {
+	d.startedMu.Lock()
+	if d.started {
+		d.startedMu.Unlock()
+		return
+	}
+	d.started = true
+	d.startedMu.Unlock()
+
+	// Initial sync - mark as initial sync
+	d.initialSyncMu.Lock()
+	d.initialSync = true
+	d.initialSyncMu.Unlock()
+	d.syncSecrets()
+	d.initialSyncMu.Lock()
+	d.initialSync = false
+	d.initialSyncMu.Unlock()
+
+	// Start polling goroutine
+	go func() {
+		ticker := time.NewTicker(d.pollInterval)
+		defer ticker.Stop()
+		for {
+			select {
+			case <-stop:
+				return
+			case <-d.stopCh:
+				return
+			case <-ticker.C:
+				d.syncSecrets()
+			}
+		}
+	}()
+}
+
+func (d *directSecretClient) syncSecrets() {
+	d.cacheMu.Lock()
+	oldCache := make(map[string]*v1.Secret)
+	for k, v := range d.cache {
+		oldCache[k] = v
+	}
+	d.cacheMu.Unlock()
+
+	newCache := make(map[string]*v1.Secret)
+	for _, name := range d.secretNames {
+		secret, err := d.kc.Kube().CoreV1().Secrets(d.namespace).Get(context.Background(), name, metav1.GetOptions{})
+		if err != nil {
+			// Secret not found or error - check if it was deleted
+			if oldSecret, exists := oldCache[name]; exists {
+				// Secret was deleted
+				d.notifyDelete(oldSecret)
+			}
+			continue
+		}
+		newCache[name] = secret
+
+		// Check if it's a new secret or updated
+		if oldSecret, exists := oldCache[name]; !exists {
+			// New secret
+			d.notifyAdd(secret)
+		} else if oldSecret.ResourceVersion != secret.ResourceVersion {
+			// Updated secret
+			d.notifyUpdate(oldSecret, secret)
+		}
+	}
+
+	// Check for deleted secrets
+	for name, oldSecret := range oldCache {
+		if _, exists := newCache[name]; !exists {
+			d.notifyDelete(oldSecret)
+		}
+	}
+
+	d.cacheMu.Lock()
+	d.cache = newCache
+	d.cacheMu.Unlock()
+}
+
+func (d *directSecretClient) notifyAdd(obj interface{}) {
+	d.handlersMu.RLock()
+	defer d.handlersMu.RUnlock()
+	d.initialSyncMu.Lock()
+	isInitialSync := d.initialSync
+	d.initialSyncMu.Unlock()
+	for _, h := range d.handlers {
+		h.OnAdd(obj, isInitialSync)
+	}
+}
+
+func (d *directSecretClient) notifyUpdate(oldObj, newObj interface{}) {
+	d.handlersMu.RLock()
+	defer d.handlersMu.RUnlock()
+	for _, h := range d.handlers {
+		h.OnUpdate(oldObj, newObj)
+	}
+}
+
+func (d *directSecretClient) notifyDelete(obj interface{}) {
+	d.handlersMu.RLock()
+	defer d.handlersMu.RUnlock()
+	for _, h := range d.handlers {
+		h.OnDelete(obj)
+	}
+}
+
+func (d *directSecretClient) Index(extract func(*v1.Secret) []string) kclient.RawIndexer {
+	// Simple implementation - return nil or a basic indexer
+	return nil
+}
+
+func (s *secretInformerGroup) Get(name, namespace string) *v1.Secret {
+	for _, inf := range s.informers {
+		if secret := inf.Get(name, namespace); secret != nil {
+			return secret
+		}
+	}
+	return nil
+}
+
+func (s *secretInformerGroup) List(namespace string, selector klabels.Selector) []*v1.Secret {
+	var res []*v1.Secret
+	for _, inf := range s.informers {
+		res = append(res, inf.List(namespace, selector)...)
+	}
+	return res
+}
+
+func (s *secretInformerGroup) ListUnfiltered(namespace string, selector klabels.Selector) []*v1.Secret {
+	var res []*v1.Secret
+	for _, inf := range s.informers {
+		res = append(res, inf.ListUnfiltered(namespace, selector)...)
+	}
+	return res
+}
+
+func (s *secretInformerGroup) AddEventHandler(h cache.ResourceEventHandler) cache.ResourceEventHandlerRegistration {
+	// We need to add the handler to all informers, but we can only return one registration.
+	// We'll add to all and return the first one's registration.
+	var reg cache.ResourceEventHandlerRegistration
+	for i, inf := range s.informers {
+		r := inf.AddEventHandler(h)
+		if i == 0 {
+			reg = r
+		}
+	}
+	return reg
+}
+
+func (s *secretInformerGroup) HasSynced() bool {
+	for _, inf := range s.informers {
+		if !inf.HasSynced() {
+			return false
+		}
+	}
+	return true
+}
+
+func (s *secretInformerGroup) HasSyncedIgnoringHandlers() bool {
+	for _, inf := range s.informers {
+		if !inf.HasSyncedIgnoringHandlers() {
+			return false
+		}
+	}
+	return true
+}
+
+func (s *secretInformerGroup) ShutdownHandlers() {
+	for _, inf := range s.informers {
+		inf.ShutdownHandlers()
+	}
+}
+
+func (s *secretInformerGroup) Start(stop <-chan struct{}) {
+	for _, inf := range s.informers {
+		inf.Start(stop)
+	}
+}
+
+func (s *secretInformerGroup) Index(extract func(*v1.Secret) []string) kclient.RawIndexer {
+	// For simplicity, we'll use the first informer's index.
+	// In practice, this might need more sophisticated handling.
+	if len(s.informers) > 0 {
+		return s.informers[0].Index(extract)
+	}
+	return nil
+}
