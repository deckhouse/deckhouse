 	"time"
 
 	cluster "github.com/envoyproxy/go-control-plane/envoy/config/cluster/v3"
@@ -223,6 +224,7 @@ func (cb *ClusterBuilder) buildSubsetCluster(
 	maybeApplyEdsConfig(subsetCluster.cluster)
 
 	cb.applyMetadataExchange(opts.mutable.cluster)
+	cb.applyOutboundDscp(opts.mutable.cluster)
 
 	// Add the DestinationRule+subsets metadata. Metadata here is generated on a per-cluster
 	// basis in buildCluster, so we can just insert without a copy.
@@ -270,6 +272,7 @@ func (cb *ClusterBuilder) applyDestinationRule(mc *clusterWrapper, clusterMode C
 	maybeApplyEdsConfig(mc.cluster)
 
 	cb.applyMetadataExchange(opts.mutable.cluster)
+	cb.applyOutboundDscp(opts.mutable.cluster)
 
 	if service.MeshExternal {
 		im := getOrCreateIstioMetadata(mc.cluster)
@@ -300,6 +303,36 @@ func (cb *ClusterBuilder) applyMetadataExchange(c *cluster.Cluster) {
 	}
 }
 
+// applyOutboundDscp tags upstream sockets with the IP DSCP value advertised by the proxy
+// (OutboundDscp) when the sidecar runs with the same UID as the app. Envoy sets it via
+// setsockopt(IP_TOS = dscp<<2), which is unprivileged (no CAP_NET_ADMIN, unlike SO_MARK);
+// iptables then exempts those packets via '-m dscp --dscp -j RETURN'.
+func (cb *ClusterBuilder) applyOutboundDscp(c *cluster.Cluster) {
+	if !cb.sidecarProxy() {
+		return
+	}
+	if cb.proxyMetadata == nil || cb.proxyMetadata.OutboundDscp == "" {
+		return
+	}
+	dscp, err := strconv.ParseUint(cb.proxyMetadata.OutboundDscp, 10, 6)
+	if err != nil {
+		return
+	}
+	sockOpt := &core.SocketOption{
+		Description: "outbound DSCP to distinguish Envoy traffic in iptables",
+		Level:       0, // IPPROTO_IP
+		Name:        1, // IP_TOS
+		Value: &core.SocketOption_IntValue{
+			IntValue: int64(dscp << 2), // DSCP occupies the top 6 bits of the TOS byte
+		},
+		State: core.SocketOption_STATE_PREBIND,
+	}
+	if c.UpstreamBindConfig == nil {
+		c.UpstreamBindConfig = &core.BindConfig{}
+	}
+	c.UpstreamBindConfig.SocketOptions = append(c.UpstreamBindConfig.SocketOptions, sockOpt)
+}
+
 // buildCluster builds the default cluster and also applies global options.
 // It is used for building both inbound and outbound cluster.
 func (cb *ClusterBuilder) buildCluster(name string, discoveryType cluster.Cluster_DiscoveryType,
@@ -564,6 +597,7 @@ func (cb *ClusterBuilder) buildDefaultPassthroughCluster() *cluster.Cluster {
 	cluster.AltStatName = util.DelimitedStatsPrefix(util.PassthroughCluster)
 	cb.applyConnectionPool(cb.req.Push.Mesh, newClusterWrapper(cluster), &networking.ConnectionPoolSettings{})
 	cb.applyMetadataExchange(cluster)
+	cb.applyOutboundDscp(cluster)
 	return cluster
 }
 
