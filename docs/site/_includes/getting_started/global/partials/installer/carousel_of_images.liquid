{%- assign installer_data = site.data.getting_started.installer.screenshots -%}
{%- assign filter_group = include.group | default: '' | strip -%}
{%- assign total_slides = 0 -%}
{%- for block in installer_data.screenshots -%}
  {%- if filter_group == '' or block.group == filter_group -%}
    {%- for item in block.items -%}
      {%- assign total_slides = total_slides | plus: 1 -%}
    {%- endfor -%}
  {%- endif -%}
{%- endfor -%}
{%- if total_slides > 0 -%}
<div class="slider" data-slider>
  <div class="slider__viewport">
    <div class="slider__track">
      {%- for block in installer_data.screenshots -%}
        {%- if filter_group == '' or block.group == filter_group -%}
          {%- for item in block.items -%}
      <div class="slider__slide">
        <figure class="slider__figure">
          <img
            src="/images/gs/installer/{{ item.filename }}"
            alt="{{ item.title | default: '' | escape }}"
            decoding="async"
          />
          {%- if item.title -%}
          <figcaption class="slider__caption">{{ item.title | escape }}</figcaption>
          {%- endif -%}
        </figure>
      </div>
          {%- endfor -%}
        {%- endif -%}
      {%- endfor -%}
    </div>
  </div>
  {%- if total_slides > 1 -%}
  <div class="slider__nav" role="group" aria-label="{% if page.lang == 'ru' %}Слайды{% else %}Slides{% endif %}">
    <button type="button" class="slider__prev" aria-label="{% if page.lang == 'ru' %}Предыдущий слайд{% else %}Previous slide{% endif %}">←</button>
    <div class="slider__pagination" aria-live="polite"></div>
    <button type="button" class="slider__next" aria-label="{% if page.lang == 'ru' %}Следующий слайд{% else %}Next slide{% endif %}">→</button>
  </div>
  {%- endif -%}
</div>
{%- endif -%}
