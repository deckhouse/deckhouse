---
# [<en>] Settings for the initial bootstrap of the Deckhouse cluster.
# [<en>] https://deckhouse.io/products/kubernetes-platform/documentation/v1/reference/api/cr.html#initconfiguration
# [<ru>] Настройки первичной инициализации кластера Deckhouse.
# [<ru>] https://deckhouse.ru/products/kubernetes-platform/documentation/v1/reference/api/cr.html#initconfiguration
apiVersion: deckhouse.io/v1
kind: InitConfiguration
deckhouse:
{%- if include.revision == 'ee' %}
  # [<en>] Docker registry address with Deckhouse images (Enterprise Edition).
  # [<ru>] Адрес Docker registry с образами Deckhouse (Enterprise Edition).
  imagesRepo: registry.deckhouse.ru/deckhouse/ee
  # [<en>] A string with your license token to access the Docker registry.
  # [<ru>] Строка с ключом (license string) для доступа к Docker registry.
  registryDockerCfg: <YOUR_ACCESS_STRING_IS_HERE>
{%- else %}
  # [<en>] Docker registry address with Deckhouse images (Community Edition).
  # [<ru>] Адрес Docker registry с образами Deckhouse (Community Edition).
  imagesRepo: registry.deckhouse.ru/deckhouse/ce
  # [<en>] Base64-encoded Docker config JSON for registry.deckhouse.ru (anonymous pull).
  # [<ru>] Base64-закодированный Docker config JSON для registry.deckhouse.ru (анонимный pull).
  registryDockerCfg: eyJhdXRocyI6IHsgInJlZ2lzdHJ5LmRlY2tob3VzZS5ydSI6IHt9fX0K
{%- endif %}
---
# [<en>] General cluster parameters.
# [<en>] https://deckhouse.io/products/kubernetes-platform/documentation/v1/reference/api/cr.html#clusterconfiguration
# [<ru>] Общие параметры кластера.
# [<ru>] https://deckhouse.ru/products/kubernetes-platform/documentation/v1/reference/api/cr.html#clusterconfiguration
apiVersion: deckhouse.io/v1
kind: ClusterConfiguration
clusterType: Static
# [<en>] Address space of the cluster Pods.
# [<ru>] Адресное пространство подов кластера.
# [<en>] You might consider changing this. Ensure that there are no overlaps with serviceSubnetCIDR and internalNetworkCIDRs.
# [<ru>] Возможно, захотите изменить. Убедитесь, что не будет пересечений с serviceSubnetCIDR и internalNetworkCIDRs.
podSubnetCIDR: <POD_SUBNET_CIDR>
# [<en>] Address space of the cluster services.
# [<ru>] Адресное пространство сети сервисов кластера.
# [<en>] You might consider changing this. Ensure that there are no overlaps with podSubnetCIDR and internalNetworkCIDRs.
# [<ru>] Возможно, захотите изменить. Убедитесь, что не будет пересечений с podSubnetCIDR и internalNetworkCIDRs.
serviceSubnetCIDR: <SERVICE_SUBNET_CIDR>
kubernetesVersion: "Automatic"
# [<en>] Cluster domain (used for local routing).
# [<ru>] Домен кластера.
clusterDomain: "internal.cluster.local"
# [<en>] Default container runtime on cluster nodes (NodeGroups).
# [<ru>] Тип container runtime, используемый на узлах кластера (в NodeGroup’ах) по умолчанию.
defaultCRI: "ContainerdV2"
---
# [<en>] Deckhouse module settings.
# [<en>] https://deckhouse.io/modules/deckhouse/configuration.html
# [<ru>] Настройки модуля deckhouse.
# [<ru>] https://deckhouse.ru/modules/deckhouse/configuration.html
apiVersion: deckhouse.io/v1alpha1
kind: ModuleConfig
metadata:
  name: deckhouse
spec:
  version: 1
  enabled: true
  settings:
    bundle: Default
{%- if include.revision == 'ee' %}
    # [<en>] Deckhouse release channel (EE example uses Stable).
    # [<ru>] Канал обновлений Deckhouse (в примере для EE — Stable).
    # [<en>] More info: https://deckhouse.io/products/kubernetes-platform/documentation/v1/reference/release-channels.html
    # [<ru>] Подробнее: https://deckhouse.ru/products/kubernetes-platform/documentation/v1/reference/release-channels.html
    releaseChannel: Stable
{%- else %}
    # [<en>] Deckhouse release channel. Early Access is stable enough for test environments.
    # [<ru>] Канал обновлений Deckhouse. Канал Early Access достаточно стабилен для тестовых сред.
    # [<en>] More info: https://deckhouse.io/products/kubernetes-platform/documentation/v1/reference/release-channels.html
    # [<ru>] Подробнее: https://deckhouse.ru/products/kubernetes-platform/documentation/v1/reference/release-channels.html
    releaseChannel: EarlyAccess
{%- endif %}
    logLevel: Info
---
# [<en>] Global Deckhouse settings.
# [<en>] https://deckhouse.io/products/kubernetes-platform/documentation/v1/reference/api/global.html#parameters
# [<ru>] Глобальные настройки Deckhouse.
# [<ru>] https://deckhouse.ru/products/kubernetes-platform/documentation/v1/reference/api/global.html#%D0%BF%D0%B0%D1%80%D0%B0%D0%BC%D0%B5%D1%82%D1%80%D1%8B
apiVersion: deckhouse.io/v1alpha1
kind: ModuleConfig
metadata:
  name: global
spec:
  version: 2
  settings:
    # [<en>] Default StorageClass for cluster PVCs (must match NFSStorageClass metadata.name below).
    # [<ru>] StorageClass по умолчанию для PVC кластера (должен совпадать с metadata.name у NFSStorageClass ниже).
    defaultClusterStorageClass: <NFS_STORAGE_CLASS_NAME>
    modules:
      # [<en>] Template for system application URLs in the cluster (e.g. Grafana at grafana.example.com for %s.example.com).
      # [<en>] Must NOT match clusterDomain in ClusterConfiguration.
      # [<ru>] Шаблон адресов системных приложений (например, Grafana на grafana.example.com для %s.example.com).
      # [<ru>] Не должен совпадать с clusterDomain в ClusterConfiguration.
      publicDomainTemplate: "<PUBLIC_DOMAIN_TEMPLATE>"
---
# [<en>] user-authn module settings.
# [<en>] https://deckhouse.io/modules/user-authn/configuration.html
# [<ru>] Настройки модуля user-authn.
# [<ru>] https://deckhouse.ru/modules/user-authn/configuration.html
apiVersion: deckhouse.io/v1alpha1
kind: ModuleConfig
metadata:
  name: user-authn
spec:
  version: 2
  enabled: true
  settings:
    controlPlaneConfigurator:
      dexCAMode: DoNotNeed
    # [<en>] Expose Kubernetes API via Ingress (see module docs).
    # [<ru>] Доступ к API Kubernetes через Ingress (см. документацию модуля).
    publishAPI:
      enabled: true
      https:
        mode: Global
        global:
          kubeconfigGeneratorMasterCA: ""
---
# [<en>] cni-cilium module settings.
# [<en>] https://deckhouse.io/modules/cni-cilium/configuration.html
# [<ru>] Настройки модуля cni-cilium.
# [<ru>] https://deckhouse.ru/modules/cni-cilium/configuration.html
apiVersion: deckhouse.io/v1alpha1
kind: ModuleConfig
metadata:
  name: cni-cilium
spec:
  version: 1
  enabled: true
  settings:
    tunnelMode: VXLAN
---
# [<en>] admission-policy-engine module settings.
# [<en>] https://deckhouse.io/modules/admission-policy-engine/configuration.html
# [<ru>] Настройки модуля admission-policy-engine.
# [<ru>] https://deckhouse.ru/modules/admission-policy-engine/configuration.html
apiVersion: deckhouse.io/v1alpha1
kind: ModuleConfig
metadata:
  name: admission-policy-engine
spec:
  version: 1
  enabled: true
---
# [<en>] multitenancy-manager module settings (projects, quotas).
# [<en>] https://deckhouse.io/modules/multitenancy-manager/configuration.html
# [<ru>] Настройки модуля multitenancy-manager (проекты, квоты).
# [<ru>] https://deckhouse.ru/modules/multitenancy-manager/configuration.html
apiVersion: deckhouse.io/v1alpha1
kind: ModuleConfig
metadata:
  name: multitenancy-manager
spec:
  version: 1
  enabled: true
---
# [<en>] Static cluster settings (internal node networks).
# [<en>] https://deckhouse.io/products/kubernetes-platform/documentation/v1/reference/api/cr.html#staticclusterconfiguration
# [<ru>] Параметры статического кластера (внутренние сети узлов).
# [<ru>] https://deckhouse.ru/products/kubernetes-platform/documentation/v1/reference/api/cr.html#staticclusterconfiguration
apiVersion: deckhouse.io/v1
kind: StaticClusterConfiguration
internalNetworkCIDRs:
  # [<en>] CIDRs used to reach nodes from the installer (must cover node IPs).
  # [<ru>] Подсети, из которых доступны узлы для инсталлятора (должны покрывать IP узлов).
  - <INTERNAL_NETWORK_CIDRS>
---
# [<en>] Worker NodeGroup for static machines (see node-manager docs).
# [<en>] https://deckhouse.io/modules/node-manager/cr.html#nodegroup
# [<ru>] Группа worker-узлов для статических машин (см. документацию node-manager).
# [<ru>] https://deckhouse.ru/modules/node-manager/cr.html#nodegroup
apiVersion: deckhouse.io/v1
kind: NodeGroup
metadata:
  name: worker
spec:
  nodeType: Static
  staticInstances:
    # [<en>] Single worker StaticInstance in this quick start.
    # [<ru>] Один worker StaticInstance в этом быстром старте.
    count: 1
    labelSelector:
      matchLabels:
        role: worker
---
# [<en>] SSH credentials for connecting to static nodes (used by StaticInstance).
# [<en>] https://deckhouse.io/products/kubernetes-platform/documentation/v1/reference/api/cr.html#sshcredentials
# [<ru>] SSH-доступ к статическим узлам (для StaticInstance).
# [<ru>] https://deckhouse.ru/products/kubernetes-platform/documentation/v1/reference/api/cr.html#sshcredentials
apiVersion: deckhouse.io/v1alpha1
kind: SSHCredentials
metadata:
  name: caps
spec:
  user: caps
  privateSSHKey: "`cat /dev/shm/caps-id | base64 -w0`"
---
# [<en>] Worker machine for this quick start (address from the “Cluster parameters” step).
# [<ru>] Worker-узел для этого быстрого старта (адрес с шага «Параметры кластера»).
apiVersion: deckhouse.io/v1alpha1
kind: StaticInstance
metadata:
  name: dvp-worker-1
  labels:
    role: worker
spec:
  address: <WORKER_NODE_IP>
  credentialsRef:
    kind: SSHCredentials
    name: caps
---
# [<en>] csi-nfs module settings.
# [<en>] https://deckhouse.io/modules/csi-nfs/configuration.html
# [<ru>] Настройки модуля csi-nfs.
# [<ru>] https://deckhouse.ru/modules/csi-nfs/configuration.html
apiVersion: deckhouse.io/v1alpha1
kind: ModuleConfig
metadata:
  name: csi-nfs
spec:
  version: 1
  enabled: true
---
# [<en>] virtualization module settings (DVCR, VM networks).
# [<en>] https://deckhouse.io/modules/virtualization/configuration.html
# [<ru>] Настройки модуля virtualization (DVCR, сети ВМ).
# [<ru>] https://deckhouse.ru/modules/virtualization/configuration.html
apiVersion: deckhouse.io/v1alpha1
kind: ModuleConfig
metadata:
  name: virtualization
spec:
  version: 1
  enabled: true
  settings:
    dvcr:
      storage:
        persistentVolumeClaim:
          # [<en>] DVCR PVC size (e.g. 60Gi).
          # [<ru>] Размер PVC для DVCR (например, 60Gi).
          size: <DVCR_STORAGE_SIZE>
        type: PersistentVolumeClaim
    # [<en>] CIDRs for virtual machine traffic (must not overlap with pod/service subnets).
    # [<ru>] CIDR для трафика виртуальных машин (не должен пересекаться с pod/service).
    virtualMachineCIDRs:
      - <VIRTUAL_MACHINE_CIDRS>
---
# [<en>] NFS StorageClass for cluster and virtualization storage.
# [<en>] https://deckhouse.io/modules/csi-nfs/cr.html#nfsstorageclass
# [<ru>] NFS StorageClass для хранения в кластере и виртуализации.
# [<ru>] https://deckhouse.ru/modules/csi-nfs/cr.html#nfsstorageclass
apiVersion: storage.deckhouse.io/v1alpha1
kind: NFSStorageClass
metadata:
  name: <NFS_STORAGE_CLASS_NAME>
spec:
  connection:
    host: <NFS_HOST>
    share: <NFS_SHARE>
    nfsVersion: "4.1"
  reclaimPolicy: Delete
  volumeBindingMode: WaitForFirstConsumer
  workloadNodes:
    nodeSelector:
      matchLabels:
        storage: "true"
---
# [<en>] Ingress NGINX Controller (HostPort on control-plane nodes for quick start).
# [<en>] https://deckhouse.io/modules/ingress-nginx/cr.html
# [<ru>] Ingress NGINX Controller (HostPort на control-plane для быстрого старта).
# [<ru>] https://deckhouse.ru/modules/ingress-nginx/cr.html
apiVersion: deckhouse.io/v1
kind: IngressNginxController
metadata:
  name: nginx
spec:
  ingressClass: nginx
  inlet: HostPort
  hostPort:
    httpPort: 80
    httpsPort: 443
  nodeSelector:
    node-role.kubernetes.io/control-plane: ""
  tolerations:
    - effect: NoSchedule
      key: node-role.kubernetes.io/control-plane
      operator: Exists
---
# [<en>] snapshot-controller module settings.
# [<en>] https://deckhouse.io/modules/snapshot-controller/configuration.html
# [<ru>] Настройки модуля snapshot-controller.
# [<ru>] https://deckhouse.ru/modules/snapshot-controller/configuration.html
apiVersion: deckhouse.io/v1alpha1
kind: ModuleConfig
metadata:
  name: snapshot-controller
spec:
  source: deckhouse
  version: 1
  enabled: true
---
# [<en>] console module settings.
# [<en>] https://deckhouse.io/modules/console/configuration.html
# [<ru>] Настройки модуля console.
# [<ru>] https://deckhouse.ru/modules/console/configuration.html
apiVersion: deckhouse.io/v1alpha1
kind: ModuleConfig
metadata:
  name: console
spec:
  version: 1
  enabled: true
---
apiVersion: deckhouse.io/v1alpha1
kind: ModuleConfig
metadata:
  name: upmeter
spec:
  enabled: false
---
apiVersion: deckhouse.io/v1alpha1
kind: ModuleConfig
metadata:
  name: local-path-provisioner
spec:
  enabled: false
---
apiVersion: deckhouse.io/v1alpha1
kind: ModuleConfig
metadata:
  name: pod-reloader
spec:
  enabled: false
---
apiVersion: deckhouse.io/v1alpha1
kind: ModuleConfig
metadata:
  name: secret-copier
spec:
  enabled: false
---
apiVersion: deckhouse.io/v1alpha1
kind: ModuleConfig
metadata:
  name: namespace-configurator
spec:
  enabled: false
---
# [<en>] Project for multitenancy-manager (resource quota and admins).
# [<en>] https://deckhouse.io/modules/multitenancy-manager/cr.html#project
# [<ru>] Проект для multitenancy-manager (квота ресурсов и администраторы).
# [<ru>] https://deckhouse.ru/modules/multitenancy-manager/cr.html#project
apiVersion: deckhouse.io/v1alpha2
kind: Project
metadata:
  name: <DVP_PROJECT_NAME>
spec:
  description: <DVP_PROJECT_NAME>
  projectTemplateName: default
  parameters:
    resourceQuota:
      requests:
        cpu: 20
        memory: 20Gi
      limits:
        cpu: 20
        memory: 20Gi
    administrators:
      - subject: User
        name: <USER_NAME>@deckhouse.io
---
# [<en>] Static user for web console access.
# [<en>] https://deckhouse.io/modules/user-authn/cr.html#user
# [<ru>] Статический пользователь для доступа к веб-консоли.
# [<ru>] https://deckhouse.ru/modules/user-authn/cr.html#user
apiVersion: deckhouse.io/v1
kind: User
metadata:
  name: <USER_NAME>
spec:
  email: <USER_NAME>@deckhouse.io
  # [<en>] bcrypt hash for the generated password (filled on the “Cluster parameters” step).
  # [<en>] echo -n '<GENERATED_PASSWORD>' | htpasswd -BinC 10 "" | cut -d: -f2 | tr -d '\n' | base64 -w0; echo
  # [<ru>] bcrypt-хеш сгенерированного пароля (заполняется на шаге «Параметры кластера»).
  # [<ru>] echo -n '<GENERATED_PASSWORD>' | htpasswd -BinC 10 "" | cut -d: -f2 | tr -d '\n' | base64 -w0; echo
  password: '<GENERATED_PASSWORD_HASH>'
---
# [<en>] Grant admin role in the project namespace.
# [<en>] https://deckhouse.io/modules/user-authz/cr.html
# [<ru>] Выдача роли admin в неймспейсе проекта.
# [<ru>] https://deckhouse.ru/modules/user-authz/cr.html
apiVersion: rbac.authorization.k8s.io/v1
kind: RoleBinding
metadata:
  namespace: <DVP_PROJECT_NAME>
  name: admin
subjects:
  - kind: User
    name: <USER_NAME>@deckhouse.io
    apiGroup: rbac.authorization.k8s.io
roleRef:
  kind: ClusterRole
  name: d8:use:role:admin
  apiGroup: rbac.authorization.k8s.io
# [<en>] caps SSH public key (same value is passed to the dhctl installer context).
# [<ru>] SSH-публичный ключ caps (то же значение передаётся в контекст инсталлятора dhctl).
# <SSH_PUBLIC_KEY>
