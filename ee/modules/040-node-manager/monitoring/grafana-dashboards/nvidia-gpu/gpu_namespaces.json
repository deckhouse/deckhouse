          "thresholds": {
            "mode": "absolute",
            "steps": [
              {
                "color": "green",
                "value": null
              }
            ]
          }
        },
        "overrides": [
          {
            "matcher": {
              "id": "byName",
              "options": "Value #B"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Compute Utilization"
              },
              {
                "id": "unit",
                "value": "percent"
              },
              {
                "id": "noValue",
                "value": "N/A"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Value #C"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "Requested"
              },
              {
                "id": "unit",
                "value": "GPUs"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "Value #H"
            },
            "properties": [
              {
                "id": "displayName",
                "value": "GPU Memory Utilization"
              },
              {
                "id": "unit",
                "value": "percent"
              }
            ]
          },
          {
            "matcher": {
              "id": "byName",
              "options": "namespace"
            },
            "properties": [
              {
                "id": "links",
                "value": [
                  {
                    "title": "",
                    "url": "/d/gpu-namespace/gpu-namespace?var-ds_prometheus=${ds_prometheus}&var-namespace=${__value.raw}&${__url_time_range}"
                  }
                ]
              }
            ]
          }
        ]
      },
      "gridPos": {
        "h": 8,
        "w": 24,
        "x": 0,
        "y": 0
      },
      "id": 27,
      "options": {
        "cellHeight": "sm",
        "footer": {
          "countRows": false,
          "enablePagination": false,
          "fields": "",
          "reducer": [
            "sum"
          ],
          "show": false
        },
        "showHeader": true,
        "sortBy": []
      },
      "pluginVersion": "10.4.5",
      "targets": [
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${ds_prometheus}"
          },
          "editorMode": "code",
          "exemplar": false,
          "expr": "(avg(label_replace(DCGM_FI_DEV_GPU_UTIL{exported_namespace!=\"\"}, \"namespace\", \"$1\", \"exported_namespace\", \"(.+)\")) by (namespace)) or (avg(label_replace(DCGM_FI_PROF_SM_ACTIVE{exported_namespace!=\"\"} * 100, \"namespace\", \"$1\", \"exported_namespace\", \"(.+)\")) by (namespace)) or (avg(label_replace(DCGM_FI_PROF_GR_ENGINE_ACTIVE{exported_namespace!=\"\"} * 100, \"namespace\", \"$1\", \"exported_namespace\", \"(.+)\")) by (namespace))",
          "format": "table",
          "hide": false,
          "instant": true,
          "legendFormat": "Compute Utilization",
          "range": false,
          "refId": "B"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${ds_prometheus}"
          },
          "editorMode": "code",
          "exemplar": false,
          "expr": "sum(kube_pod_container_resource_requests{namespace!=\"\",resource=~\"nvidia_com_gpu|nvidia_com_mig_.*\"}) by (namespace)",
          "format": "table",
          "hide": false,
          "instant": true,
          "legendFormat": "Requested",
          "range": false,
          "refId": "C"
        },
        {
          "datasource": {
            "type": "prometheus",
            "uid": "${ds_prometheus}"
          },
          "editorMode": "code",
          "exemplar": false,
          "expr": "100 * sum(label_replace(DCGM_FI_DEV_FB_USED{exported_namespace!=\"\"}, \"namespace\", \"$1\", \"exported_namespace\", \"(.+)\")) by (namespace) / clamp_min(sum(label_replace(DCGM_FI_DEV_FB_USED{exported_namespace!=\"\"}, \"namespace\", \"$1\", \"exported_namespace\", \"(.+)\")) by (namespace) + sum(label_replace(DCGM_FI_DEV_FB_FREE{exported_namespace!=\"\"}, \"namespace\", \"$1\", \"exported_namespace\", \"(.+)\")) by (namespace), 1)",
          "format": "table",
          "hide": false,
          "instant": true,
          "legendFormat": "GPU Memory Utilization",
          "range": false,
          "refId": "H"
        }
      ],
      "title": "Summary",
      "transformations": [
        {
          "id": "merge",
          "options": {}
        },
        {
          "id": "filterFieldsByName",
          "options": {
            "include": {
              "names": [
