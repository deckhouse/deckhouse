+// isLoadBalancerDeleteIgnorableError returns true when LB cleanup can be skipped during cluster deletion.
+// VCD tenants (e.g. NO_RDE clusters) may lack rights to read/delete LB virtual services; cluster teardown
+// should not block on orphaned LB objects.
+func isLoadBalancerDeleteIgnorableError(err error) bool {
+	if err == nil {
+		return false
+	}
+	if errors.Is(err, govcd.ErrorEntityNotFound) {
+		return true
+	}
+	errMsg := strings.ToLower(err.Error())
+	return strings.Contains(errMsg, "403") ||
+		strings.Contains(errMsg, "forbidden") ||
+		strings.Contains(errMsg, "404") ||
+		strings.Contains(errMsg, "not found")
+}
