+	// Override the default ReauthFunc set by gophercloud. The default implementation
+	// authenticates a throw-away client and only copies the token back via CopyTokenFrom,
+	// leaving EndpointLocator with a stale service catalog. After long pod lifetimes
+	// this causes re-authentication failures if the catalog has changed.
+	// Instead, re-authenticate the main provider directly so both the token and
+	// EndpointLocator are refreshed.
+	globalForReauth := global
+	provider.ReauthFunc = func(ctx context.Context) error {
+		klog.V(4).Info("cinder-csi: performing full OpenStack re-authentication with catalog refresh")
+		opts := globalForReauth.ToAuthOptions()
+		opts.AllowReauth = false
+		if err := openstack.Authenticate(ctx, provider, opts); err != nil {
+			klog.Errorf("cinder-csi: OpenStack re-authentication failed: %v", err)
+			return err
+		}
+		return nil
+	}
+
